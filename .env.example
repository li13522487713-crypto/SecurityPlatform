# 镜像仓库和标签（deploy.sh 会覆盖 *_IMAGE_TAG）
BACKEND_IMAGE_REPO=atlas-backend
FRONTEND_IMAGE_REPO=atlas-frontend
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# 服务端口
HTTP_PORT=80
HTTPS_PORT=443
ASPNETCORE_URLS=http://+:5000
ASPNETCORE_ENVIRONMENT=Production

# ============================================================
# 必填安全配置（生产部署必须替换！请勿使用示例值！）
# ============================================================
# JWT 签名密钥：必须 ≥32 位随机字符串，不得包含 CHANGE_ME
# 生成示例：openssl rand -base64 48
JWT_SIGNING_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Bootstrap 管理员密码：必须满足复杂度（大写+小写+数字+特殊字符，≥8位）
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# 文件服务签名密钥：必须 ≥32 位随机字符串（如不使用文件签名可保留默认值）
# 生成示例：openssl rand -base64 48
FILE_SIGNED_URL_SECRET=CHANGE_ME_TO_RANDOM_FILE_SECRET

# ============================================================
# 可选配置
# ============================================================
CORS_ALLOWED_ORIGIN=https://app.example.com
DATABASE_CONNECTION_STRING=Data Source=/app/data/atlas.db
DATABASE_ENCRYPTION_KEY=
FILE_STORAGE_BASE_PATH=/app/uploads
PLUGINS_ROOT_PATH=/app/plugins
OTEL_EXPORTER_OTLP_ENDPOINT=

# TLS 证书挂载目录：/opt/atlas/certs
# 需要提供：
# - /opt/atlas/certs/server.crt
# - /opt/atlas/certs/server.key
