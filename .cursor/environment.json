{
  "install": "bash scripts/cursor-cloud-install.sh",
  "terminals": [
    {
      "name": "PlatformHost",
      "command": "dotnet run --project src/backend/Atlas.PlatformHost",
      "description": "启动平台后端服务 (:5001)"
    },
    {
      "name": "AppHost",
      "command": "dotnet run --project src/backend/Atlas.AppHost",
      "description": "启动应用后端服务 (:5002)"
    },
    {
      "name": "AppWeb Dev",
      "command": "pnpm run dev:app-web --prefix src/frontend",
      "description": "启动当前唯一前端开发服务器 app-web (:5181)"
    }
  ]
}
