{
  "type": "page",
  "title": "动态表设计器",
  "body": [
    {
      "type": "form",
      "name": "tableForm",
      "api": {
        "method": "post",
        "url": "/api/v1/dynamic-tables",
        "data": {
          "tableKey": "${tableKey}",
          "displayName": "${displayName}",
          "description": "${description}",
          "dbType": "${dbType}",
          "fields": "${fields}",
          "indexes": "${indexes}"
        },
        "adaptor": "return { status: payload.success ? 0 : 1, msg: payload.message || '操作失败', data: payload.data };",
        "messages": {
          "success": "动态表保存成功！",
          "failed": "保存失败：${msg}"
        }
      },
      "body": [
        {
          "type": "fieldset",
          "title": "基础信息",
          "collapsable": true,
          "body": [
            {
              "type": "input-text",
              "name": "tableKey",
              "label": "表标识",
              "required": true,
              "description": "仅字母/数字/下划线，且以字母开头。",
              "validation": {
                "pattern": "^[A-Za-z][A-Za-z0-9_]{1,63}$",
                "message": "表标识格式不正确"
              }
            },
            {
              "type": "input-text",
              "name": "displayName",
              "label": "表名称",
              "required": true
            },
            {
              "type": "textarea",
              "name": "description",
              "label": "描述"
            },
            {
              "type": "select",
              "name": "dbType",
              "label": "数据库类型",
              "value": "Sqlite",
              "options": [
                { "label": "SQLite", "value": "Sqlite" },
                { "label": "SQL Server", "value": "SqlServer" },
                { "label": "MySQL", "value": "MySql" },
                { "label": "PostgreSQL", "value": "PostgreSql" }
              ]
            }
          ]
        },
        {
          "type": "fieldset",
          "title": "字段定义",
          "collapsable": true,
          "body": [
            {
              "type": "input-table",
              "name": "fields",
              "label": "字段定义",
              "addable": true,
              "editable": true,
              "removable": true,
              "columns": [
                {
                  "name": "name",
                  "label": "字段名",
                  "type": "input-text",
                  "required": true,
                  "validation": {
                    "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$",
                    "message": "字段名格式不正确"
                  }
                },
                {
                  "name": "displayName",
                  "label": "显示名",
                  "type": "input-text"
                },
                {
                  "name": "fieldType",
                  "label": "类型",
                  "type": "select",
                  "required": true,
                  "options": [
                    { "label": "Int", "value": "Int" },
                    { "label": "Long", "value": "Long" },
                    { "label": "Decimal", "value": "Decimal" },
                    { "label": "String", "value": "String" },
                    { "label": "Text", "value": "Text" },
                    { "label": "Bool", "value": "Bool" },
                    { "label": "DateTime", "value": "DateTime" },
                    { "label": "Date", "value": "Date" }
                  ]
                },
                {
                  "name": "length",
                  "label": "长度",
                  "type": "input-number",
                  "visibleOn": "data.fieldType === 'String'",
                  "value": 50
                },
                {
                  "name": "precision",
                  "label": "精度",
                  "type": "input-number",
                  "visibleOn": "data.fieldType === 'Decimal'",
                  "value": 18
                },
                {
                  "name": "scale",
                  "label": "小数位",
                  "type": "input-number",
                  "visibleOn": "data.fieldType === 'Decimal'",
                  "value": 2
                },
                {
                  "name": "allowNull",
                  "label": "可为空",
                  "type": "switch",
                  "value": true
                },
                {
                  "name": "isPrimaryKey",
                  "label": "主键",
                  "type": "checkbox"
                },
                {
                  "name": "isAutoIncrement",
                  "label": "自增",
                  "type": "checkbox",
                  "visibleOn": "data.isPrimaryKey && (data.fieldType === 'Int' || data.fieldType === 'Long')"
                },
                {
                  "name": "isUnique",
                  "label": "唯一",
                  "type": "checkbox"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
