{
  "type": "page",
  "title": "动态表管理",
  "body": [
    {
      "type": "crud",
      "name": "tableCrud",
      "api": {
        "method": "get",
        "url": "/api/v1/dynamic-tables?pageIndex=${pageIndex}&pageSize=${pageSize}&keyword=${keyword}",
        "adaptor": "if (!payload.success) { return { status: 1, msg: payload.message }; } var d = payload.data; return { status: 0, data: { items: d.items, total: d.total, pageIndex: d.pageIndex, pageSize: d.pageSize } };"
      },
      "pageField": "pageIndex",
      "perPageField": "pageSize",
      "pageSize": 20,
      "filter": {
        "title": "搜索",
        "body": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "关键字"
          }
        ]
      },
      "columns": [
        { "name": "tableKey", "label": "表标识" },
        { "name": "displayName", "label": "表名称" },
        { "name": "dbType", "label": "数据库类型" },
        { "name": "status", "label": "状态" },
        { "name": "createdAt", "label": "创建时间" },
        {
          "type": "operation",
          "label": "操作",
          "buttons": [
            {
              "type": "button",
              "label": "进入数据",
              "actionType": "link",
              "link": "/dynamic-tables/${tableKey}"
            },
            {
              "type": "button",
              "label": "删除",
              "level": "danger",
              "actionType": "ajax",
              "confirmText": "确认删除该表？此操作不可恢复。",
              "api": {
                "method": "delete",
                "url": "/api/v1/dynamic-tables/${tableKey}",
                "adaptor": "return { status: payload.success ? 0 : 1, msg: payload.message };"
              }
            }
          ]
        }
      ],
      "headerToolbar": [
        {
          "type": "button",
          "label": "新建表",
          "level": "primary",
          "actionType": "drawer",
          "drawer": {
            "title": "新建动态表",
            "size": "lg",
            "body": {
              "type": "service",
              "schemaApi": "get:/api/v1/amis/dynamic-tables/designer"
            }
          }
        },
        "bulkActions",
        "pagination"
      ]
    }
  ]
}
