{
  "name": "atlas-coze-workflow-host",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\prepare-coze-workflow-host.ps1",
    "build:upstream": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\prepare-coze-workflow-host.ps1",
    "build:upstream:deploy-only": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\prepare-coze-workflow-host.ps1 -SkipInstall -SkipBuild",
    "build:upstream:build-only": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\prepare-coze-workflow-host.ps1 -SkipInstall -SkipDeploy",
    "dev": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\start-coze-workflow-host-preview.ps1",
    "preview:upstream": "powershell -ExecutionPolicy Bypass -File ..\\..\\scripts\\start-coze-workflow-host-preview.ps1",
    "test": "vitest --run --passWithNoTests"
  },
  "dependencies": {
    "@coze-arch/bot-env": "workspace:*",
    "@coze-arch/bot-typings": "workspace:*",
    "@coze-arch/import-watch-loader": "workspace:*",
    "@coze-arch/pkg-root-webpack-plugin": "workspace:*",
    "@coze-arch/responsive-kit": "workspace:*",
    "@coze-arch/rsbuild-config": "workspace:*",
    "@coze-workflow/playground-adapter": "workspace:*",
    "@rsbuild/core": "~1.1.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "~3.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "~5.9.3",
    "vitest": "~3.0.5",
    "webpack": "~5.91.0"
  },
  "pnpm": {
    "overrides": {
      "@less/test-data": "link:./vendor/less-test-data",
      "@less/test-import-module": "link:./vendor/less-test-import-module",
      "@reactflow/eslint-config": "link:./vendor/reactflow/eslint-config",
      "@reactflow/rollup-config": "link:./vendor/reactflow/rollup-config",
      "@reactflow/tsconfig": "link:./vendor/reactflow/tsconfig"
    }
  },
  "packageManager": "pnpm@8.15.8+sha512.d1a029e1a447ad90bc96cd58b0fad486d2993d531856396f7babf2d83eb1823bb83c5a3d0fc18f675b2d10321d49eb161fece36fe8134aa5823ecd215feed392"
}
