{
  "extends": "@coze-arch/ts-config/tsconfig.web.json",
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "isolatedModules": true,
    "target": "ES2020",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "dist/tsconfig.build.tsbuildinfo"
  },
  "include": ["src", "rsbuild.config.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../frontend/config/eslint-config/tsconfig.build.json" },
    { "path": "../frontend/config/postcss-config/tsconfig.build.json" },
    { "path": "../frontend/config/rsbuild-config/tsconfig.build.json" },
    { "path": "../frontend/config/stylelint-config/tsconfig.build.json" },
    { "path": "../frontend/config/tailwind-config/tsconfig.build.json" },
    { "path": "../frontend/config/ts-config/tsconfig.build.json" },
    { "path": "../frontend/config/vitest-config/tsconfig.build.json" },
    { "path": "../frontend/infra/plugins/import-watch-loader/tsconfig.build.json" },
    { "path": "../frontend/infra/plugins/pkg-root-webpack-plugin/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/bot-env/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/bot-typings/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/default-slardar/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/i18n/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/logger/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/responsive-kit/tsconfig.build.json" },
    { "path": "../frontend/packages/arch/web-context/tsconfig.build.json" },
    { "path": "../frontend/packages/workflow/adapter/playground/tsconfig.build.json" }
  ]
}
