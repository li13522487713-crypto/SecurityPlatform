{
  "name": "atlas-frontend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:app-web": "pnpm --filter atlas-app-web run dev",
    "dev:app-web:platform": "pnpm --filter atlas-app-web run dev",
    "dev:app-web:direct": "pnpm --filter atlas-app-web run dev",
    "build": "pnpm run build:app-web",
    "build:app-web": "pnpm --filter atlas-app-web run build",
    "lint": "pnpm --filter atlas-app-web run lint",
    "test:unit": "pnpm --filter @atlas/shared-core run test && pnpm --filter @atlas/runtime-core run test",
    "format": "pnpm -r run format",
    "test:e2e:app": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs",
    "test:e2e:app:headed": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --headed",
    "test:e2e:app:smoke": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --grep @smoke",
    "i18n:check": "node ./scripts/i18n-audit.mjs --target app-web --strict"
  },
  "devDependencies": {
    "@atlas/app-shell-shared": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
