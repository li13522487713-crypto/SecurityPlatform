{
  "name": "atlas-frontend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:app-web": "pnpm --filter atlas-app-web run dev",
    "dev:lowcode-studio": "pnpm --filter atlas-lowcode-studio-web run dev",
    "build": "pnpm run build:app-web",
    "build:app-web": "pnpm --filter atlas-app-web run build",
    "lint": "pnpm run lint:app-web",
    "lint:app-web": "pnpm --filter atlas-app-web run lint",
    "test:unit": "pnpm exec vitest run --passWithNoTests \"packages/**/src/**/*.spec.ts\" \"packages/**/src/**/*.spec.tsx\" \"packages/**/src/**/*.test.ts\" \"packages/**/src/**/*.test.tsx\" \"apps/**/src/**/*.spec.ts\" \"apps/**/src/**/*.spec.tsx\" \"apps/**/src/**/*.test.ts\" \"apps/**/src/**/*.test.tsx\"",
    "format": "pnpm -r run format",
    "test:e2e:full": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --config playwright.e2e-all.config.ts",
    "test:e2e:app": "pnpm run test:e2e:full",
    "test:e2e:app:only": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --config playwright.app.config.ts",
    "test:e2e:app:headed": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --config playwright.app.config.ts --headed",
    "test:e2e:app:smoke": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-app-e2e.mjs --config playwright.app.config.ts --grep @smoke-main",
    "coze:diff": "node ../../tools/coze-source-diff/index.mjs",
    "i18n:check": "node ./scripts/i18n-audit.mjs --target app-web --strict --scan-packages --check-labels-coverage"
  },
  "devDependencies": {
    "@atlas/app-shell-shared": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "18.2.0",
      "react-dom": "18.2.0",
      "styled-components": "6.4.0",
      "@swc/helpers": "0.5.21",
      "@douyinfe/semi-ui": "2.94.0",
      "@douyinfe/semi-icons": "2.94.0",
      "@douyinfe/semi-foundation": "2.94.0",
      "@douyinfe/semi-illustrations": "2.94.0"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
