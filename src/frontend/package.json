{
  "name": "atlas-frontend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:platform-web": "pnpm --filter atlas-platform-web run dev",
    "dev:app-web": "pnpm --filter atlas-app-web run dev",
    "dev:app-web:platform": "pnpm --filter atlas-app-web run dev:platform",
    "dev:app-web:direct": "pnpm --filter atlas-app-web run dev:direct",
    "build": "pnpm -r run build",
    "build:platform-web": "pnpm --filter atlas-platform-web run build",
    "build:app-web": "pnpm --filter atlas-app-web run build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "test:e2e:setup": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-setup-e2e.mjs",
    "test:e2e:setup:headed": "node ./scripts/reset-setup-state.mjs && node ./scripts/run-setup-e2e.mjs --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
