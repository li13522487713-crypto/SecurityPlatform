{
  "name": "atlas-lowcode-studio-web",
  "private": true,
  "version": "0.0.0",
  "description": "Atlas 低代码应用设计器主入口（M07，端口 5183）。三栏壳层 + 5 Tab + 多页面 + 变量 + 资源投射 + FAQ。",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec rsbuild dev --host 0.0.0.0",
    "build": "pnpm exec rsbuild build",
    "preview": "pnpm exec rsbuild preview",
    "lint": "pnpm exec eslint --max-warnings 0 \"src/**/*.{ts,tsx}\"",
    "test": "vitest --run --passWithNoTests"
  },
  "dependencies": {
    "@atlas/app-shell-shared": "workspace:*",
    "@atlas/lowcode-action-runtime": "workspace:*",
    "@atlas/lowcode-component-registry": "workspace:*",
    "@atlas/lowcode-components-web": "workspace:*",
    "@atlas/lowcode-debug-client": "workspace:*",
    "@atlas/lowcode-versioning-client": "workspace:*",
    "@atlas/lowcode-editor-canvas": "workspace:*",
    "@atlas/lowcode-editor-inspector": "workspace:*",
    "@atlas/lowcode-editor-outline": "workspace:*",
    "@atlas/lowcode-expression": "workspace:*",
    "@atlas/lowcode-property-forms": "workspace:*",
    "@atlas/lowcode-schema": "workspace:*",
    "@douyinfe/semi-icons": "^2.82.0",
    "@douyinfe/semi-ui": "^2.82.0",
    "@tanstack/react-query": "^5.59.20",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@rsbuild/core": "~1.1.0",
    "@rsbuild/plugin-react": "~1.1.0",
    "@types/react": "18.2.37",
    "@types/react-dom": "18.2.15",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
