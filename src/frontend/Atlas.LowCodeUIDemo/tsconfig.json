{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@atlas/lowcode-ui": ["../Atlas.LowCodeUI/dist/index.d.ts"],
      "@atlas/lowcode-ui/designer": ["../Atlas.LowCodeUI/dist/designer.d.ts"],
      "@atlas/lowcode-ui/renderer": ["../Atlas.LowCodeUI/dist/renderer.d.ts"],
      "@atlas/lowcode-ui/plugin": ["../Atlas.LowCodeUI/dist/plugin.d.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
