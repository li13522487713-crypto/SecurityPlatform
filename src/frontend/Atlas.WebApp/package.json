{
  "name": "atlas-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:platform-console": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --mode platform-console",
    "build:app-studio": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --mode app-studio",
    "build:app-runtime": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --mode app-runtime",
    "build:app-login": "node --max-old-space-size=8192 node_modules/vite/bin/vite.js build --mode app-login",
    "build:entries": "npm run build:platform-console && npm run build:app-studio && npm run build:app-runtime && npm run build:app-login",
    "build": "vue-tsc --noEmit && npm run build:entries",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write .",
    "check": "vue-tsc --noEmit && eslint . --ext .ts,.vue && node --max-old-space-size=8192 node_modules/vite/bin/vite.js build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "generate-types": "cd ../../backend/Atlas.WebApi && nswag run nswag.json && cd ../../frontend/Atlas.WebApp && node scripts/postprocess-api-generated.mjs",
    "generate-api": "npm run generate-types",
    "spell:check": "npx --yes cspell --config ../../cspell.json",
    "spell:check:files": "npx --yes cspell --config ../../cspell.json --no-progress --no-summary",
    "i18n:diff-runtime": "node scripts/i18n-runtime-key-diff.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {
    "@antv/x6": "^2.19.2",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-minimap": "^2.0.7",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-vue-shape": "^2.1.2",
    "@uppy/core": "^5.2.0",
    "@uppy/tus": "^5.1.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "amis": "^6.0.0",
    "ant-design-vue": "^4.2.6",
    "dompurify": "^3.3.3",
    "driver.js": "^1.4.0",
    "echarts": "^5.5.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.2.0",
    "screenfull": "^6.0.2",
    "vform3-builds": "^3.0.10",
    "vue": "^3.5.30",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "wavesurfer.js": "^7.12.4"
  },
  "overrides": {
    "@popperjs/core": "2.11.8"
  }
}
