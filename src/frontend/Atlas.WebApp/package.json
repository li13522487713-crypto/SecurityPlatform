{
  "name": "atlas-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && node --max-old-space-size=8192 node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write .",
    "generate-types": "cd ../../backend/Atlas.WebApi && nswag run nswag.json"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {
    "@antv/x6": "^2.18.1",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-vue-shape": "^2.0.8",
    "amis": "^6.0.0",
    "ant-design-vue": "^4.2.6",
    "driver.js": "^1.4.0",
    "element-plus": "^2.13.2",
    "mobx": "4.15.7",
    "mobx-react-lite": "2.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.2.0",
    "vform3-builds": "^3.0.10",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "overrides": {
    "@popperjs/core": "2.11.8",
    "element-plus": {
      "@popperjs/core": "2.11.8"
    }
  }
}
