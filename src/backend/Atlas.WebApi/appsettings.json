{
  "Jwt": {
    "Issuer": "Atlas.SecurityPlatform",
    "Audience": "Atlas.SecurityPlatform",
    "SigningKey": "Atlas@SecurityPlatform!DefaultKey#2025$",
    "ExpiresMinutes": 15,
    "RefreshExpiresMinutes": 720,
    "SessionExpiresMinutes": 720
  },
  "Security": {
    "EnforceHttps": true,
    "CaptchaThreshold": 3,
    "CaptchaExpirySeconds": 300,
    "PasswordPolicy": {
      "MinLength": 8,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireNonAlphanumeric": true,
      "ExpirationDays": 90
    },
    "LockoutPolicy": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15,
      "AutoUnlockMinutes": 30,
      "AllowManualUnlock": true
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "TenantId": "00000000-0000-0000-0000-000000000001",
      "Username": "admin",
      "Password": "",
      "Roles": "Admin",
      "IsPlatformAdmin": true
    }
  },
  "Idempotency": {
    "HeaderName": "Idempotency-Key",
    "RetentionHours": 24,
    "CleanupIntervalMinutes": 60,
    "MaxKeyLength": 128
  },
  "Database": {
    "ConnectionString": "Data Source=atlas.db",
    "Encryption": {
      "Enabled": true,
      "Key": "Atlas@DbEncrypt!SimulatedProd#2025$Key",
      "_comment": "模拟生产运行密钥。正式生产请改用环境变量 Database__Encryption__Key 注入。"
    },
    "Backup": {
      "Enabled": true,
      "BackupDirectory": "backups",
      "IntervalHours": 24,
      "RetentionDays": 30
    }
  },
  "Logging": {
    "RetentionDays": 180
  },
  "Snowflake": {
    "GeneratorId": 1
  },
  "IdGenerator": {
    "DefaultAppId": "SecurityPlatform",
    "Mappings": [
      {
        "TenantId": "00000000-0000-0000-0000-000000000001",
        "AppId": "SecurityPlatform",
        "GeneratorId": 1
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Xss": {
    "WhitelistPaths": [
      "/api/notifications",
      "/api/files"
    ],
    "MaxBodySizeBytes": 1048576
  },
  "FileStorage": {
    "BasePath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".xlsx", ".xls", ".docx", ".doc", ".txt", ".csv", ".zip"],
    "BlockedExtensions": [".exe", ".sh", ".bat", ".cmd", ".ps1", ".vbs", ".js", ".msi", ".dll", ".so"],
    "ChunkPartSizeBytes": 2097152,
    "ChunkSessionExpireMinutes": 120,
    "SignedUrlDefaultExpireSeconds": 600,
    "SignedUrlSecret": "Atlas@FileStorage!DefaultSignedKey#2025$"
  },
  "Tenancy": {
    "HeaderName": "X-Tenant-Id"
  },
  "Plugins": {
    "RootPath": "plugins"
  },
  "AiPlatform": {
    "DefaultProvider": "openai",
    "Providers": {
      "openai": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com",
        "DefaultModel": "gpt-4o-mini",
        "SupportsEmbedding": true
      },
      "deepseek": {
        "ApiKey": "",
        "BaseUrl": "https://api.deepseek.com",
        "DefaultModel": "deepseek-chat",
        "SupportsEmbedding": true
      },
      "ollama": {
        "ApiKey": "",
        "BaseUrl": "http://localhost:11434",
        "DefaultModel": "llama3",
        "SupportsEmbedding": false
      }
    },
    "Embedding": {
      "Provider": "openai",
      "Model": "text-embedding-3-small",
      "Dimensions": 1536
    }
  },
  "CodeExecution": {
    "Mode": "Direct",
    "TimeoutSeconds": 10,
    "MaxOutputLength": 8000,
    "BlockedModules": [
      "os",
      "subprocess",
      "sys"
    ]
  },
  "App": {
    "HeaderName": "X-App-Id",
    "DefaultAppId": "SecurityPlatform",
    "AllowHeaderOverrideWhenAuthenticated": true,
    "RequireWorkspaceHeaderForAuthenticatedOverride": true,
    "WorkspaceHeaderName": "X-App-Workspace",
    "WorkspaceHeaderValue": "1",
    "RequireHeaderAppIdNumeric": true,
    "ClientTypeMappings": [
      {
        "ClientType": "WebH5",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Mobile",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Backend",
        "AppId": "SecurityPlatform"
      }
    ]
  },
  "Approval": {
    "SeedData": {
      "Enabled": true,
      "InitializeButtonConfigs": true,
      "InitializeExampleFlows": false
    }
  },
  "TableViewDefaults": {
    "Fallback": {
      "density": "default",
      "pagination": {
        "pageSize": 10
      }
    },
    "Defaults": {
      "system.users": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.roles": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.permissions": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.menus": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.departments": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.positions": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.projects": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.apps": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      }
    }
  },
  "AllowedHosts": "*",
  "Oidc": {
    "Enabled": false,
    "Authority": "",
    "ClientId": "",
    "ClientSecret": "",
    "Scopes": ["openid", "profile", "email"],
    "CallbackPath": "/auth/oidc/callback",
    "RoleClaimMapping": {}
  },
  "Messaging": {
    "ApprovalEvents": {
      "AsyncEnabled": false
    }
  },
  "DatabaseInitializer": {
    "_comment": "控制启动时的数据库初始化行为。默认全部跳过（true）以加快启动速度。首次部署或升级数据库时，将对应项设为false后重启一次，完成后恢复true。",
    "SkipSchemaInit": true,
    "SkipSeedData": true,
    "SkipSchemaMigrations": true
  }
}
