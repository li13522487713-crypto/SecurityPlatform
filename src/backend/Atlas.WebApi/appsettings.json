{
  "Jwt": {
    "Issuer": "Atlas.SecurityPlatform",
    "Audience": "Atlas.SecurityPlatform",
    "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET",
    "ExpiresMinutes": 15,
    "RefreshExpiresMinutes": 720,
    "SessionExpiresMinutes": 720
  },
  "Security": {
    "EnforceHttps": true,
    "CaptchaThreshold": 3,
    "CaptchaExpirySeconds": 300,
    "PasswordPolicy": {
      "MinLength": 8,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireNonAlphanumeric": true,
      "ExpirationDays": 90
    },
    "LockoutPolicy": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15,
      "AutoUnlockMinutes": 30,
      "AllowManualUnlock": true
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "TenantId": "00000000-0000-0000-0000-000000000001",
      "Username": "admin",
      "Password": "",
      "Roles": "Admin"
    }
  },
  "Idempotency": {
    "HeaderName": "Idempotency-Key",
    "RetentionHours": 24,
    "CleanupIntervalMinutes": 60,
    "MaxKeyLength": 128
  },
  "Database": {
    "ConnectionString": "Data Source=atlas.db",
    "Encryption": {
      "Enabled": false,
      "Key": "",
      "_comment": "生产环境：设置Enabled=true，通过环境变量DATABASE_ENCRYPTION_KEY提供密钥。请勿在配置文件中硬编码密钥！"
    },
    "Backup": {
      "Enabled": true,
      "BackupDirectory": "backups",
      "IntervalHours": 24,
      "RetentionDays": 30
    }
  },
  "Logging": {
    "RetentionDays": 180
  },
  "Snowflake": {
    "GeneratorId": 1
  },
  "IdGenerator": {
    "DefaultAppId": "SecurityPlatform",
    "Mappings": [
      {
        "TenantId": "00000000-0000-0000-0000-000000000001",
        "AppId": "SecurityPlatform",
        "GeneratorId": 1
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Xss": {
    "WhitelistPaths": [
      "/api/notifications",
      "/api/files"
    ],
    "MaxBodySizeBytes": 1048576
  },
  "FileStorage": {
    "BasePath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".xlsx", ".xls", ".docx", ".doc", ".txt", ".csv", ".zip"],
    "BlockedExtensions": [".exe", ".sh", ".bat", ".cmd", ".ps1", ".vbs", ".js", ".msi", ".dll", ".so"]
  },
  "Tenancy": {
    "HeaderName": "X-Tenant-Id"
  },
  "Plugins": {
    "RootPath": "plugins"
  },
  "App": {
    "HeaderName": "X-App-Id",
    "DefaultAppId": "SecurityPlatform",
    "ClientTypeMappings": [
      {
        "ClientType": "WebH5",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Mobile",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Backend",
        "AppId": "SecurityPlatform"
      }
    ]
  },
  "Approval": {
    "SeedData": {
      "Enabled": true,
      "InitializeButtonConfigs": true,
      "InitializeExampleFlows": false
    }
  },
  "TableViewDefaults": {
    "Fallback": {
      "density": "default",
      "pagination": {
        "pageSize": 10
      }
    },
    "Defaults": {
      "system.users": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.roles": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.permissions": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.menus": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.departments": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.positions": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.projects": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      },
      "system.apps": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      }
    }
  },
  "AllowedHosts": "*"
}
