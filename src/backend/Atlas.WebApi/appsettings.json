{
  "Jwt": {
    "Issuer": "Atlas.SecurityPlatform",
    "Audience": "Atlas.SecurityPlatform",
    "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET",
    "ExpiresMinutes": 60
  },
  "Security": {
    "EnforceHttps": true,
    "PasswordPolicy": {
      "MinLength": 8,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireNonAlphanumeric": true,
      "ExpirationDays": 90
    },
    "LockoutPolicy": {
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15,
      "AutoUnlockMinutes": 30,
      "AllowManualUnlock": true
    },
    "BootstrapAdmin": {
      "Enabled": true,
      "TenantId": "00000000-0000-0000-0000-000000000001",
      "Username": "admin",
      "Password": "",
      "Roles": "Admin"
    }
  },
  "Database": {
    "ConnectionString": "Data Source=atlas.db",
    "Encryption": {
      "Enabled": false,
      "Key": ""
    },
    "Backup": {
      "Enabled": true,
      "BackupDirectory": "backups",
      "IntervalHours": 24,
      "RetentionDays": 30
    }
  },
  "Logging": {
    "RetentionDays": 180
  },
  "Snowflake": {
    "GeneratorId": 1
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Tenancy": {
    "HeaderName": "X-Tenant-Id"
  },
  "Approval": {
    "SeedData": {
      "Enabled": true,
      "InitializeButtonConfigs": true,
      "InitializeExampleFlows": false
    }
  },
  "AllowedHosts": "*"
}
