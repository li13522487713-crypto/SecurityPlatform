{
  "key": "system.departments",
  "title": "\u90e8\u95e8\u7ba1\u7406",
  "description": "AMIS \u8868\u5355\u7ba1\u7406\u90e8\u95e8\u7ed3\u6784\u4e0e\u6392\u5e8f",
  "tableKey": "system.departments",
  "schema": {
    "type": "page",
    "title": "\u90e8\u95e8\u7ba1\u7406",
    "body": [
      {
        "type": "crud",
        "name": "departments-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/departments?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "\u5173\u952e\u5b57",
            "placeholder": "\u540d\u79f0",
            "clearable": true
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "\u65b0\u589e\u90e8\u95e8",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "\u65b0\u589e\u90e8\u95e8",
              "body": {
                "type": "form",
                "api": {
                  "url": "/departments",
                  "method": "post",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u4fdd\u5b58\u5b8c\u6210', data: payload?.data };"
                },
                "body": [
                  {
                    "type": "input-text",
                    "name": "name",
                    "label": "\u540d\u79f0",
                    "required": true
                  },
                  {
                    "type": "select",
                    "name": "parentId",
                    "label": "\u4e0a\u7ea7\u90e8\u95e8",
                    "searchable": true,
                    "source": {
                      "url": "/departments/all",
                      "method": "get",
                      "adaptor": "const list = payload?.data ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                    },
                    "valueField": "id",
                    "labelField": "name"
                  },
                  {
                    "type": "input-number",
                    "name": "sortOrder",
                    "label": "\u6392\u5e8f",
                    "value": 0
                  }
                ],
                "name": "system-departments-dialog-form-1"
              },
              "actions": [
                {
                  "type": "button",
                  "label": "\u53d6\u6d88",
                  "actionType": "cancel"
                },
                {
                  "type": "button",
                  "label": "\u4fdd\u5b58",
                  "level": "primary",
                  "actionType": "submit",
                  "target": "system-departments-dialog-form-1"
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          {
            "name": "name",
            "label": "\u540d\u79f0"
          },
          {
            "name": "parentId",
            "label": "\u4e0a\u7ea7\u90e8\u95e8",
            "tpl": "<span>${parentId || '\u6839\u7ea7'}</span>"
          },
          {
            "name": "sortOrder",
            "label": "\u6392\u5e8f"
          },
          {
            "type": "operation",
            "label": "\u64cd\u4f5c",
            "buttons": [
              {
                "label": "\u7f16\u8f91",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u7f16\u8f91\u90e8\u95e8",
                  "body": {
                    "type": "form",
                    "api": {
                      "url": "/departments/${id}",
                      "method": "put",
                      "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u66f4\u65b0\u5b8c\u6210' };"
                    },
                    "body": [
                      {
                        "type": "input-text",
                        "name": "name",
                        "label": "\u540d\u79f0",
                        "required": true
                      },
                      {
                        "type": "select",
                        "name": "parentId",
                        "label": "\u4e0a\u7ea7\u90e8\u95e8",
                        "searchable": true,
                        "source": {
                          "url": "/departments/all",
                          "method": "get",
                          "adaptor": "const list = payload?.data ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                        },
                        "valueField": "id",
                        "labelField": "name"
                      },
                      {
                        "type": "input-number",
                        "name": "sortOrder",
                        "label": "\u6392\u5e8f",
                        "value": 0
                      }
                    ],
                    "name": "system-departments-dialog-form-2"
                  },
                  "actions": [
                    {
                      "type": "button",
                      "label": "\u53d6\u6d88",
                      "actionType": "cancel"
                    },
                    {
                      "type": "button",
                      "label": "\u4fdd\u5b58",
                      "level": "primary",
                      "actionType": "submit",
                      "target": "system-departments-dialog-form-2"
                    }
                  ]
                }
              },
              {
                "label": "\u5220\u9664",
                "level": "link",
                "actionType": "ajax",
                "confirmText": "\u786e\u8ba4\u5220\u9664\u8be5\u90e8\u95e8\uff1f",
                "api": {
                  "url": "/departments/${id}",
                  "method": "delete",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u5220\u9664\u5b8c\u6210' };"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
