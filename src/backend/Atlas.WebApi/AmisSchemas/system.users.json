    "title": "\u5458\u5de5\u7ba1\u7406",
    "body": [
      {
        "type": "crud",
        "name": "users-crud",
        "syncLocation": false,
        "api": {
          "url": "/users?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "perPage": 20,
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "placeholder": "\u7528\u6237\u540d/\u59d3\u540d/\u90ae\u7bb1",
            "clearable": true,
            "label": "\u5173\u952e\u5b57"
          }
        ],
