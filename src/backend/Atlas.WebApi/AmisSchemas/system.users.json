                    "label": "\u5bc6\u7801",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "displayName",
                    "label": "\u59d3\u540d",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "email",
                    "label": "\u90ae\u7bb1"
                  },
                  {
                    "type": "input-text",
                    "name": "phoneNumber",
                    "label": "\u624b\u673a\u53f7"
                  },
                  {
                    "type": "switch",
                    "name": "isActive",
                    "label": "\u542f\u7528",
                    "trueValue": true,
                    "falseValue": false
                  },
                  {
                    "type": "select",
                    "name": "roleIds",
                    "label": "\u89d2\u8272",
