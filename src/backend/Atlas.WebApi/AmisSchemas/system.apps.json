{
  "key": "system.apps",
  "title": "\u5e94\u7528\u914d\u7f6e",
  "description": "AMIS \u9875\u9762\u5c55\u793a\u5f53\u524d\u5e94\u7528\u5217\u8868\u4e0e\u53ef\u914d\u7f6e\u53c2\u6570",
  "tableKey": "system.apps",
  "schema": {
    "type": "page",
    "title": "\u5e94\u7528\u914d\u7f6e",
    "body": [
      {
        "type": "crud",
        "name": "apps-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/apps?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "\u5173\u952e\u5b57",
            "placeholder": "\u540d\u79f0/\u6807\u8bc6",
            "clearable": true
          }
        ],
        "headerToolbar": [
          "reload"
        ],
        "columns": [
          {
            "name": "appId",
            "label": "\u5e94\u7528\u6807\u8bc6"
          },
          {
            "name": "name",
            "label": "\u540d\u79f0"
          },
          {
            "name": "isActive",
            "label": "\u542f\u7528",
            "type": "tpl",
            "tpl": "<span>${isActive ? '\u662f' : '\u5426'}</span>"
          },
          {
            "name": "enableProjectScope",
            "label": "\u9879\u76ee\u6a21\u5f0f",
            "type": "tpl",
            "tpl": "<span>${enableProjectScope ? '\u5f00\u542f' : '\u5173\u95ed'}</span>"
          },
          {
            "name": "description",
            "label": "\u63cf\u8ff0",
            "tpl": "<span>${description || '-'}</span>"
          },
          {
            "name": "sortOrder",
            "label": "\u6392\u5e8f"
          },
          {
            "type": "operation",
            "label": "\u64cd\u4f5c",
            "buttons": [
              {
                "label": "\u7f16\u8f91",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u7f16\u8f91\u5e94\u7528",
                  "body": {
                    "type": "form",
                    "api": {
                      "url": "/apps/${id}",
                      "method": "put",
                      "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u66f4\u65b0\u5b8c\u6210', data: payload?.data };"
                    },
                    "body": [
                      {
                        "type": "input-text",
                        "name": "appId",
                        "label": "\u5e94\u7528\u6807\u8bc6",
                        "disabled": true
                      },
                      {
                        "type": "input-text",
                        "name": "name",
                        "label": "\u540d\u79f0",
                        "required": true
                      },
                      {
                        "type": "textarea",
                        "name": "description",
                        "label": "\u63cf\u8ff0",
                        "rows": 3
                      },
                      {
                        "type": "switch",
                        "name": "isActive",
                        "label": "\u542f\u7528",
                        "trueValue": true,
                        "falseValue": false
                      },
                      {
                        "type": "switch",
                        "name": "enableProjectScope",
                        "label": "\u9879\u76ee\u6a21\u5f0f",
                        "trueValue": true,
                        "falseValue": false
                      },
                      {
                        "type": "input-number",
                        "name": "sortOrder",
                        "label": "\u6392\u5e8f",
                        "value": 0
                      }
                    ],
                    "initApi": "/apps/${id}",
                    "name": "system-apps-dialog-form-1"
                  },
                  "actions": [
                    {
                      "type": "button",
                      "label": "\u53d6\u6d88",
                      "actionType": "cancel"
                    },
                    {
                      "type": "button",
                      "label": "\u4fdd\u5b58",
                      "level": "primary",
                      "actionType": "submit",
                      "target": "system-apps-dialog-form-1"
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
