{
  "key": "system.menus",
  "title": "\u83dc\u5355\u7ba1\u7406",
  "description": "\u901a\u8fc7 AMIS \u7f16\u8f91\u83dc\u5355\u6811\u3001\u6388\u6743\u7801\u53ca\u5c42\u7ea7",
  "tableKey": "system.menus",
  "schema": {
    "type": "page",
    "title": "\u83dc\u5355\u7ba1\u7406",
    "body": [
      {
        "type": "crud",
        "name": "menus-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/menus?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}&isHidden=${isHidden}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "\u5173\u952e\u5b57",
            "placeholder": "\u540d\u79f0/\u8def\u5f84",
            "clearable": true
          },
          {
            "type": "select",
            "name": "isHidden",
            "label": "\u662f\u5426\u9690\u85cf",
            "options": [
              {
                "label": "\u5168\u90e8",
                "value": ""
              },
              {
                "label": "\u663e\u793a",
                "value": "false"
              },
              {
                "label": "\u9690\u85cf",
                "value": "true"
              }
            ]
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "\u65b0\u589e\u83dc\u5355",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "\u65b0\u589e\u83dc\u5355",
              "size": "lg",
              "body": {
                "type": "form",
                "api": {
                  "url": "/menus",
                  "method": "post",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u4fdd\u5b58\u5b8c\u6210', data: payload?.data };"
                },
                "body": [
                  {
                    "type": "input-text",
                    "name": "name",
                    "label": "\u540d\u79f0",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "path",
                    "label": "\u8def\u5f84"
                  },
                  {
                    "type": "select",
                    "name": "parentId",
                    "label": "\u4e0a\u7ea7\u83dc\u5355",
                    "searchable": true,
                    "source": {
                      "url": "/menus/all",
                      "method": "get",
                      "adaptor": "const list = payload?.data ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                    },
                    "valueField": "id",
                    "labelField": "name"
                  },
                  {
                    "type": "input-text",
                    "name": "component",
                    "label": "\u7ec4\u4ef6"
                  },
                  {
                    "type": "input-text",
                    "name": "icon",
                    "label": "\u56fe\u6807"
                  },
                  {
                    "type": "input-text",
                    "name": "permissionCode",
                    "label": "\u6743\u9650\u7801"
                  },
                  {
                    "type": "switch",
                    "name": "isHidden",
                    "label": "\u9690\u85cf",
                    "trueValue": true,
                    "falseValue": false
                  },
                  {
                    "type": "input-number",
                    "name": "sortOrder",
                    "label": "\u6392\u5e8f",
                    "value": 0
                  }
                ],
                "name": "system-menus-dialog-form-1"
              },
              "actions": [
                {
                  "type": "button",
                  "label": "\u53d6\u6d88",
                  "actionType": "cancel"
                },
                {
                  "type": "button",
                  "label": "\u4fdd\u5b58",
                  "level": "primary",
                  "actionType": "submit",
                  "target": "system-menus-dialog-form-1"
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          {
            "name": "name",
            "label": "\u540d\u79f0"
          },
          {
            "name": "path",
            "label": "\u8def\u5f84"
          },
          {
            "name": "permissionCode",
            "label": "\u6743\u9650\u7801"
          },
          {
            "name": "isHidden",
            "label": "\u9690\u85cf",
            "type": "tpl",
            "tpl": "<span>${isHidden ? '\u662f' : '\u5426'}</span>"
          },
          {
            "name": "sortOrder",
            "label": "\u987a\u5e8f"
          },
          {
            "type": "operation",
            "label": "\u64cd\u4f5c",
            "buttons": [
              {
                "label": "\u7f16\u8f91",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u7f16\u8f91\u83dc\u5355",
                  "body": {
                    "type": "form",
                    "api": {
                      "url": "/menus/${id}",
                      "method": "put",
                      "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u66f4\u65b0\u5b8c\u6210' };"
                    },
                    "body": [
                      {
                        "type": "input-text",
                        "name": "name",
                        "label": "\u540d\u79f0",
                        "required": true
                      },
                      {
                        "type": "input-text",
                        "name": "path",
                        "label": "\u8def\u5f84"
                      },
                      {
                        "type": "select",
                        "name": "parentId",
                        "label": "\u4e0a\u7ea7\u83dc\u5355",
                        "searchable": true,
                        "source": {
                          "url": "/menus/all",
                          "method": "get",
                          "adaptor": "const list = payload?.data ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                        },
                        "valueField": "id",
                        "labelField": "name"
                      },
                      {
                        "type": "input-text",
                        "name": "component",
                        "label": "\u7ec4\u4ef6"
                      },
                      {
                        "type": "input-text",
                        "name": "icon",
                        "label": "\u56fe\u6807"
                      },
                      {
                        "type": "input-text",
                        "name": "permissionCode",
                        "label": "\u6743\u9650\u7801"
                      },
                      {
                        "type": "switch",
                        "name": "isHidden",
                        "label": "\u9690\u85cf",
                        "trueValue": true,
                        "falseValue": false
                      },
                      {
                        "type": "input-number",
                        "name": "sortOrder",
                        "label": "\u6392\u5e8f",
                        "value": 0
                      }
                    ],
                    "name": "system-menus-dialog-form-2"
                  },
                  "actions": [
                    {
                      "type": "button",
                      "label": "\u53d6\u6d88",
                      "actionType": "cancel"
                    },
                    {
                      "type": "button",
                      "label": "\u4fdd\u5b58",
                      "level": "primary",
                      "actionType": "submit",
                      "target": "system-menus-dialog-form-2"
                    }
                  ]
                }
              },
              {
                "label": "\u63d0\u793a",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u8bf4\u660e",
                  "body": "\u5f53\u524d\u7248\u672c\u672a\u5f00\u653e\u83dc\u5355\u5220\u9664\u63a5\u53e3\uff0c\u5982\u9700\u5220\u9664\u8bf7\u8d70\u914d\u7f6e\u6d41\u7a0b\u3002"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
