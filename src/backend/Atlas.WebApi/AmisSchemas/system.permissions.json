{
  "key": "system.permissions",
  "title": "\u6743\u9650\u7ba1\u7406",
  "description": "\u901a\u8fc7 AMIS \u7ba1\u7406\u63a5\u53e3\u5c42\u6743\u9650\u7801",
  "tableKey": "system.permissions",
  "schema": {
    "type": "page",
    "title": "\u6743\u9650\u7ba1\u7406",
    "body": [
      {
        "type": "crud",
        "name": "permissions-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/permissions?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}&type=${type}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "\u5173\u952e\u5b57",
            "placeholder": "\u540d\u79f0/\u7f16\u7801",
            "clearable": true
          },
          {
            "type": "select",
            "name": "type",
            "label": "\u7c7b\u578b",
            "options": [
              {
                "label": "\u5168\u90e8",
                "value": ""
              },
              {
                "label": "API",
                "value": "Api"
              },
              {
                "label": "\u83dc\u5355",
                "value": "Menu"
              }
            ]
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "\u65b0\u589e\u6743\u9650",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "\u65b0\u589e\u6743\u9650",
              "body": {
                "type": "form",
                "api": {
                  "url": "/permissions",
                  "method": "post",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u64cd\u4f5c\u5b8c\u6210', data: payload?.data };"
                },
                "body": [
                  {
                    "type": "input-text",
                    "name": "name",
                    "label": "\u540d\u79f0",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "code",
                    "label": "\u7f16\u7801",
                    "required": true
                  },
                  {
                    "type": "select",
                    "name": "type",
                    "label": "\u7c7b\u578b",
                    "options": [
                      {
                        "label": "API",
                        "value": "Api"
                      },
                      {
                        "label": "\u83dc\u5355",
                        "value": "Menu"
                      }
                    ],
                    "required": true
                  },
                  {
                    "type": "textarea",
                    "name": "description",
                    "label": "\u63cf\u8ff0",
                    "rows": 3
                  }
                ],
                "name": "system-permissions-dialog-form-1"
              },
              "actions": [
                {
                  "type": "button",
                  "label": "\u53d6\u6d88",
                  "actionType": "cancel"
                },
                {
                  "type": "button",
                  "label": "\u4fdd\u5b58",
                  "level": "primary",
                  "actionType": "submit",
                  "target": "system-permissions-dialog-form-1"
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          {
            "name": "name",
            "label": "\u540d\u79f0"
          },
          {
            "name": "code",
            "label": "\u7f16\u7801"
          },
          {
            "name": "type",
            "label": "\u7c7b\u578b"
          },
          {
            "name": "description",
            "label": "\u63cf\u8ff0",
            "tpl": "<span>${description || '-'}</span>"
          },
          {
            "type": "operation",
            "label": "\u64cd\u4f5c",
            "buttons": [
              {
                "label": "\u7f16\u8f91",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u7f16\u8f91\u6743\u9650",
                  "body": {
                    "type": "form",
                    "api": {
                      "url": "/permissions/${id}",
                      "method": "put",
                      "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u66f4\u65b0\u5b8c\u6210' };"
                    },
                    "body": [
                      {
                        "type": "input-text",
                        "name": "name",
                        "label": "\u540d\u79f0",
                        "required": true
                      },
                      {
                        "type": "input-text",
                        "name": "code",
                        "label": "\u7f16\u7801",
                        "disabled": true
                      },
                      {
                        "type": "select",
                        "name": "type",
                        "label": "\u7c7b\u578b",
                        "options": [
                          {
                            "label": "API",
                            "value": "Api"
                          },
                          {
                            "label": "\u83dc\u5355",
                            "value": "Menu"
                          }
                        ],
                        "required": true
                      },
                      {
                        "type": "textarea",
                        "name": "description",
                        "label": "\u63cf\u8ff0",
                        "rows": 3
                      }
                    ],
                    "initApi": "/permissions/${id}",
                    "name": "system-permissions-dialog-form-2"
                  },
                  "actions": [
                    {
                      "type": "button",
                      "label": "\u53d6\u6d88",
                      "actionType": "cancel"
                    },
                    {
                      "type": "button",
                      "label": "\u4fdd\u5b58",
                      "level": "primary",
                      "actionType": "submit",
                      "target": "system-permissions-dialog-form-2"
                    }
                  ]
                }
              },
              {
                "label": "\u63d0\u793a",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u8bf4\u660e",
                  "body": "\u5f53\u524d\u7248\u672c\u672a\u5f00\u653e\u6743\u9650\u5220\u9664\u63a5\u53e3\uff0c\u5982\u9700\u5220\u9664\u8bf7\u8d70\u914d\u7f6e\u6d41\u7a0b\u3002"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
