<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <variable name="logLayout" value="${longdate}|${level:uppercase=true}|trace=${aspnet-traceidentifier}|activity=${activityid}|${logger}|${message} ${exception:format=toString}" />
  <targets>
    <target xsi:type="File" name="allFile"
            fileName="logs/all.log"
            archiveFileName="logs/archive/all.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="${configsetting:item=Logging:RetentionDays}"
            concurrentWrites="true"
            keepFileOpen="false"
            layout="${var:logLayout}" />

    <target xsi:type="File" name="infoFile"
            fileName="logs/info.log"
            archiveFileName="logs/archive/info.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="${configsetting:item=Logging:RetentionDays}"
            concurrentWrites="true"
            keepFileOpen="false"
            layout="${var:logLayout}" />

    <target xsi:type="File" name="warnFile"
            fileName="logs/warn.log"
            archiveFileName="logs/archive/warn.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="${configsetting:item=Logging:RetentionDays}"
            concurrentWrites="true"
            keepFileOpen="false"
            layout="${var:logLayout}" />

    <target xsi:type="File" name="errorFile"
            fileName="logs/error.log"
            archiveFileName="logs/archive/error.{#}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="${configsetting:item=Logging:RetentionDays}"
            concurrentWrites="true"
            keepFileOpen="false"
            layout="${var:logLayout}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Trace" writeTo="allFile" />
    <logger name="*" minlevel="Info" maxlevel="Info" writeTo="infoFile" />
    <logger name="*" minlevel="Warn" maxlevel="Warn" writeTo="warnFile" />
    <logger name="*" minlevel="Error" writeTo="errorFile" />
  </rules>
</nlog>
