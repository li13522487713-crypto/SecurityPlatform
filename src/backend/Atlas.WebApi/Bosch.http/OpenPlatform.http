@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@agentId = 1
@workflowId = 1
@knowledgeBaseId = 1
@fileId = 1

### 1) 登录获取 JWT
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 2) 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 3) 创建 PAT（仅返回一次明文）
# @name createPat
POST {{baseUrl}}/api/v1/personal-access-tokens
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "Open Platform PAT",
  "scopes": ["open:*"],
  "expiresAt": null
}

###
@patToken = {{createPat.response.body.$.data.plainTextToken}}

### 4) Open Bots 列表
GET {{baseUrl}}/api/v1/open/bots?PageIndex=1&PageSize=20
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}

### 5) Open Chat（同步）
POST {{baseUrl}}/api/v1/open/chat/completions
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "agentId": {{agentId}},
  "message": "你好，请介绍一下你能做什么。",
  "conversationId": null,
  "enableRag": false
}

### 6) Open Chat（SSE）
POST {{baseUrl}}/api/v1/open/chat/stream
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "agentId": {{agentId}},
  "message": "请用三点总结安全平台价值。",
  "conversationId": null,
  "enableRag": false
}

### 6.1) Open Chat（SSE-ReAct 结构化事件）
POST {{baseUrl}}/api/v1/open/chat/stream?eventMode=react
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
X-Stream-Event-Mode: react

{
  "agentId": {{agentId}},
  "message": "请展示工具调用过程。",
  "conversationId": null,
  "enableRag": false
}

### 7) Open Knowledge 列表
GET {{baseUrl}}/api/v1/open/knowledge/bases?PageIndex=1&PageSize=20
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}

### 8) Open Knowledge 文档列表
GET {{baseUrl}}/api/v1/open/knowledge/bases/{{knowledgeBaseId}}/documents?PageIndex=1&PageSize=20
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}

### 9) Open Workflow 运行
# @name runWorkflow
POST {{baseUrl}}/api/v1/open/workflows/{{workflowId}}/run
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "inputs": {
    "question": "hello"
  }
}

###
@executionId = {{runWorkflow.response.body.$.data.executionId}}

### 10) Open Workflow 进度
GET {{baseUrl}}/api/v1/open/workflows/executions/{{executionId}}
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}

### 11) Open Workflow 节点历史
GET {{baseUrl}}/api/v1/open/workflows/executions/{{executionId}}/history
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}

### 12) Open File 元数据
GET {{baseUrl}}/api/v1/open/files/{{fileId}}/info
Authorization: Bearer {{patToken}}
X-Tenant-Id: {{tenantId}}
