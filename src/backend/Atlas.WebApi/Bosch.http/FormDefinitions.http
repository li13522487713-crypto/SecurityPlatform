### FormDefinitions 表单定义管理测试
### 低代码平台 - 动态表单设计和管理

@baseUrl = http://localhost:5000/api/v1
@tenantId = 00000000-0000-0000-0000-000000000001

### 登录获取令牌
# @name login
POST {{baseUrl}}/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

@accessToken = {{login.response.body.$.data.accessToken}}

###############################################
# 表单定义 CRUD 操作
###############################################

### 1. 创建表单定义
# @name createForm
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "员工信息登记表",
  "description": "用于新员工入职信息收集",
  "category": "人力资源",
  "icon": "user-add",
  "dataTableKey": "employee_info",
  "schemaJson": {
    "type": "page",
    "title": "员工信息登记",
    "body": [
      {
        "type": "form",
        "api": "/api/v1/forms/${formId}/data",
        "body": [
          {
            "type": "input-text",
            "name": "name",
            "label": "姓名",
            "required": true
          },
          {
            "type": "input-email",
            "name": "email",
            "label": "邮箱",
            "required": true
          },
          {
            "type": "input-text",
            "name": "phone",
            "label": "手机号",
            "required": true
          },
          {
            "type": "select",
            "name": "department",
            "label": "部门",
            "options": [
              {"label": "技术部", "value": "tech"},
              {"label": "市场部", "value": "marketing"},
              {"label": "人力资源", "value": "hr"}
            ]
          }
        ]
      }
    ]
  }
}

@formId = {{createForm.response.body.$.data.id}}

### 2. 获取表单列表（分页）
GET {{baseUrl}}/form-definitions?pageIndex=1&pageSize=10&keyword=&category=
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 3. 按分类过滤表单
GET {{baseUrl}}/form-definitions?pageIndex=1&pageSize=10&category=人力资源
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 4. 搜索表单（关键词）
GET {{baseUrl}}/form-definitions?pageIndex=1&pageSize=10&keyword=员工
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 5. 获取表单详情
GET {{baseUrl}}/form-definitions/{{formId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 6. 更新表单定义
PUT {{baseUrl}}/form-definitions/{{formId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "员工信息登记表（完整版）",
  "description": "用于新员工入职信息收集 - 包含更多字段",
  "category": "人力资源",
  "icon": "user-add",
  "dataTableKey": "employee_info",
  "schemaJson": {
    "type": "page",
    "title": "员工信息登记",
    "body": [
      {
        "type": "form",
        "api": "/api/v1/forms/${formId}/data",
        "body": [
          {
            "type": "input-text",
            "name": "name",
            "label": "姓名",
            "required": true
          },
          {
            "type": "input-email",
            "name": "email",
            "label": "邮箱",
            "required": true
          },
          {
            "type": "input-text",
            "name": "phone",
            "label": "手机号",
            "required": true
          },
          {
            "type": "select",
            "name": "department",
            "label": "部门",
            "required": true,
            "options": [
              {"label": "技术部", "value": "tech"},
              {"label": "市场部", "value": "marketing"},
              {"label": "人力资源", "value": "hr"}
            ]
          },
          {
            "type": "input-date",
            "name": "joinDate",
            "label": "入职日期",
            "required": true
          }
        ]
      }
    ]
  }
}

### 7. 仅更新Schema（部分更新）
PATCH {{baseUrl}}/form-definitions/{{formId}}/schema
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "schemaJson": {
    "type": "page",
    "title": "员工信息登记（简化版）",
    "body": [
      {
        "type": "form",
        "api": "/api/v1/forms/${formId}/data",
        "body": [
          {
            "type": "input-text",
            "name": "name",
            "label": "姓名",
            "required": true
          },
          {
            "type": "input-email",
            "name": "email",
            "label": "邮箱",
            "required": true
          }
        ]
      }
    ]
  }
}

###############################################
# 表单状态管理
###############################################

### 8. 发布表单
POST {{baseUrl}}/form-definitions/{{formId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 9. 禁用表单
POST {{baseUrl}}/form-definitions/{{formId}}/disable
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 10. 启用表单
POST {{baseUrl}}/form-definitions/{{formId}}/enable
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 11. 删除表单
DELETE {{baseUrl}}/form-definitions/{{formId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###############################################
# 批量操作测试
###############################################

### 12. 创建多个表单（用于测试列表）
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "客户反馈表",
  "description": "收集客户意见和建议",
  "category": "客户服务",
  "icon": "feedback",
  "schemaJson": {
    "type": "form",
    "body": [
      {
        "type": "input-text",
        "name": "customerName",
        "label": "客户姓名"
      },
      {
        "type": "textarea",
        "name": "feedback",
        "label": "反馈内容",
        "required": true
      }
    ]
  }
}

### 13. 创建第三个表单
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "设备报修单",
  "description": "IT设备故障报修",
  "category": "IT支持",
  "icon": "tool",
  "schemaJson": {
    "type": "form",
    "body": [
      {
        "type": "input-text",
        "name": "deviceName",
        "label": "设备名称",
        "required": true
      },
      {
        "type": "select",
        "name": "issueType",
        "label": "故障类型",
        "options": [
          {"label": "硬件故障", "value": "hardware"},
          {"label": "软件故障", "value": "software"},
          {"label": "网络问题", "value": "network"}
        ]
      },
      {
        "type": "textarea",
        "name": "description",
        "label": "故障描述",
        "required": true
      }
    ]
  }
}

### 14. 获取所有表单（验证总数）
GET {{baseUrl}}/form-definitions?pageIndex=1&pageSize=100
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###############################################
# 错误场景测试
###############################################

### 15. 创建表单 - 缺少必填字段（应该失败）
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": ""
}

### 16. 创建表单 - SchemaJson为空（应该失败）
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "测试表单",
  "schemaJson": null
}

### 17. 获取不存在的表单（应该返回404）
GET {{baseUrl}}/form-definitions/99999
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 18. 更新不存在的表单（应该返回404）
PUT {{baseUrl}}/form-definitions/99999
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "不存在的表单",
  "schemaJson": {}
}

### 19. 未授权访问（应该返回401）
GET {{baseUrl}}/form-definitions
X-Tenant-Id: {{tenantId}}

###############################################
# 版本控制测试
###############################################

### 20. 创建表单并记录版本号
# @name versionTest
POST {{baseUrl}}/form-definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "版本测试表单",
  "schemaJson": {
    "type": "form",
    "body": [
      {
        "type": "input-text",
        "name": "field1",
        "label": "字段1"
      }
    ]
  }
}

@versionFormId = {{versionTest.response.body.$.data.id}}
@initialVersion = {{versionTest.response.body.$.data.version}}

### 21. 更新表单（版本号应增加）
PUT {{baseUrl}}/form-definitions/{{versionFormId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "版本测试表单 v2",
  "schemaJson": {
    "type": "form",
    "body": [
      {
        "type": "input-text",
        "name": "field1",
        "label": "字段1"
      },
      {
        "type": "input-text",
        "name": "field2",
        "label": "字段2"
      }
    ]
  }
}

### 22. 获取详情验证版本号
GET {{baseUrl}}/form-definitions/{{versionFormId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###############################################
# 完整测试流程总结
###############################################

# 场景1：表单设计与发布流程
# 1. 创建表单 → 2. 编辑Schema → 3. 预览 → 4. 发布

# 场景2：表单管理流程
# 1. 查看列表 → 2. 按分类筛选 → 3. 搜索 → 4. 查看详情 → 5. 编辑 → 6. 禁用/启用

# 场景3：表单生命周期
# Draft（草稿） → Published（已发布） → Disabled（已禁用） → Archived（已归档） → Deleted（已删除）
