@baseUrl = http://localhost:5000
@token =
@tenantId =
@idempotencyKey = {{$guid}}
@csrfToken =

### 获取 CSRF Token（执行写接口前先调用）
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 获取我的待办任务（需要权限: approval:flow:view）
GET {{baseUrl}}/api/v1/approval/tasks/my?pageIndex=1&pageSize=10&status=Pending
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 获取任务详情
GET {{baseUrl}}/api/v1/approval/tasks/{taskId}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 获取实例内的所有任务（需要权限: approval:flow:view）
GET {{baseUrl}}/api/v1/approval/instances/{instanceId}/tasks?pageIndex=1&pageSize=10
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 同意审批任务
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{idempotencyKey}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "taskId": "{taskId}",
  "approved": true,
  "comment": "同意，符合请假规范"
}

### 安全负例：缺少 Idempotency-Key（应返回 400）
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
X-CSRF-TOKEN: {{csrfToken}}

{
  "taskId": "{taskId}",
  "approved": true,
  "comment": "缺幂等键"
}

### 安全负例：缺少 X-CSRF-TOKEN（应返回 403）
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}

{
  "taskId": "{taskId}",
  "approved": true,
  "comment": "缺 CSRF"
}

### 安全负例：幂等冲突（同 key 不同 payload，第二次应返回 409）
@idemConflictTaskDecision = decision-conflict-001
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{idemConflictTaskDecision}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "taskId": "{taskId}",
  "approved": true,
  "comment": "冲突测试-A"
}

###
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{idemConflictTaskDecision}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "taskId": "{taskId}",
  "approved": false,
  "comment": "冲突测试-B"
}

### 驳回审批任务
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/decision
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "taskId": "{taskId}",
  "approved": false,
  "comment": "不同意，请假天数过长"
}

### 委派任务
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/delegation?delegateeUserId={userId}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

"委派处理说明"

### 认领任务（任务池）
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/claim
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 催办任务
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/urge
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

"请尽快处理此审批任务"

### 发起沟通
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/communication?recipientUserId={recipientUserId}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

"需要和您沟通一下关于这个审批的情况"

### 安全负例：XSS payload（应被服务端净化并落审计）
POST {{baseUrl}}/api/v1/approval/tasks/{taskId}/communication?recipientUserId={recipientUserId}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

"<script>alert('xss')</script>请尽快沟通"

### 获取沟通记录
GET {{baseUrl}}/api/v1/approval/tasks/{taskId}/communications
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 获取任务池（待认领任务）
GET {{baseUrl}}/api/v1/approval/tasks/pool?pageIndex=1&pageSize=10
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 批量转办（管理员操作）
POST {{baseUrl}}/api/v1/approval/tasks/batch-transfer?fromUserId={fromUserId}&toUserId={toUserId}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
