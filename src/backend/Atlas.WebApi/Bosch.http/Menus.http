@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Menus (Paged)
GET {{baseUrl}}/api/v1/menus?pageIndex=1&pageSize=10&isHidden=false
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Menus (All)
GET {{baseUrl}}/api/v1/menus/all
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create Menu
POST {{baseUrl}}/api/v1/menus
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "name": "System",
  "path": "/system",
  "parentId": null,
  "sortOrder": 0,
  "component": "Layout",
  "icon": "settings",
  "permissionCode": "system:admin",
  "isHidden": false
}

### Update Menu
PUT {{baseUrl}}/api/v1/menus/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "name": "System",
  "path": "/system",
  "parentId": null,
  "sortOrder": 0,
  "component": "Layout",
  "icon": "settings",
  "permissionCode": "system:admin",
  "isHidden": false
}
