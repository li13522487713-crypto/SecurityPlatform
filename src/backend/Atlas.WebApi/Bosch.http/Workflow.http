@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get all workflow definitions
GET {{baseUrl}}/api/v1/workflows/definitions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get specific workflow definition (latest version)
GET {{baseUrl}}/api/v1/workflows/definitions/my-workflow
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get specific workflow definition (specific version)
GET {{baseUrl}}/api/v1/workflows/definitions/my-workflow?version=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Start a workflow instance
# @name startWorkflow
POST {{baseUrl}}/api/v1/workflows/instances
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "workflowId": "my-workflow",
  "version": 1,
  "data": {
    "message": "Hello from workflow!"
  },
  "reference": "test-ref-001"
}

###
@instanceId = {{startWorkflow.response.body.$.data.instanceId}}

### Get workflow instance details
GET {{baseUrl}}/api/v1/workflows/instances/{{instanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get workflow instances (paged)
GET {{baseUrl}}/api/v1/workflows/instances?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Suspend workflow instance
POST {{baseUrl}}/api/v1/workflows/instances/{{instanceId}}/suspend
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Resume workflow instance
POST {{baseUrl}}/api/v1/workflows/instances/{{instanceId}}/resume
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Terminate workflow instance
POST {{baseUrl}}/api/v1/workflows/instances/{{instanceId}}/terminate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Publish external event
POST {{baseUrl}}/api/v1/workflows/events
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "eventName": "MyEvent",
  "eventKey": "event-key-001",
  "eventData": {
    "status": "approved"
  }
}

### Get available step types
GET {{baseUrl}}/api/v1/workflows/step-types
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Register dynamic workflow from JSON (DSL v1 format)
# @name registerDynamic
POST {{baseUrl}}/api/v1/workflows/definitions
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "workflowId": "test-dynamic-workflow",
  "version": 1,
  "definitionJson": "{ \"Id\": \"test-dynamic-workflow\", \"Version\": 1, \"Steps\": [ { \"Id\": \"step1\", \"Name\": \"延迟5秒\", \"StepType\": \"Delay\", \"Inputs\": { \"Period\": \"00:00:05\" }, \"NextStepId\": \"step2\" }, { \"Id\": \"step2\", \"Name\": \"完成\" } ] }"
}

### Start the dynamic workflow
# @name startDynamic
POST {{baseUrl}}/api/v1/workflows/instances
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "workflowId": "test-dynamic-workflow",
  "version": 1,
  "data": {},
  "reference": "dynamic-test-001"
}

###
@dynamicInstanceId = {{startDynamic.response.body.$.data.instanceId}}

### Get execution pointers for the dynamic workflow
GET {{baseUrl}}/api/v1/workflows/instances/{{dynamicInstanceId}}/pointers
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

