@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### Get CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Get Users (Paged)
GET {{baseUrl}}/api/v1/users?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get User Detail
GET {{baseUrl}}/api/v1/users/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create User
POST {{baseUrl}}/api/v1/users
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "username": "demo",
  "password": "P@ssw0rd!",
  "displayName": "Demo User",
  "email": "demo@example.com",
  "phoneNumber": "13800000000",
  "isActive": true,
  "roleIds": [],
  "departmentIds": []
}

### Update User
PUT {{baseUrl}}/api/v1/users/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "displayName": "Demo User",
  "email": "demo@example.com",
  "phoneNumber": "13800000000",
  "isActive": true
}

### Update User Roles
PUT {{baseUrl}}/api/v1/users/1/roles
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "roleIds": []
}

### Update User Departments
PUT {{baseUrl}}/api/v1/users/1/departments
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "departmentIds": []
}

### Update User Positions
PUT {{baseUrl}}/api/v1/users/1/positions
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "positionIds": []
}

### Delete User
DELETE {{baseUrl}}/api/v1/users/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

