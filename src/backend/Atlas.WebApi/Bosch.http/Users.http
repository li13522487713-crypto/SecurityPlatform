@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Users (Paged)
GET {{baseUrl}}/users?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get User Detail
GET {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create User
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "username": "demo",
  "password": "P@ssw0rd!",
  "displayName": "Demo User",
  "email": "demo@example.com",
  "phoneNumber": "13800000000",
  "isActive": true,
  "roleIds": [],
  "departmentIds": []
}

### Update User
PUT {{baseUrl}}/users/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "displayName": "Demo User",
  "email": "demo@example.com",
  "phoneNumber": "13800000000",
  "isActive": true
}

### Update User Roles
PUT {{baseUrl}}/users/1/roles
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "roleIds": []
}

### Update User Departments
PUT {{baseUrl}}/users/1/departments
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "departmentIds": []
}

### Update User Positions
PUT {{baseUrl}}/users/1/positions
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "positionIds": []
}

### Delete User
DELETE {{baseUrl}}/users/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
