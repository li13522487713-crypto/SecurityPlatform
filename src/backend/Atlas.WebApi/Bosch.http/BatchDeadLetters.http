@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@clientType = WebH5
@clientPlatform = Web
@clientChannel = Browser
@clientAgent = Chrome
@localeZh = zh-CN

### Login
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}
Accept-Language: {{localeZh}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### List Dead Letters (All)
GET {{baseUrl}}/api/v1/batch-dead-letters?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Accept-Language: {{localeZh}}

### List Dead Letters by Job Execution
GET {{baseUrl}}/api/v1/batch-dead-letters?pageIndex=1&pageSize=10&jobExecutionId=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Accept-Language: {{localeZh}}

### List Dead Letters by Status (Pending)
GET {{baseUrl}}/api/v1/batch-dead-letters?pageIndex=1&pageSize=10&status=0
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Accept-Language: {{localeZh}}

### Get Dead Letter Detail
GET {{baseUrl}}/api/v1/batch-dead-letters/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Accept-Language: {{localeZh}}

### Retry Single Dead Letter
POST {{baseUrl}}/api/v1/batch-dead-letters/1/retry
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Accept-Language: {{localeZh}}

### Retry Batch Dead Letters
POST {{baseUrl}}/api/v1/batch-dead-letters/batch-retry
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Accept-Language: {{localeZh}}

{
  "ids": [1, 2, 3]
}

### Abandon Single Dead Letter
POST {{baseUrl}}/api/v1/batch-dead-letters/1/abandon
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Accept-Language: {{localeZh}}

### Abandon Batch Dead Letters
POST {{baseUrl}}/api/v1/batch-dead-letters/batch-abandon
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Accept-Language: {{localeZh}}

{
  "ids": [1, 2, 3]
}
