@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### Get CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Get Positions (Paged)
GET {{baseUrl}}/api/v1/positions?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Positions (All)
GET {{baseUrl}}/api/v1/positions/all
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Position Detail
GET {{baseUrl}}/api/v1/positions/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create Position
POST {{baseUrl}}/api/v1/positions
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "工程师",
  "code": "Engineer",
  "description": "技术岗位",
  "isActive": true,
  "sortOrder": 0
}

### Update Position
PUT {{baseUrl}}/api/v1/positions/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "高级工程师",
  "description": "技术岗位",
  "isActive": true,
  "sortOrder": 1
}

### Delete Position
DELETE {{baseUrl}}/api/v1/positions/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

