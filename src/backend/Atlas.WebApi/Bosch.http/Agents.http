@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@agentId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Agent 分页
GET {{baseUrl}}/api/v1/agents?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建 Agent
POST {{baseUrl}}/api/v1/agents
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "Demo Agent",
  "description": "用于阶段 3 验证",
  "systemPrompt": "你是一个安全平台助手。",
  "temperature": 0.7,
  "maxTokens": 2048
}

### 查询 Agent 详情
GET {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新 Agent
PUT {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "Demo Agent Updated",
  "description": "更新后的描述",
  "avatarUrl": "https://example.com/avatar.png",
  "systemPrompt": "你是一个专业安全顾问。",
  "temperature": 0.3,
  "maxTokens": 4096,
  "knowledgeBaseIds": [1001, 1002]
}

### 复制 Agent
POST {{baseUrl}}/api/v1/agents/{{agentId}}/duplicate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 发布 Agent
POST {{baseUrl}}/api/v1/agents/{{agentId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 删除 Agent
DELETE {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
