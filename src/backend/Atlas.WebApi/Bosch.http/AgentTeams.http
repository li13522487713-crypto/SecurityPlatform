@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@teamId = 0

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 创建 Agent Team
# @name createAgentTeam
POST {{baseUrl}}/api/v1/agent-teams
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "teamName": "风控审查团队",
  "description": "Agent Team MVP 创建示例",
  "owner": "admin",
  "collaborators": ["ops", "reviewer"],
  "riskLevel": "Medium",
  "tags": ["risk", "mvp"],
  "defaultModelPolicyJson": "{}",
  "budgetPolicyJson": "{\"dailyBudget\":100}",
  "permissionScopeJson": "{}"
}

###
@teamId = {{createAgentTeam.response.body.$.data.id}}

### 查询团队列表
GET {{baseUrl}}/api/v1/agent-teams?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询团队详情
GET {{baseUrl}}/api/v1/agent-teams/{{teamId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新团队
PUT {{baseUrl}}/api/v1/agent-teams/{{teamId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "teamName": "风控审查团队-更新",
  "description": "Agent Team 更新示例",
  "owner": "admin",
  "collaborators": ["ops"],
  "riskLevel": "High",
  "tags": ["risk", "prod"],
  "defaultModelPolicyJson": "{}",
  "budgetPolicyJson": "{\"dailyBudget\":120}",
  "permissionScopeJson": "{}"
}

### 发布团队
POST {{baseUrl}}/api/v1/agent-teams/{{teamId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "releaseNote": "MVP 首次发布",
  "requiresApproval": false
}

### 查询版本
GET {{baseUrl}}/api/v1/agent-teams/{{teamId}}/versions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 复制团队
POST {{baseUrl}}/api/v1/agent-teams/{{teamId}}/duplicate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
