### TenantAppInstances V2 API

@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken = {{login.response.headers.X-CSRF-TOKEN}}
@idempotencyKey = {{$guid}}

### 查询实例列表
GET {{baseUrl}}/api/v2/tenant-app-instances?pageIndex=1&pageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询实例详情
GET {{baseUrl}}/api/v2/tenant-app-instances/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询实例实体别名
GET {{baseUrl}}/api/v2/tenant-app-instances/1/entity-aliases
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新实例实体别名
PUT {{baseUrl}}/api/v2/tenant-app-instances/1/entity-aliases
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "items": [
    {
      "entityType": "users",
      "singularAlias": "成员",
      "pluralAlias": "成员列表"
    },
    {
      "entityType": "roles",
      "singularAlias": "岗位",
      "pluralAlias": "岗位列表"
    },
    {
      "entityType": "departments",
      "singularAlias": "组织",
      "pluralAlias": "组织列表"
    }
  ]
}

### 查询实例数据源信息
GET {{baseUrl}}/api/v2/tenant-app-instances/1/datasource
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 测试实例数据源连接
POST {{baseUrl}}/api/v2/tenant-app-instances/1/datasource/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用级文件存储配置
GET {{baseUrl}}/api/v2/tenant-app-instances/1/file-storage
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新应用级文件存储覆盖（关闭继承）
PUT {{baseUrl}}/api/v2/tenant-app-instances/1/file-storage
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "inheritBasePath": false,
  "overrideBasePath": "uploads/app-1001",
  "inheritMinioBucketName": false,
  "overrideMinioBucketName": "atlas-app-1001"
}

### 更新应用级文件存储覆盖（恢复继承）
PUT {{baseUrl}}/api/v2/tenant-app-instances/1/file-storage
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "inheritBasePath": true,
  "inheritMinioBucketName": true
}

### 查询实例数据源绑定（可选 appIds 过滤）
# 响应包含 bindingId/bindingType/bindingActive/boundAt/source（支持绑定表与历史字段回填来源）
GET {{baseUrl}}/api/v2/tenant-app-instances/data-source-bindings?appIds=1&appIds=2
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建实例（写接口需幂等与防伪）
# @name createTenantAppInstance
POST {{baseUrl}}/api/v2/tenant-app-instances
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{idempotencyKey}}
Content-Type: application/json

{
  "appKey": "coze-demo-{{$timestamp}}",
  "name": "Coze 演示应用",
  "description": "用于验证 v2 tenant-app-instances 写链路",
  "category": "OA",
  "icon": "🤖"
}

###
@tenantAppInstanceId = {{createTenantAppInstance.response.body.$.data.id}}

### 查询应用角色
# 读权限：apps:roles:view
GET {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/roles?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用角色治理概览（成员覆盖/权限覆盖）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/roles/governance-overview
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建应用角色
# @name createTenantAppRole
POST {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/roles
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "code": "APP_EDITOR",
  "name": "应用编辑员",
  "description": "可维护应用配置",
  "permissionCodes": ["app:user", "apps:view", "apps:update"]
}

###
@tenantAppRoleId = {{createTenantAppRole.response.body.$.data.roleId}}

### 更新应用角色权限
# 写权限：apps:roles:update
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/roles/{{tenantAppRoleId}}/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "permissionCodes": ["app:user", "apps:view"]
}

### 查询应用成员列表
# 读权限：apps:members:view
GET {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/members?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询当前用户（提取 userId 供成员接口示例使用）
# @name currentUser
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@currentUserId = {{currentUser.response.body.$.data.userId}}

### 添加应用成员（示例使用 admin 自身）
# 写权限：apps:members:update
POST {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/members
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "userIds": [{{currentUserId}}],
  "roleIds": [{{tenantAppRoleId}}]
}

### 更新实例
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "name": "Coze 演示应用-已更新",
  "description": "更新后的描述",
  "category": "CRM",
  "icon": "✨",
  "dataSourceId": 1001
}

### 切换实例数据源
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "name": "Coze 演示应用-已更新",
  "description": "更新后的描述",
  "category": "CRM",
  "icon": "✨",
  "dataSourceId": 1002
}

### 解绑实例数据源（清空 dataSourceId）
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "name": "Coze 演示应用-已更新",
  "description": "更新后的描述",
  "category": "CRM",
  "icon": "✨",
  "unbindDataSource": true
}

### 发布实例
POST {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}

### 导出实例
GET {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}/export
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 导入实例
POST {{baseUrl}}/api/v2/tenant-app-instances/import
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
Content-Type: application/json

{
  "package": {
    "appKey": "coze-import-{{$timestamp}}",
    "name": "Coze 导入应用",
    "status": "Draft",
    "pages": [],
    "pageVersions": []
  },
  "conflictStrategy": "Rename",
  "keySuffix": "v2"
}

### 删除实例
DELETE {{baseUrl}}/api/v2/tenant-app-instances/{{tenantAppInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}
Idempotency-Key: {{$guid}}
