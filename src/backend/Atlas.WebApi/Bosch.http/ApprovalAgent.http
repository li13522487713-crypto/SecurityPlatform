@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@token =
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 查询我的代理配置
GET {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 创建代理配置（成功）
POST {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "agentUserId": 1002,
  "startTime": "2026-03-02T08:00:00Z",
  "endTime": "2026-03-31T18:00:00Z"
}

### 安全负例：缺少 Idempotency-Key（应返回 400）
POST {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
X-CSRF-TOKEN: {{csrfToken}}

{
  "agentUserId": 1002,
  "startTime": "2026-03-02T08:00:00Z",
  "endTime": "2026-03-31T18:00:00Z"
}

### 安全负例：缺少 X-CSRF-TOKEN（应返回 403）
POST {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}

{
  "agentUserId": 1002,
  "startTime": "2026-03-02T08:00:00Z",
  "endTime": "2026-03-31T18:00:00Z"
}

### 安全负例：幂等冲突（同 key 不同 payload，第二次应返回 409）
@idemConflictAgent = approval-agent-conflict-001
POST {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{idemConflictAgent}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "agentUserId": 1002,
  "startTime": "2026-03-02T08:00:00Z",
  "endTime": "2026-03-31T18:00:00Z"
}

###
POST {{baseUrl}}/api/v1/approval/agents
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{idemConflictAgent}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "agentUserId": 1003,
  "startTime": "2026-03-02T08:00:00Z",
  "endTime": "2026-03-31T18:00:00Z"
}

### 删除代理配置（成功）
DELETE {{baseUrl}}/api/v1/approval/agents/1
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
