@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Anti-Forgery Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Create Dynamic Table
POST {{baseUrl}}/api/v1/dynamic-tables
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "tableKey": "orders",
  "displayName": "订单",
  "description": "订单主表",
  "dbType": "Sqlite",
  "fields": [
    {
      "name": "id",
      "displayName": "主键",
      "fieldType": "Long",
      "allowNull": false,
      "isPrimaryKey": true,
      "isAutoIncrement": true,
      "isUnique": true,
      "sortOrder": 0
    },
    {
      "name": "orderNo",
      "displayName": "订单号",
      "fieldType": "String",
      "length": 50,
      "allowNull": false,
      "isPrimaryKey": false,
      "isAutoIncrement": false,
      "isUnique": true,
      "sortOrder": 1,
      "validation": {
        "pattern": "^SO-[0-9]{5}$",
        "minLength": 8,
        "maxLength": 8
      }
    },
    {
      "name": "amount",
      "displayName": "金额",
      "fieldType": "Decimal",
      "precision": 18,
      "scale": 2,
      "allowNull": false,
      "isPrimaryKey": false,
      "isAutoIncrement": false,
      "isUnique": false,
      "sortOrder": 2
    }
  ],
  "indexes": [
    {
      "name": "idx_orders_no",
      "isUnique": true,
      "fields": ["orderNo"]
    }
  ]
}

### 预览动态表结构变更（新增校验字段 + 删除旧字段）
POST {{baseUrl}}/api/v1/dynamic-tables/orders/schema/alter/preview
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "addFields": [
    {
      "name": "remark",
      "displayName": "备注",
      "fieldType": "String",
      "length": 200,
      "allowNull": true,
      "isPrimaryKey": false,
      "isAutoIncrement": false,
      "isUnique": false,
      "sortOrder": 9,
      "validation": {
        "maxLength": 200
      }
    }
  ],
  "updateFields": [],
  "removeFields": ["amount"]
}

### 执行动态表结构变更（新增校验字段 + 删除旧字段）
POST {{baseUrl}}/api/v1/dynamic-tables/orders/schema/alter
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "addFields": [
    {
      "name": "remark",
      "displayName": "备注",
      "fieldType": "String",
      "length": 200,
      "allowNull": true,
      "isPrimaryKey": false,
      "isAutoIncrement": false,
      "isUnique": false,
      "sortOrder": 9,
      "validation": {
        "maxLength": 200
      }
    }
  ],
  "updateFields": [],
  "removeFields": ["amount"]
}

### List Dynamic Tables
GET {{baseUrl}}/api/v1/dynamic-tables?pageIndex=1&pageSize=20&keyword=order
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Dynamic Table Detail
GET {{baseUrl}}/api/v1/dynamic-tables/orders
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Dynamic Table Summary
# 轻量概览：fieldCount/indexCount/approvalFlowDefinitionId/previewFields
GET {{baseUrl}}/api/v1/dynamic-tables/orders/summary
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Set Dynamic Table Relations
PUT {{baseUrl}}/api/v1/dynamic-tables/orders/relations
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "relations": [
    {
      "relatedTableKey": "order_items",
      "sourceField": "id",
      "targetField": "orderId",
      "relationType": "OneToMany",
      "cascadeRule": "Restrict"
    }
  ]
}

### Get Dynamic Table Relations
GET {{baseUrl}}/api/v1/dynamic-tables/orders/relations
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Set Dynamic Field Permissions
PUT {{baseUrl}}/api/v1/dynamic-tables/orders/field-permissions
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "permissions": [
    {
      "fieldName": "orderNo",
      "roleCode": "Admin",
      "canView": true,
      "canEdit": true
    },
    {
      "fieldName": "amount",
      "roleCode": "AuditAdmin",
      "canView": true,
      "canEdit": false
    }
  ]
}

### Get Dynamic Field Permissions
GET {{baseUrl}}/api/v1/dynamic-tables/orders/field-permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Dynamic CRUD AMIS Schema
GET {{baseUrl}}/api/v1/amis/dynamic-tables/orders/crud
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Dynamic Detail Form Schema
GET {{baseUrl}}/api/v1/amis/dynamic-tables/orders/forms/detail?id=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create Record
POST {{baseUrl}}/api/v1/dynamic-tables/orders/records
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "values": [
    { "field": "orderNo", "valueType": "String", "stringValue": "SO-10001" },
    { "field": "amount", "valueType": "Decimal", "decimalValue": 199.99 },
    { "field": "remark", "valueType": "String", "stringValue": "M9 alter add field" }
  ]
}

### Query Records
GET {{baseUrl}}/api/v1/dynamic-tables/orders/records?pageIndex=1&pageSize=20&keyword=SO
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Query Records (Advanced Filters)
POST {{baseUrl}}/api/v1/dynamic-tables/orders/records/query
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "pageIndex": 1,
  "pageSize": 20,
  "keyword": "SO",
  "sortBy": "amount",
  "sortDesc": true,
  "filters": [
    {
      "field": "amount",
      "operator": "gte",
      "value": 100
    },
    {
      "field": "orderNo",
      "operator": "like",
      "value": "SO-"
    }
  ]
}

### Export Records CSV
POST {{baseUrl}}/api/v1/dynamic-tables/orders/records/export
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "keyword": "SO",
  "sortBy": "amount",
  "sortDesc": true,
  "filters": [
    {
      "field": "amount",
      "operator": "gte",
      "value": 100
    }
  ],
  "fields": ["orderNo", "amount"]
}

### Update Record
PUT {{baseUrl}}/api/v1/dynamic-tables/orders/records/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "values": [
    { "field": "amount", "valueType": "Decimal", "decimalValue": 299.99 }
  ]
}

### 批量删除记录
DELETE {{baseUrl}}/api/v1/dynamic-tables/orders/records
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "ids": [1, 2]
}

### 绑定审批流（flowId 按实际替换）
PUT {{baseUrl}}/api/v1/dynamic-tables/orders/approval-binding
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "approvalFlowDefinitionId": 1,
  "approvalStatusField": "orderNo"
}

