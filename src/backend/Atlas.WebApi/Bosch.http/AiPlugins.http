@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@pluginId = 1
@apiId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 插件分页
GET {{baseUrl}}/api/v1/ai-plugins?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 内置插件元数据
GET {{baseUrl}}/api/v1/ai-plugins/built-in-metadata
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建插件
POST {{baseUrl}}/api/v1/ai-plugins
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "HTTP 调试插件",
  "description": "用于验证插件体系",
  "icon": "api",
  "category": "integration",
  "type": 0,
  "definitionJson": "{\"baseUrl\":\"https://example.com\"}"
}

### 查询插件详情
GET {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新插件
PUT {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "HTTP 调试插件-更新",
  "description": "更新描述",
  "icon": "api",
  "category": "integration",
  "type": 0,
  "definitionJson": "{\"baseUrl\":\"https://example.com/api\"}"
}

### 插件调试
POST {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/debug
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "inputJson": "{\"query\":\"hello\"}"
}

### 导入 OpenAPI
POST {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/import/openapi
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "openApiJson": "{\"openapi\":\"3.0.0\",\"paths\":{\"/ping\":{\"get\":{\"summary\":\"ping\",\"responses\":{\"200\":{\"description\":\"ok\"}}}}}}",
  "overwrite": true
}

### 查询插件接口列表
GET {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/apis
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新增插件接口
POST {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/apis
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "查询天气",
  "description": "调用天气服务",
  "method": "GET",
  "path": "/weather/current",
  "requestSchemaJson": "{\"type\":\"object\"}",
  "responseSchemaJson": "{\"type\":\"object\"}",
  "timeoutSeconds": 30
}

### 更新插件接口
PUT {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/apis/{{apiId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "查询天气V2",
  "description": "支持城市参数",
  "method": "GET",
  "path": "/weather/current",
  "requestSchemaJson": "{\"type\":\"object\"}",
  "responseSchemaJson": "{\"type\":\"object\"}",
  "timeoutSeconds": 30,
  "isEnabled": true
}

### 发布插件
POST {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 锁定插件
PATCH {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/lock
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "isLocked": true
}

### 删除插件接口
DELETE {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}/apis/{{apiId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 删除插件
DELETE {{baseUrl}}/api/v1/ai-plugins/{{pluginId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
