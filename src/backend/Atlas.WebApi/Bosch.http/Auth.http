@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@clientType = WebH5
@clientPlatform = Web
@clientChannel = Browser
@clientAgent = Chrome

### Create Token
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@refreshToken = {{login.response.body.$.data.refreshToken}}
@csrfToken =

### Refresh Token
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

{
  "refreshToken": "{{refreshToken}}"
}

### Get CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Current User
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

### Get Profile
GET {{baseUrl}}/api/v1/auth/profile
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

### Update Profile
PUT {{baseUrl}}/api/v1/auth/profile
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "displayName": "系统管理员（更新）",
  "email": "admin.updated@atlas.local",
  "phoneNumber": "13800000000"
}

### E1-02 准备：创建待禁用测试用户（管理员令牌）
# @name createDisableUser
POST {{baseUrl}}/api/v1/users
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "username": "session.disable.demo",
  "password": "P@ssw0rd!2026",
  "displayName": "Session Disable Demo",
  "email": "session.disable.demo@atlas.local",
  "phoneNumber": "13800000999",
  "isActive": true,
  "roleIds": [],
  "departmentIds": []
}

###
@disabledDemoUserId = {{createDisableUser.response.body.$.data.id}}

### E1-02 测试用户登录并拿到 token
# @name loginDisableUser
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "session.disable.demo",
  "password": "P@ssw0rd!2026"
}

###
@disabledDemoToken = {{loginDisableUser.response.body.$.data.accessToken}}

### E1-02 验证：禁用前可访问 /auth/me
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{disabledDemoToken}}
X-Tenant-Id: {{tenantId}}

### E1-02 管理员禁用该用户
PUT {{baseUrl}}/api/v1/users/{{disabledDemoUserId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "displayName": "Session Disable Demo",
  "email": "session.disable.demo@atlas.local",
  "phoneNumber": "13800000999",
  "isActive": false
}

### E1-02 验证：已签发 token 下一请求应 401
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{disabledDemoToken}}
X-Tenant-Id: {{tenantId}}

### Dynamic Routers
GET {{baseUrl}}/api/v1/auth/routers
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-Client-Type: {{clientType}}
X-Client-Platform: {{clientPlatform}}
X-Client-Channel: {{clientChannel}}
X-Client-Agent: {{clientAgent}}

