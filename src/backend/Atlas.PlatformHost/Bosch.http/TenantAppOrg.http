# ====================================================
# 应用级项目管理 (TenantAppProjects)
# ====================================================

### 查询应用项目列表（分页）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/projects?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用项目全量
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/projects/all
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建应用项目
# @name createProj
POST {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/projects
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "安全平台 V2.0",
  "code": "SEC-V2",
  "description": "等保2.0合规升级项目",
  "isActive": true
}

###
@newProjId = {{createProj.response.body.$.data.id}}

### 更新应用项目
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/projects/{{newProjId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "安全平台 V2.0（升级版）",
  "description": "等保2.0合规升级，包括多租户改造",
  "isActive": true
}

### 删除应用项目
