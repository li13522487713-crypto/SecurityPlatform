Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

# ====================================================
# 应用角色数据权限 (AppRoles DataScope)
# ====================================================

@roleId = 1

### 查询应用角色数据权限
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/data-scope
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 设置应用角色数据权限（全部数据）
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/data-scope
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "dataScope": 0,
  "deptIds": null
}

### 设置应用角色数据权限（自定义部门）
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/data-scope
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "dataScope": 3,
  "deptIds": "1,2,3"
}

# ====================================================
# 平台级权限 — 验证不泄露应用级数据
# ====================================================

### 平台权限列表（应只返回 AppId IS NULL 的权限）
GET {{baseUrl}}/api/v1/permissions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 平台部门列表（应只返回平台级部门，非应用级）
GET {{baseUrl}}/api/v1/departments?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 平台职位列表（应只返回平台级职位）
GET {{baseUrl}}/api/v1/positions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 平台项目列表（应只返回平台级项目）
GET {{baseUrl}}/api/v1/projects?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

# ====================================================
# 应用级功能权限 CRUD (TenantAppPermissions)
# ====================================================

### 查询应用级权限列表（分页）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/permissions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建应用级权限
# @name createAppPerm
POST {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "查看资产",
  "code": "assets:view",
  "type": "Api",
  "description": "允许查看应用内资产列表"
}

###
@newAppPermId = {{createAppPerm.response.body.$.data.id}}

### 查询单个应用级权限
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/permissions/{{newAppPermId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新应用级权限
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/permissions/{{newAppPermId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "查看资产（更新）",
  "type": "Api",
  "description": "允许查看应用内资产列表（含详情）"
}

### 删除应用级权限
DELETE {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/permissions/{{newAppPermId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

# ====================================================
# 应用角色页面分配 (AppRolePage)
# ====================================================

### 获取应用可分配的页面列表
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/available-pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取应用角色已分配的页面 ID 列表
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 设置应用角色的页面分配（全量替换）
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "pageIds": [1, 2, 3]
}

### 清空应用角色的页面分配
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "pageIds": []
}

# ====================================================
# 应用角色字段权限 (AppRoleFieldPermissions)
# ====================================================

### 获取应用角色的字段权限配置（所有表）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/field-permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 设置应用角色的字段权限（全量替换，按 tableKey 分组）
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/field-permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "groups": [
    {
      "tableKey": "asset_list",
      "fields": [
        { "fieldName": "name", "canView": true, "canEdit": true },
        { "fieldName": "ip", "canView": true, "canEdit": false },
        { "fieldName": "secret_key", "canView": false, "canEdit": false }
      ]
    },
    {
      "tableKey": "user_profile",
      "fields": [
        { "fieldName": "username", "canView": true, "canEdit": false },
        { "fieldName": "email", "canView": true, "canEdit": false }
      ]
    }
  ]
}

### 清空应用角色的字段权限
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{roleId}}/field-permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "groups": []
}
