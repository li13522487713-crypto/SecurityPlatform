### 应用级组织管理 API 测试
### TenantAppDepartments / TenantAppPositions / TenantAppProjects / AppRoles DataScope

@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@appId = 1

# ====================================================
# 应用级成员管理 (TenantAppMembers V2)
# ====================================================

### 查询成员列表（分页）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/members?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按角色过滤成员
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/members?pageIndex=1&pageSize=20&roleId=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按部门过滤成员
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/members?pageIndex=1&pageSize=20&departmentId=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按关键字搜索成员
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/members?pageIndex=1&pageSize=20&keyword=admin
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询单个成员详情
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/members/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

# ====================================================
# 应用级角色管理 (TenantAppRoles V2)
# ====================================================

### 查询角色列表（分页）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按 isSystem 过滤角色
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles?pageIndex=1&pageSize=20&isSystem=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按关键字搜索角色
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles?pageIndex=1&pageSize=20&keyword=admin
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询单个角色
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询角色治理概览
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/governance-overview
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建角色
# @name createRole
POST {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "code": "TESTER",
  "name": "测试工程师",
  "description": "负责功能测试与质量保障",
  "permissionCodes": ["assets:view"]
}

###
@newRoleId = {{createRole.response.body.$.data.roleId}}

### 更新角色
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{newRoleId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "高级测试工程师",
  "description": "负责功能与自动化测试"
}

### 更新角色权限
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{newRoleId}}/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "permissionCodes": ["assets:view", "assets:create"]
}

### 删除角色
DELETE {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/roles/{{newRoleId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

# ====================================================
# 应用级部门管理 (TenantAppDepartments)
# ====================================================

### 查询应用部门列表（分页）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用部门全量（用于树形选择）
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments/all
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建应用部门
# @name createDept
POST {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "研发部",
  "code": "DEV",
  "parentId": null,
  "sortOrder": 1
}

###
@newDeptId = {{createDept.response.body.$.data.id}}

### 查询单个应用部门
GET {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments/{{newDeptId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新应用部门
PUT {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments/{{newDeptId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "研发中心",
  "code": "DEV",
  "parentId": null,
  "sortOrder": 2
}

### 删除应用部门
DELETE {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/departments/{{newDeptId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

