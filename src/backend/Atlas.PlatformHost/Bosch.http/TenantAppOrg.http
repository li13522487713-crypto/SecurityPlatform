Content-Type: application/json

{
  "name": "资深工程师",
  "description": "负责核心架构与模块开发",
  "isActive": true,
  "sortOrder": 2
}

### 删除应用职位
DELETE {{baseUrl}}/api/v2/tenant-app-instances/{{appId}}/positions/{{newPosId}}
Authorization: Bearer {{accessToken}}
