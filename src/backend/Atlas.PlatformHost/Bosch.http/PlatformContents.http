@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 运营内容列表（全部 Slot）
GET {{baseUrl}}/api/v1/platform/contents?onlyActive=false
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 运营内容列表（仅 banner）
GET {{baseUrl}}/api/v1/platform/contents?slot=banner&onlyActive=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新增 banner
# @name createBanner
POST {{baseUrl}}/api/v1/platform/contents
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "slot": "banner",
  "contentKey": "main",
  "contentJson": "{\"heroTitle\":\"欢迎来到 Atlas Coze\",\"heroSubtitle\":\"新一代 AI 应用开发平台\",\"ctaList\":[{\"key\":\"create\",\"label\":\"立即创建\"}]}",
  "tag": null,
  "orderIndex": 0,
  "isActive": true,
  "publishedAt": null
}

###
@bannerId = {{createBanner.response.body.$.data.id}}

### 新增教程卡
POST {{baseUrl}}/api/v1/platform/contents
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "slot": "tutorial",
  "contentKey": "intro",
  "contentJson": "{\"id\":\"intro\",\"title\":\"什么是扣子\",\"description\":\"5 分钟了解平台\",\"iconKey\":\"intro\",\"link\":\"/docs/welcome\"}",
  "orderIndex": 0,
  "isActive": true
}

### 更新运营内容
PATCH {{baseUrl}}/api/v1/platform/contents/{{bannerId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "contentJson": "{\"heroTitle\":\"Atlas Coze：更快构建\",\"heroSubtitle\":\"多平台发布 + WebSDK\",\"ctaList\":[{\"key\":\"create\",\"label\":\"立即创建\"}]}",
  "tag": null,
  "orderIndex": 0,
  "isActive": true,
  "publishedAt": null
}

### 删除运营内容
DELETE {{baseUrl}}/api/v1/platform/contents/{{bannerId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
