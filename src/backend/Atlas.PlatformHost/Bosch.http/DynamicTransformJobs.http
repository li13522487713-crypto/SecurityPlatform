@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1482690002860118016
@jobKey = orders_sync_job

### Login
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Anti-Forgery Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### List Transform Jobs
GET {{baseUrl}}/api/v1/dynamic-transform-jobs
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}

### Create Transform Job
POST {{baseUrl}}/api/v1/dynamic-transform-jobs
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "appId": "{{appId}}",
  "jobKey": "{{jobKey}}",
  "name": "订单同步任务",
  "definitionJson": "{\"source\":\"orders_view\",\"target\":\"orders_snapshot\"}",
  "cronExpression": "*/5 * * * *",
  "enabled": true,
  "sourceConfigJson": "{\"type\":\"view\",\"viewKey\":\"orders_view\"}",
  "targetConfigJson": "{\"type\":\"table\",\"tableKey\":\"orders_snapshot\"}"
}

### Get Job Detail
GET {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}

### Update Transform Job
PUT {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "订单同步任务-更新",
  "definitionJson": "{\"source\":\"orders_view\",\"target\":\"orders_snapshot\"}",
  "cronExpression": "*/10 * * * *",
  "enabled": true,
  "sourceConfigJson": "{\"type\":\"view\",\"viewKey\":\"orders_view\"}",
  "targetConfigJson": "{\"type\":\"table\",\"tableKey\":\"orders_snapshot\"}"
}

### Manual Run
POST {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}/run
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{}

### Pause Job
POST {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}/pause
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{}

### Resume Job
POST {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}/resume
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{}

### Job History (Paged)
GET {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}/history?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}

### Execution Detail
GET {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}/executions/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}

### Delete Job
DELETE {{baseUrl}}/api/v1/dynamic-transform-jobs/{{jobKey}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-App-Id: {{appId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}
