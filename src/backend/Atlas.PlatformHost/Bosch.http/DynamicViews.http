@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1482690002860118016

### Login to get token
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Anti-Forgery Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Create Dynamic View
POST {{baseUrl}}/api/v1/dynamic-views
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "appId": "{{appId}}",
  "viewKey": "orders_view",
  "name": "订单视图",
  "description": "P0 视图样例",
  "nodes": [
    {
      "id": "n1",
      "type": "sourceTable",
      "label": "orders",
      "tableKey": "orders"
    },
    {
      "id": "n2",
      "type": "limit",
      "config": {
        "limit": 100
      }
    }
  ],
  "edges": [],
  "outputFields": [
    {
      "targetFieldKey": "orderNo",
      "targetLabel": "订单号",
      "targetType": "String",
      "nullable": true,
      "source": {
        "nodeId": "n1",
        "fieldKey": "orderNo"
      },
      "pipeline": [
        {
          "type": "trim",
          "args": {}
        }
      ],
      "onError": "null"
    }
  ],
  "filters": [
    {
      "field": "orderNo",
      "operator": "contains",
      "value": "SO-"
    }
  ],
  "groupBy": [],
  "sorts": [
    {
      "field": "orderNo",
      "direction": "asc"
    }
  ]
}

### List Dynamic Views
GET {{baseUrl}}/api/v1/dynamic-views?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Dynamic View
GET {{baseUrl}}/api/v1/dynamic-views/orders_view
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

