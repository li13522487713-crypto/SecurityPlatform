  "nodes": [
    {
      "id": "n1",
      "type": "sourceTable",
      "label": "orders",
      "tableKey": "orders"
    }
  ],
  "edges": [],
  "outputFields": [
    {
      "targetFieldKey": "orderNo",
      "targetLabel": "订单号",
      "targetType": "String",
      "nullable": true,
      "source": {
        "nodeId": "n1",
        "fieldKey": "orderNo"
      },
      "pipeline": [],
      "onError": "null"
    }
  ],
  "filters": [],
  "groupBy": [],
  "sorts": []
}

### Preview Dynamic View
