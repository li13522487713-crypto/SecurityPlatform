    "viewKey": "orders_view",
    "name": "订单视图",
    "description": "预览",
    "nodes": [
      {
        "id": "n1",
        "type": "sourceTable",
        "tableKey": "orders"
      }
    ],
    "edges": [],
    "outputFields": [
      {
        "targetFieldKey": "orderNo",
        "targetLabel": "订单号",
        "targetType": "String",
        "nullable": true,
        "source": {
          "nodeId": "n1",
          "fieldKey": "orderNo"
        },
        "pipeline": [],
        "onError": "null"
      }
    ],
    "filters": [],
    "groupBy": [],
    "sorts": []
  },
  "limit": 100
}

