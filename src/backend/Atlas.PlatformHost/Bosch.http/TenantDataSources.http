@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@sourceId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 跨租户校验：已登录请求伪造租户头应返回 403
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}
X-Tenant-Id: 00000000-0000-0000-0000-000000000002

### 查询租户数据源
GET {{baseUrl}}/api/v1/tenant-datasources
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询支持的驱动与可视化字段定义
GET {{baseUrl}}/api/v1/tenant-datasources/drivers
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建 SQLite 数据源
POST {{baseUrl}}/api/v1/tenant-datasources
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "tenantIdValue": "{{tenantId}}",
  "name": "SQLite-DS",
  "connectionString": "Data Source=tenant_a.db",
  "dbType": "SQLite",
  "ownershipScope": "Platform",
  "mode": "raw"
}

### 创建 MySQL 数据源（可视化模式）
POST {{baseUrl}}/api/v1/tenant-datasources
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "tenantIdValue": "{{tenantId}}",
  "name": "MySQL-DS-Visual",
  "connectionString": "",
  "dbType": "MySql",
  "ownershipScope": "AppScoped",
  "ownerAppInstanceId": "1482690002860118000",
  "mode": "visual",
  "visualConfig": {
    "host": "127.0.0.1",
    "port": "3306",
    "database": "atlas",
    "username": "root",
    "password": "root",
    "extra": "SslMode=none"
  }
}

### 测试 PostgreSQL 数据源连通性（示例）
POST {{baseUrl}}/api/v1/tenant-datasources/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "connectionString": "Host=127.0.0.1;Port=5432;Database=atlas;Username=postgres;Password=postgres",
  "dbType": "PostgreSQL",
  "mode": "raw"
}

### 测试 MySQL 数据源连通性（示例）
POST {{baseUrl}}/api/v1/tenant-datasources/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "connectionString": "Server=127.0.0.1;Port=3306;Database=atlas;Uid=root;Pwd=root;",
  "dbType": "MySql",
  "mode": "raw"
}

### 更新数据源
PUT {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "SQLite-DS-Updated",
  "dbType": "SQLite",
  "ownershipScope": "Platform",
  "mode": "raw",
  "maxPoolSize": 80,
  "connectionTimeoutSeconds": 20
}

### 测试已保存数据源连通性（不回传明文连接串）
POST {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### SQL 预览查询
POST {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}/query
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "sql": "SELECT * FROM sqlite_master LIMIT 10"
}

### 获取数据源表结构
GET {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}/schema
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取数据源使用者
GET {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}/consumers
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取孤立数据源
GET {{baseUrl}}/api/v1/tenant-datasources/orphans
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 删除数据源
DELETE {{baseUrl}}/api/v1/tenant-datasources/{{sourceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
