@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@tableKey = orders
@recordId = 1

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 列表查询：动态表记录分页
GET {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("动态表记录列表查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(Array.isArray(response.body.data.items), "items 应为数组");
  });
%}

### 详情查询：动态表记录详情
GET {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/{{recordId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("动态表记录详情查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.code === "Success", "code 应为 Success");
    client.assert(response.body.data === null || response.body.data.id !== undefined, "应返回 null 或包含 id");
  });
%}

### 导出记录（流式 CSV）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/export
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "keyword": "REC-",
  "sortBy": "id",
  "sortDesc": true,
  "filters": [],
  "fields": ["orderNo", "amount"]
}

> {%
  client.test("导出返回 CSV 文件流", function () {
    client.assert(response.status === 200, "状态码应为 200");
    const contentType = (response.headers.valueOf("content-type") || "").toLowerCase();
    client.assert(contentType.includes("text/csv"), "content-type 应包含 text/csv");
    const disposition = response.headers.valueOf("content-disposition") || "";
    client.assert(disposition.toLowerCase().includes("attachment"), "应返回 attachment");
  });
%}

### 关键写操作：创建动态表记录
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "values": [
    { "field": "orderNo", "valueType": "String", "stringValue": "REC-{{$timestamp}}" },
    { "field": "amount", "valueType": "Decimal", "decimalValue": 166.66 }
  ]
}

> {%
  client.test("动态表记录创建成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.id, "应返回 data.id");
  });
%}

### 错误码断言：更新不存在记录
PUT {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/999999999
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "values": [
    { "field": "orderNo", "valueType": "String", "stringValue": "REC-NOT-FOUND" },
    { "field": "amount", "valueType": "Decimal", "decimalValue": 1.00 }
  ]
}

> {%
  client.test("更新不存在记录返回错误码", function () {
    client.assert(response.status >= 400, "状态码应为 4xx/5xx");
    client.assert(response.body.success === false, "success 应为 false");
    client.assert(response.body.code && response.body.code !== "Success", "应返回业务错误码");
  });
%}

### 批量导入（CSV）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/import
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "format": "csv",
  "content": "orderNo,amount\nIMP-1001,88.80\nIMP-1002,99.90",
  "dryRun": true
}

### 导入分析（multipart/form-data）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/import/analyze
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: multipart/form-data; boundary=BoundaryAtlasImport

--BoundaryAtlasImport
Content-Disposition: form-data; name="format"

csv
--BoundaryAtlasImport
Content-Disposition: form-data; name="file"; filename="orders.csv"
Content-Type: text/csv

orderNo,amount
IMP-1001,88.80
IMP-1002,99.90
--BoundaryAtlasImport--

### 导入提交（analyze -> commit）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/import/commit
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "sessionId": "replace-with-analyze-session-id",
  "dryRun": true,
  "batchSize": 200,
  "mappings": [
    { "sourceField": "orderNo", "targetField": "orderNo" },
    { "sourceField": "amount", "targetField": "amount" }
  ]
}

### Excel 粘贴导入（TSV）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records/excel-paste
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "format": "excel",
  "content": "orderNo\tamount\nXL-2001\t120.5\nXL-2002\t130.6",
  "dryRun": true
}
