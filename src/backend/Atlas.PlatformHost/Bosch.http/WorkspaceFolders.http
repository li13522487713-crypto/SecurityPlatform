@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@workspaceId = atlas-space
@username = admin
@password = P@ssw0rd!

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 文件夹列表
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/folders?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建文件夹
# @name createFolder
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/folders
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "客服项目",
  "description": "客服场景下的智能体与应用集合"
}

###
@folderId = {{createFolder.response.body.$.data.folderId}}

### 编辑文件夹
PATCH {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/folders/{{folderId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "客服项目（重命名）",
  "description": "更新后的描述"
}

### 移入项目（itemType: agent | app | project）
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/folders/{{folderId}}/items
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "itemType": "agent",
  "itemId": "agent-123"
}

### 删除文件夹
DELETE {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/folders/{{folderId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
