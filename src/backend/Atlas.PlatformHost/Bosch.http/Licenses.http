@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录（获取 Token，用于需要鉴权的接口）
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

###
# 1. 获取当前授权状态（AllowAnonymous，登录前可调用）
GET {{baseUrl}}/api/v1/license/status
X-Tenant-Id: {{tenantId}}

###
# 2. 获取当前机器码（AllowAnonymous，用于向颁发方申请绑定证书）
GET {{baseUrl}}/api/v1/license/fingerprint
X-Tenant-Id: {{tenantId}}

###
# 3. 激活证书（AllowAnonymous，登录前激活）
# licenseContent 为 .atlaslicense 文件的 Base64 内容
POST {{baseUrl}}/api/v1/license/activate
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "licenseContent": ""
}

###
# 4. 获取当前授权状态（已登录，鉴权接口）
GET {{baseUrl}}/api/v1/license/status
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
