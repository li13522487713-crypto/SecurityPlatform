@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@recentId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 全局搜索
GET {{baseUrl}}/api/v1/ai-search?keyword=agent&limit=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 最近编辑列表
GET {{baseUrl}}/api/v1/ai-search/recent?limit=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 记录最近编辑
# @name recordRecent
POST {{baseUrl}}/api/v1/ai-search/recent
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "resourceType": "agent",
  "resourceId": 1,
  "title": "客服 Agent",
  "path": "/ai/agents/1/edit"
}

###
@recentId = {{recordRecent.response.body.$.data.id}}

### 删除最近编辑
DELETE {{baseUrl}}/api/v1/ai-search/recent/{{recentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
