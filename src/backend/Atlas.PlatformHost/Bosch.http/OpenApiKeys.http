@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### API 密钥列表
GET {{baseUrl}}/api/v1/open/api-keys?pageIndex=1&pageSize=50
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建 API 密钥（key 仅在响应中返回一次）
# @name createKey
POST {{baseUrl}}/api/v1/open/api-keys
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "alias": "my-key",
  "scopes": ["agent:read", "workflow:run"],
  "expiresAt": null
}

###
@createdKeyId = {{createKey.response.body.$.data.item.id}}

### 删除 API 密钥（撤销 PAT）
DELETE {{baseUrl}}/api/v1/open/api-keys/{{createdKeyId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
