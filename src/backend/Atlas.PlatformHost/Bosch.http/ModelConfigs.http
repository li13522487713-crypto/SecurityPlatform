@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@modelConfigId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 模型配置分页
GET {{baseUrl}}/api/v1/model-configs?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 模型配置启用列表
GET {{baseUrl}}/api/v1/model-configs/enabled
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 模型配置统计
GET {{baseUrl}}/api/v1/model-configs/stats?keyword=
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建模型配置
POST {{baseUrl}}/api/v1/model-configs
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "OpenAI-Primary",
  "providerType": "openai",
  "apiKey": "sk-demo-key",
  "baseUrl": "https://api.openai.com",
  "defaultModel": "gpt-4o-mini",
  "supportsEmbedding": true,
  "modelId": "gpt-4o-mini",
  "systemPrompt": null,
  "enableStreaming": true,
  "enableReasoning": false,
  "enableTools": false,
  "enableVision": false,
  "enableJsonMode": false,
  "temperature": 0.2,
  "maxTokens": 2048,
  "topP": 1.0,
  "frequencyPenalty": 0,
  "presencePenalty": 0
}

### 测试模型连接
POST {{baseUrl}}/api/v1/model-configs/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "providerType": "openai",
  "apiKey": "sk-demo-key",
  "baseUrl": "https://api.openai.com",
  "model": "gpt-4o-mini"
}

### 测试提示词流式输出（正文 + 思维链）
POST {{baseUrl}}/api/v1/model-configs/test/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
Accept: text/event-stream

{
  "providerType": "openai",
  "apiKey": "sk-demo-key",
  "baseUrl": "https://api.openai.com",
  "model": "gpt-4o-mini",
  "prompt": "请分步骤分析如何优化 SQL 查询，并给出最终建议。",
  "enableReasoning": true,
  "enableTools": true,
  "enableStreaming": true
}

### 测试提示词非流式输出
POST {{baseUrl}}/api/v1/model-configs/test/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
Accept: text/event-stream

{
  "providerType": "openai",
  "apiKey": "sk-demo-key",
  "baseUrl": "https://api.openai.com",
  "model": "gpt-4o-mini",
  "prompt": "你好，请简单介绍自己。",
  "enableReasoning": false,
  "enableTools": false,
  "enableStreaming": false
}

### 根据 ID 查询模型配置
GET {{baseUrl}}/api/v1/model-configs/{{modelConfigId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新模型配置
PUT {{baseUrl}}/api/v1/model-configs/{{modelConfigId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "OpenAI-Primary",
  "apiKey": "sk-demo-key-updated",
  "baseUrl": "https://api.openai.com",
  "defaultModel": "gpt-4o",
  "isEnabled": true,
  "supportsEmbedding": true,
  "modelId": "gpt-4o",
  "systemPrompt": "You are a helpful assistant.",
  "enableStreaming": true,
  "enableReasoning": false,
  "enableTools": true,
  "enableVision": true,
  "enableJsonMode": false,
  "temperature": 0.5,
  "maxTokens": 4096,
  "topP": 0.9,
  "frequencyPenalty": 0.1,
  "presencePenalty": 0.1
}

### 删除模型配置
DELETE {{baseUrl}}/api/v1/model-configs/{{modelConfigId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 删除模型配置（被 Agent 引用时阻断）
# 预期：返回 VALIDATION_ERROR，message 包含“被 N 个 Agent 引用，禁止删除”
DELETE {{baseUrl}}/api/v1/model-configs/{{modelConfigId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
