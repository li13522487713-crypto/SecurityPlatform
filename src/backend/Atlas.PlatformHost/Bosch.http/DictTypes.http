@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### Get CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Get DictTypes (Paged)
GET {{baseUrl}}/api/v1/dict-types?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get All Active DictTypes
GET {{baseUrl}}/api/v1/dict-types/all
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get DictType By Id
GET {{baseUrl}}/api/v1/dict-types/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create DictType
POST {{baseUrl}}/api/v1/dict-types
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: create-dict-type-001
X-CSRF-TOKEN: {{csrfToken}}

{
  "code": "sys_user_sex",
  "name": "用户性别",
  "status": true,
  "remark": "用户性别枚举"
}

### Get Dict Data (Paged)
GET {{baseUrl}}/api/v1/dict-types/sys_user_sex/data?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get Active Dict Data (for dropdown)
GET {{baseUrl}}/api/v1/dict-types/sys_user_sex/data/active
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create DictData
POST {{baseUrl}}/api/v1/dict-types/sys_user_sex/data
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: create-dict-data-001
X-CSRF-TOKEN: {{csrfToken}}

{
  "label": "男",
  "value": "0",
  "sortOrder": 0,
  "status": true,
  "cssClass": null,
  "listClass": "success"
}

### Update DictType
PUT {{baseUrl}}/api/v1/dict-types/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "用户性别（更新）",
  "status": true,
  "remark": "已更新"
}

### Delete DictType
DELETE {{baseUrl}}/api/v1/dict-types/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### Update DictData
PUT {{baseUrl}}/api/v1/dict-data/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "label": "男（更新）",
  "value": "0",
  "sortOrder": 0,
  "status": true,
  "cssClass": null,
  "listClass": "success"
}

### Delete DictData
DELETE {{baseUrl}}/api/v1/dict-data/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### Get DictData by-code (for dropdown)
GET {{baseUrl}}/api/v1/dict-data/by-code/sys_user_sex
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
