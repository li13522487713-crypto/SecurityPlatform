@baseUrl = http://localhost:5001

### 系统初始化与迁移控制台 - 二次认证（恢复密钥 / BootstrapAdmin 凭证）
# @name authenticate
POST {{baseUrl}}/api/v1/setup-console/auth/recover
Content-Type: application/json

{
  "bootstrapAdminUsername": "admin",
  "bootstrapAdminPassword": "P@ssw0rd!"
}

###
@consoleToken = {{authenticate.response.body.$.data.consoleToken}}

### 控制台 token 续期
POST {{baseUrl}}/api/v1/setup-console/auth/refresh
Content-Type: application/json

{
  "consoleToken": "{{consoleToken}}"
}

### 控制台 token 撤销（登出）
POST {{baseUrl}}/api/v1/setup-console/auth/revoke
Content-Type: application/json

{
  "consoleToken": "{{consoleToken}}"
}

### 控制台总览
GET {{baseUrl}}/api/v1/setup-console/overview
X-Setup-Console-Token: {{consoleToken}}

### 系统级状态查询
GET {{baseUrl}}/api/v1/setup-console/system/state
X-Setup-Console-Token: {{consoleToken}}

### 实体目录概览（聚合 6 大类）
GET {{baseUrl}}/api/v1/setup-console/catalog/entities
X-Setup-Console-Token: {{consoleToken}}

### 实体目录概览 - 仅业务对象类
GET {{baseUrl}}/api/v1/setup-console/catalog/entities?category=business-domain
X-Setup-Console-Token: {{consoleToken}}

### 系统初始化 - Step 1 预检查
POST {{baseUrl}}/api/v1/setup-console/system/precheck
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "expectedDbType": "SQLite"
}

### 系统初始化 - Step 2 建表（真实调用 AtlasOrmSchemaCatalog.EnsureRuntimeSchema）
POST {{baseUrl}}/api/v1/setup-console/system/schema
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "dryRun": false
}

### 系统初始化 - Step 3 写入种子（M5：仅承认现有 hostedservice 已写过；M7 完整重做）
POST {{baseUrl}}/api/v1/setup-console/system/seed
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "bundleVersion": "v1",
  "forceReapply": false
}

### 系统初始化 - Step 4 默认管理员（含一次性恢复密钥）
POST {{baseUrl}}/api/v1/setup-console/system/bootstrap-user
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "username": "admin",
  "password": "P@ssw0rd!",
  "tenantId": "00000000-0000-0000-0000-000000000001",
  "isPlatformAdmin": true,
  "optionalRoleCodes": ["SecurityAdmin", "AuditAdmin"],
  "generateRecoveryKey": true
}

### 系统初始化 - Step 5 默认工作空间
POST {{baseUrl}}/api/v1/setup-console/system/default-workspace
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "workspaceName": "Default workspace",
  "ownerUsername": "admin",
  "applyDefaultPublishChannels": true,
  "applyDefaultModelStub": true
}

### 系统初始化 - Step 6 收尾（状态机切到 completed）
POST {{baseUrl}}/api/v1/setup-console/system/complete
X-Setup-Console-Token: {{consoleToken}}

### 系统初始化 - 重试某一步
POST {{baseUrl}}/api/v1/setup-console/system/retry/schema
X-Setup-Console-Token: {{consoleToken}}

### 系统初始化 - 重新打开控制台（dismissed -> not_started）
POST {{baseUrl}}/api/v1/setup-console/system/reopen
X-Setup-Console-Token: {{consoleToken}}

### 工作空间初始化 - 列表
GET {{baseUrl}}/api/v1/setup-console/workspaces
X-Setup-Console-Token: {{consoleToken}}

### 工作空间初始化 - 初始化指定工作空间
POST {{baseUrl}}/api/v1/setup-console/workspaces/default/init
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "workspaceName": "Default workspace",
  "seedBundleVersion": "v1",
  "applyDefaultRoles": true,
  "applyDefaultPublishChannels": true
}

### 工作空间初始化 - 应用 / 升级 seed bundle
POST {{baseUrl}}/api/v1/setup-console/workspaces/default/seed-bundle
X-Setup-Console-Token: {{consoleToken}}
Content-Type: application/json

{
  "bundleVersion": "v1",
  "forceReapply": true
}

### 工作空间初始化 - 完成
POST {{baseUrl}}/api/v1/setup-console/workspaces/default/complete
X-Setup-Console-Token: {{consoleToken}}
