@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 查询在线会话
# @name sessions
GET {{baseUrl}}/api/v1/sessions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@sessionId = {{sessions.response.body.$.data.items[0].sessionId}}

### 强制下线（成功路径）
DELETE {{baseUrl}}/api/v1/sessions/{{sessionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 安全负向：缺少 Idempotency-Key（预期 400）
DELETE {{baseUrl}}/api/v1/sessions/{{sessionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}

### 安全负向：缺少认证（预期 401）
GET {{baseUrl}}/api/v1/sessions?pageIndex=1&pageSize=20
X-Tenant-Id: {{tenantId}}
