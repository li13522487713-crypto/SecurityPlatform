@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1234567890

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{ "username": "{{username}}", "password": "{{password}}" }

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 发布 hosted app
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/publish/hosted
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "kind": "hosted", "rendererMatrixJson": "{\"web\":true,\"h5\":true}" }

### 发布 embedded-sdk
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/publish/embedded-sdk
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "kind": "embedded-sdk", "rendererMatrixJson": "{\"web\":true}" }

### 发布 preview（预览，仅内部）
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/publish/preview
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "kind": "preview" }

### 列出产物
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/artifacts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 撤回产物（rollback）
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/publish/rollback
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "artifactId": "100" }
