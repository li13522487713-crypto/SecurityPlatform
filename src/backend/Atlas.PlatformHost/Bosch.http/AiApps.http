@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 应用分页
GET {{baseUrl}}/api/v1/ai-apps?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建应用
POST {{baseUrl}}/api/v1/ai-apps
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "客服助手应用",
  "description": "聚合 Agent + Workflow",
  "icon": "robot",
  "agentId": null,
  "workflowId": null,
  "promptTemplateId": null
}

### 查询应用详情
GET {{baseUrl}}/api/v1/ai-apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询 App Builder 配置
GET {{baseUrl}}/api/v1/ai-apps/{{appId}}/builder-config
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新 App Builder 配置
PUT {{baseUrl}}/api/v1/ai-apps/{{appId}}/builder-config
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "inputs": [
    {
      "id": "input-1",
      "type": "text",
      "label": "问题",
      "variableKey": "question",
      "required": true
    }
  ],
  "outputs": [
    {
      "id": "output-1",
      "type": "markdown",
      "label": "回复",
      "sourceExpression": "steps.answer.output"
    }
  ],
  "boundWorkflowId": "1",
  "layoutMode": "form"
}

### 更新应用
PUT {{baseUrl}}/api/v1/ai-apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "客服助手应用V2",
  "description": "更新后的描述",
  "icon": "robot",
  "agentId": null,
  "workflowId": null,
  "promptTemplateId": null
}

### 发布应用
POST {{baseUrl}}/api/v1/ai-apps/{{appId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "releaseNote": "首个可用版本"
}

### 版本检查
GET {{baseUrl}}/api/v1/ai-apps/{{appId}}/version-check
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 提交资源复制任务
POST {{baseUrl}}/api/v1/ai-apps/{{appId}}/resource-copy-tasks
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "sourceAppId": 2
}

### 查询资源复制任务进度
GET {{baseUrl}}/api/v1/ai-apps/{{appId}}/resource-copy-tasks/latest
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 删除应用
DELETE {{baseUrl}}/api/v1/ai-apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
