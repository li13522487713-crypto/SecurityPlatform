@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 查询消息模板
GET {{baseUrl}}/api/v1/messages/templates?pageIndex=1&pageSize=20&keyword=&sortBy=id&sortDesc=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询发送记录
GET {{baseUrl}}/api/v1/messages/records?pageIndex=1&pageSize=20&keyword=&sortBy=id&sortDesc=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询通道配置
GET {{baseUrl}}/api/v1/messages/channels
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 发送消息（成功路径）
POST {{baseUrl}}/api/v1/messages/send
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "channel": "IN_APP",
  "templateId": null,
  "recipientId": "1",
  "recipientAddress": null,
  "subject": "集成测试消息",
  "content": "这是一条来自 Messages.http 的测试消息",
  "eventType": "integration",
  "variables": {
    "source": "http-test"
  }
}

POST {{baseUrl}}/api/v1/messages/send
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "channel": "IN_APP",
  "recipientId": "1",
  "subject": "缺少幂等键",
  "content": "应该返回幂等错误"
}
