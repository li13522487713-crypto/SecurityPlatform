@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 查询知识库列表
GET {{baseUrl}}/api/v1/knowledge-bases?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建知识库
# @name createKb
POST {{baseUrl}}/api/v1/knowledge-bases
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "React Library Knowledge {{$timestamp}}",
  "description": "用于验证 React 版资源库入口",
  "type": 0
}

###
@knowledgeBaseId = {{createKb.response.body.$.data.id}}

### 获取知识库详情
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 检索测试
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/retrieval-test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "query": "平台有哪些安全能力",
  "topK": 5
}

# =====================================================================
# v5 §32-44 知识库专题扩展接口（jobs / bindings / permissions / versions /
# retrieval-logs / provider-configs / table & image views / 统一检索协议）
# =====================================================================

### 任务列表（指定 KB）
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/jobs?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 任务列表（跨 KB 全局任务中心）
GET {{baseUrl}}/api/v1/knowledge-bases/jobs?pageIndex=1&pageSize=20&status=Failed
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 重跑解析任务
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/jobs/parse
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "documentId": 1,
  "parsingStrategy": {
    "parsingType": 1,
    "extractImage": true,
    "extractTable": true,
    "imageOcr": false
  }
}

### 全量重建索引
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/jobs/rebuild-index
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{}

### 死信任务重投
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/jobs/1:retry
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 取消运行中任务
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/jobs/1:cancel
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 列出绑定关系
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/bindings?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建绑定
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/bindings
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "callerType": 0,
  "callerId": "agent_security_assistant",
  "callerName": "安全助手 Agent"
}

### 解除绑定
DELETE {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/bindings/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 列出权限
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/permissions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 授权
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "scope": 2,
  "scopeId": "{{knowledgeBaseId}}",
  "subjectType": 1,
  "subjectId": "role_security_owner",
  "subjectName": "安全负责人",
  "actions": [0, 1, 5]
}

### 撤销授权
DELETE {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/permissions/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 列出版本
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/versions?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建版本快照
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/versions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "label": "v1.0.0",
  "note": "首次发布"
}

### 发布版本
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/versions/1:release
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 回退到指定版本
POST {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/versions/1:rollback
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 版本对比
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/versions/diff?from=1&to=2
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询检索日志
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/retrieval-logs?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按 traceId 查询单条检索日志
GET {{baseUrl}}/api/v1/knowledge-bases/retrieval-logs/trc_dummy
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 统一检索（caller_context + RetrievalProfile + debug）
POST {{baseUrl}}/api/v1/knowledge-bases/retrieval
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "query": "等保 加密",
  "knowledgeBaseIds": [{{knowledgeBaseId}}],
  "topK": 5,
  "minScore": 0.0,
  "callerContext": {
    "callerType": 0,
    "callerId": "studio-debug",
    "callerName": "Studio 调试",
    "tenantId": "{{tenantId}}",
    "userId": "admin"
  },
  "debug": true,
  "retrievalProfile": {
    "topK": 5,
    "minScore": 0.0,
    "enableRerank": true,
    "enableHybrid": true,
    "enableQueryRewrite": true,
    "weights": { "vector": 0.6, "bm25": 0.4, "table": 0, "image": 0 }
  }
}

### 表格 KB：列定义
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/documents/1/table-columns
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 表格 KB：行视图
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/documents/1/table-rows?pageIndex=1&pageSize=50
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 图片 KB：项目+标注
GET {{baseUrl}}/api/v1/knowledge-bases/{{knowledgeBaseId}}/documents/1/image-items?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Provider 配置中心
GET {{baseUrl}}/api/v1/knowledge-bases/provider-configs
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
