@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 列表查询：服务监控快照
GET {{baseUrl}}/api/v1/monitor/server-info
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("服务监控查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.osDescription !== undefined, "应返回关键字段 osDescription");
  });
%}

### 列表查询：应用运行宿主快照（Phase3 可观测）
GET {{baseUrl}}/api/v1/monitor/app-runtime-hosts?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("应用运行宿主快照查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.items !== undefined, "应返回实例列表 items");
  });
%}

### 详情查询：导出等保证据包（文件流）
GET {{baseUrl}}/api/v1/monitor/compliance/evidence-package
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("证据包导出成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.headers.valueOf("content-type").includes("application/zip"), "应返回 zip 文件");
  });
%}

### 关键写操作（运维触发型请求）：导出证据包（显式携带幂等与 CSRF）
GET {{baseUrl}}/api/v1/monitor/compliance/evidence-package
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("证据包导出请求携带幂等与 CSRF 头", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.headers.valueOf("content-disposition").includes(".zip"), "应返回 zip 文件名");
  });
%}

### 错误码断言：未授权访问监控接口
GET {{baseUrl}}/api/v1/monitor/server-info
Authorization: Bearer invalid-token
X-Tenant-Id: {{tenantId}}

> {%
  client.test("未授权访问返回错误", function () {
    client.assert(response.status === 401 || response.status === 403, "状态码应为 401/403");
  });
%}
