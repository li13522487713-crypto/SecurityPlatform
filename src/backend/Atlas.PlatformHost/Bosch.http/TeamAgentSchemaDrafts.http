@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@teamAgentId = 1
@draftId = 0

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 创建 Schema Draft
# @name createDraft
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "title": "客户合同表草案",
  "requirement": "我要做客户合同管理，需要客户、合同、回款记录。",
  "conversationId": null
}

###
@draftId = {{createDraft.response.body.$.data.id}}

### 获取 Schema Draft 列表
GET {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取 Schema Draft
GET {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新 Schema Draft
PUT {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "title": "客户合同表草案（修订）",
  "requirement": "我要做客户合同管理，需要客户、合同、回款记录。",
  "schemaDraft": {
    "schemaDraft": "根据需求生成的草案，建议创建 客户表、合同表、回款表。",
    "entities": [
      {
        "tableKey": "customer_1",
        "displayName": "客户表",
        "description": "客户主数据"
      },
      {
        "tableKey": "contract_1",
        "displayName": "合同表",
        "description": "合同主表"
      }
    ],
    "fields": [
      {
        "tableKey": "customer_1",
        "name": "Id",
        "displayName": "主键",
        "fieldType": "Long",
        "allowNull": false,
        "isPrimaryKey": true,
        "isAutoIncrement": true,
        "isUnique": true,
        "sortOrder": 1
      },
      {
        "tableKey": "contract_1",
        "name": "CustomerId",
        "displayName": "客户",
        "fieldType": "Long",
        "allowNull": false,
        "isPrimaryKey": false,
        "isAutoIncrement": false,
        "isUnique": false,
        "sortOrder": 11
      }
    ],
    "relations": [
      {
        "sourceTableKey": "contract_1",
        "sourceField": "CustomerId",
        "relatedTableKey": "customer_1",
        "targetField": "Id",
        "relationType": "ManyToOne",
        "cascadeRule": "Restrict"
      }
    ],
    "indexes": [
      {
        "tableKey": "contract_1",
        "name": "UX_contract_1_ContractNo",
        "isUnique": true,
        "fields": ["ContractNo"]
      }
    ],
    "securityPolicies": [
      {
        "tableKey": "contract_1",
        "fieldName": "TenantId",
        "roleCode": "tenant_admin",
        "canView": true,
        "canEdit": false
      }
    ],
    "openQuestions": [],
    "confirmationState": "pending"
  },
  "openQuestions": []
}

### 确认并创建表
# 注意：只有当 schemaDraft.openQuestions 为空时，此请求才会成功。
# 建议先记住当前幂等键，再重复执行同一请求验证“同 key + 同 payload 返回同一结果”。
@confirmCreateKey = {{$guid}}
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/confirm-create
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "confirmed": true,
  "notes": "确认创建动态表"
}

### 重放 confirm-create（同 key + 同 payload）
# 期望：命中幂等返回同一业务结果，或在草案已确认时直接返回已持久化的创建结果。
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/confirm-create
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "confirmed": true,
  "notes": "确认创建动态表"
}

### 幂等冲突示例（同 key + 不同 payload）
# 期望：返回 409 / IDEMPOTENCY_CONFLICT。
@confirmConflictKey = {{$guid}}
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/confirm-create
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "confirmed": true,
  "notes": "第一次确认"
}

###
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/confirm-create
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "confirmed": true,
  "notes": "第二次确认，payload 不同，应触发幂等冲突"
}

### 查询 Schema Draft 执行审计
# confirm-create 成功时可看到 create_table / set_relations / set_field_permissions。
# confirm-create 失败时可看到 failed / rollback_table / rollback_failed 等审计动作。
GET {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/execution-audits
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 废弃 Schema Draft
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/schema-drafts/{{draftId}}/discard
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 失败回滚验证建议
# 1. 先创建一个故意包含错误 relation / permission 的 draft。
# 2. 调用 confirm-create，期望返回业务失败。
# 3. 再调用 execution-audits，确认存在 failed 与 rollback_table / rollback_failed 明细。
# 4. 最后到动态表接口确认未留下半成品表。
