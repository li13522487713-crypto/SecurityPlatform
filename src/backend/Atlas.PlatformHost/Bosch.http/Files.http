@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@fileId = 1
@sessionId = 1
@tusSessionId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 上传文件（按本地实际路径修改）
# @name uploadFile
POST {{baseUrl}}/api/v1/files
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.txt"
Content-Type: text/plain

hello atlas upload
--WebAppBoundary--

###
@fileId = {{uploadFile.response.body.$.data.id}}

### 秒传校验（SHA-256）
GET {{baseUrl}}/api/v1/files/instant-check?sha256=916690b31697370dc7c569ea972ebb7b45402152175aafabbb7ed2394193362b&sizeBytes=18
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 初始化分片上传会话
# @name initChunk
POST {{baseUrl}}/api/v1/files/upload/init
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "originalName": "chunked-sample.txt",
  "contentType": "text/plain",
  "totalSizeBytes": 18,
  "totalParts": 2
}

###
@sessionId = {{initChunk.response.body.$.data.sessionId}}

### 上传分片 #1
POST {{baseUrl}}/api/v1/files/upload/{{sessionId}}/part/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="part1.txt"
Content-Type: text/plain

hello
--WebAppBoundary--

### 上传分片 #2
POST {{baseUrl}}/api/v1/files/upload/{{sessionId}}/part/2
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="part2.txt"
Content-Type: text/plain

 atlas upload
--WebAppBoundary--

### 分片上传进度
GET {{baseUrl}}/api/v1/files/upload/{{sessionId}}/progress
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 完成分片上传
POST {{baseUrl}}/api/v1/files/upload/{{sessionId}}/complete
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "originalName": "chunked-sample.txt",
  "contentType": "text/plain"
}

### 图片上传申请
POST {{baseUrl}}/api/v1/files/images/apply
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "originalName": "avatar.png",
  "contentType": "image/png",
  "totalSizeBytes": 1024,
  "totalParts": 1
}

### 图片上传提交
POST {{baseUrl}}/api/v1/files/images/commit
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "sessionId": {{sessionId}},
  "originalName": "avatar.png",
  "contentType": "image/png"
}

### 查询文件元数据
GET {{baseUrl}}/api/v1/files/{{fileId}}/info
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 下载文件
GET {{baseUrl}}/api/v1/files/{{fileId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Range 下载（206）
GET {{baseUrl}}/api/v1/files/{{fileId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Range: bytes=0-4

### Tus OPTIONS 探测
OPTIONS {{baseUrl}}/api/v1/files/tus
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Tus 创建会话（从响应 Location 读取 sessionId）
# @name tusCreate
POST {{baseUrl}}/api/v1/files/tus
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Tus-Resumable: 1.0.0
Upload-Length: 14
Upload-Metadata: filename dHVzLXVwbG9hZC50eHQ=,contentType dGV4dC9wbGFpbg==

### Tus 查询会话状态（将 {{tusSessionId}} 替换为实际值）
HEAD {{baseUrl}}/api/v1/files/tus/{{tusSessionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Tus-Resumable: 1.0.0

### Tus PATCH 上传（将 {{tusSessionId}} 替换为实际值）
PATCH {{baseUrl}}/api/v1/files/tus/{{tusSessionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Tus-Resumable: 1.0.0
Upload-Offset: 0
Content-Type: application/offset+octet-stream

tus demo data!

### 获取签名下载地址
# @name signedUrl
GET {{baseUrl}}/api/v1/files/{{fileId}}/signed-url?expiresInSeconds=300
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@signedPath = {{signedUrl.response.body.$.data.url}}

### 使用签名地址下载（允许匿名）
GET {{baseUrl}}{{signedPath}}

### 删除文件
DELETE {{baseUrl}}/api/v1/files/{{fileId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### ===== 版本历史 =====

### 获取文件版本历史列表
GET {{baseUrl}}/api/v1/files/{{fileId}}/versions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### ===== 附件多态绑定 =====

### 查询指定业务实体的附件（不过滤字段槽）
GET {{baseUrl}}/api/v1/files/attachments/DynamicTable_orders/1001
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询指定业务实体 + 字段槽的附件
GET {{baseUrl}}/api/v1/files/attachments/DynamicTable_orders/1001?fieldKey=contract_scan
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 绑定附件到业务实体
POST {{baseUrl}}/api/v1/files/bind
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "fileRecordId": {{fileId}},
  "entityType": "DynamicTable_orders",
  "entityId": 1001,
  "fieldKey": "contract_scan",
  "isPrimary": true
}

### 解绑附件
DELETE {{baseUrl}}/api/v1/files/unbind
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "fileRecordId": {{fileId}},
  "entityType": "DynamicTable_orders",
  "entityId": 1001,
  "fieldKey": "contract_scan"
}

POST {{baseUrl}}/api/v1/files
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.txt"
Content-Type: text/plain

hello atlas upload
--WebAppBoundary--
