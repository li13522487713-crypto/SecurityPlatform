@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@commandId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 查询快捷命令
GET {{baseUrl}}/api/v1/ai-shortcuts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新建快捷命令
# @name createShortcut
POST {{baseUrl}}/api/v1/ai-shortcuts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "commandKey": "open-agent",
  "displayName": "打开 Agent 列表",
  "targetPath": "/ai/agents",
  "description": "进入 Agent 管理页",
  "sortOrder": 10
}

###
@commandId = {{createShortcut.response.body.$.data.id}}

### 更新快捷命令
PUT {{baseUrl}}/api/v1/ai-shortcuts/{{commandId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "displayName": "打开 Agent 工作台",
  "targetPath": "/ai/agents",
  "description": "进入 Agent 管理页",
  "sortOrder": 20,
  "isEnabled": true
}

### 查询引导弹窗
GET {{baseUrl}}/api/v1/ai-shortcuts/popup
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 设置弹窗 dismiss
POST {{baseUrl}}/api/v1/ai-shortcuts/popup/dismiss
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "popupCode": "ai-onboarding",
  "dismissed": true
}

### 删除快捷命令
DELETE {{baseUrl}}/api/v1/ai-shortcuts/{{commandId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
