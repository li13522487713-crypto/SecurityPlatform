### Tools Authorization API

@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 创建策略
# @name createPolicy
POST {{baseUrl}}/api/v1/tools/authorization-policies
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "toolId": "workflow.start",
  "toolName": "启动流程",
  "policyType": "RequireApproval",
  "rateLimitQuota": 100,
  "approvalFlowId": null,
  "conditionJson": "{}",
  "auditEnabled": true
}

###
@policyId = {{createPolicy.response.body.$.data.Id}}

### 查询策略
GET {{baseUrl}}/api/v1/tools/authorization-policies?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新策略
PUT {{baseUrl}}/api/v1/tools/authorization-policies/{{policyId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "toolId": "workflow.start",
  "toolName": "启动流程",
  "policyType": "Allow",
  "rateLimitQuota": 200,
  "approvalFlowId": null,
  "conditionJson": "{}",
  "auditEnabled": true
}

### 策略模拟
POST {{baseUrl}}/api/v1/tools/simulate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "toolId": "workflow.start",
  "userId": "10001",
  "contextJson": "{\"source\":\"ui\"}"
}

### 审计查询
GET {{baseUrl}}/api/v1/tools/audit
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
