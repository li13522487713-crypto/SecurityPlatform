@host = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001

### Login to get token
POST {{host}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

> {%
  client.global.set("token", response.body.data.accessToken);
%}

### REST Proxy - call external API
POST {{host}}/api/v1/lowcode-actions/proxy/rest
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "url": "https://httpbin.org/get",
  "method": "GET",
  "headers": {}
}

### Trigger Workflow
POST {{host}}/api/v1/lowcode-actions/trigger-workflow
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "workflowDefinitionId": "1",
  "inputData": {
    "key": "value"
  }
}

### Execute Microflow
POST {{host}}/api/v1/lowcode-actions/execute-microflow
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "microflowJson": "{\"steps\":[{\"type\":\"condition\",\"config\":{\"field\":\"amount\",\"value\":\"5000\"}},{\"type\":\"api_call\",\"config\":{\"url\":\"https://httpbin.org/post\",\"method\":\"POST\"}}]}",
  "inputData": {
    "amount": "5000",
    "reason": "Test microflow"
  }
}

### Trigger Approval Flow
POST {{host}}/api/v1/lowcode-actions/trigger-approval
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "approvalFlowDefinitionId": 1,
  "title": "Test Approval",
  "formData": {
    "amount": 5000,
    "reason": "Test from low-code designer"
  }
}
