@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@workspaceId = 2001

### Login（先执行获取 token）
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 创建应用 - 需要权限：lowcode-app:create
# @name createApp
POST {{baseUrl}}/api/v1/lowcode/apps
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "code": "demo-app-001",
  "displayName": "示例应用 001",
  "description": "M01 验证用应用",
  "targetTypes": "web",
  "defaultLocale": "zh-CN",
  "workspaceId": "{{workspaceId}}",
  "theme": {
    "primaryColor": "#1677ff",
    "borderRadius": 4,
    "darkMode": "auto"
  }
}

###
@appId = {{createApp.response.body.$.data.id}}

### 列表（默认 pageSize=20）
GET {{baseUrl}}/api/v1/lowcode/apps?pageIndex=1&pageSize=20&workspaceId={{workspaceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 列表（按状态过滤）
GET {{baseUrl}}/api/v1/lowcode/apps?status=draft&workspaceId={{workspaceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 详情
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新元数据 - 需要权限：lowcode-app:update
PUT {{baseUrl}}/api/v1/lowcode/apps/{{appId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "displayName": "示例应用 001（已改名）",
  "description": "更新后",
  "targetTypes": "web,mini_program",
  "defaultLocale": "zh-CN",
  "workspaceId": "{{workspaceId}}",
  "theme": null
}

### 获取草稿
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/draft
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 替换草稿（手动保存，schema 为 AppSchema 完整 JSON 字符串）
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/draft
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "schemaJson": "{\"schemaVersion\":\"v1\",\"appId\":\"demo-app-001\",\"pages\":[],\"variables\":[],\"contentParams\":[]}"
}

### 自动保存草稿（M04 画布去抖 30s 调用）
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/autosave
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "schemaJson": "{\"schemaVersion\":\"v1\",\"appId\":\"demo-app-001\",\"pages\":[{\"id\":\"home\",\"path\":\"/home\"}]}"
}

### 创建版本快照 - 需要权限：lowcode-app:publish
# @name snapshot
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/snapshot
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "versionLabel": "v1.0.0",
  "note": "首发版本",
  "resourceSnapshotJson": "{\"workflows\":[],\"chatflows\":[]}"
}

### 列出版本
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/versions?includeSystemSnapshot=false
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取完整 Schema 快照（含 pages + variables + contentParams）
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/schema
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 删除应用 - 需要权限：lowcode-app:delete
DELETE {{baseUrl}}/api/v1/lowcode/apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
