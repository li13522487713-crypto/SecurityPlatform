@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@teamId = 0
@teamVersionId = 1
@runId = 0
@nodeRunId = 0

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 创建运行实例
# @name createRun
POST {{baseUrl}}/api/v1/agent-team-runs
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "teamId": {{teamId}},
  "teamVersionId": {{teamVersionId}},
  "triggerType": "Manual",
  "inputPayloadJson": "{\"task\":\"agent-team-run\"}"
}

###
@runId = {{createRun.response.body.$.data.id}}

### 查询运行详情
GET {{baseUrl}}/api/v1/agent-team-runs/{{runId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询节点执行列表
GET {{baseUrl}}/api/v1/agent-team-runs/{{runId}}/nodes
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询等待介入节点
GET {{baseUrl}}/api/v1/agent-team-runs/{{runId}}/interventions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 介入节点（确认/跳过/重试/覆盖）
POST {{baseUrl}}/api/v1/agent-team-runs/{{runId}}/nodes/{{nodeRunId}}/intervene
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "action": "confirm",
  "payloadJson": "{\"operator\":\"admin\"}"
}

### 取消运行
POST {{baseUrl}}/api/v1/agent-team-runs/{{runId}}/cancel
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
