@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@teamAgentId = 1
@conversationId = 0
@executionId = 0
### 请按实际环境替换以下三个 Team Agent Id：
### groupChatTeamAgentId = GroupChat 团队
### workflowTeamAgentId = Workflow 团队
### handoffTeamAgentId = Handoff 团队
@groupChatTeamAgentId = 1
@workflowTeamAgentId = 2
@handoffTeamAgentId = 3
@groupChatConversationId = 0
@workflowConversationId = 0
@handoffConversationId = 0

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 创建团队会话
# @name createConversation
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/conversations
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "title": "客户合同管理建模"
}

###
@conversationId = {{createConversation.response.body.$.data.id}}

### 查询团队会话列表
GET {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/conversations?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 团队聊天
# @name teamChat
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/chat
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{conversationId}},
  "message": "我要做一个客户合同回款管理的数据结构，需要客户、合同、回款记录。",
  "enableRag": false,
  "generateSchemaDraft": true
}

###
@executionId = {{teamChat.response.body.$.data.executionId}}

### 获取团队执行结果
GET {{baseUrl}}/api/v1/team-agents/executions/{{executionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 团队聊天 SSE
# 手工验证基线：
# 1. 所有模式都必须先出现 orchestration.runtime.selected，再出现 conversation.started。
# 2. GroupChat 应出现 round.started -> member.message -> execution.step 的轮次型顺序。
# 3. Workflow 应以 execution.step 为主，按节点顺序推进；如启用建表可出现 schema.draft.updated。
# 4. Handoff 应体现显式交接链，execution.step 顺序应与 handoff 链一致。
# 5. 结束事件必须是 conversation.completed 或 conversation.failed 二选一。
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/chat/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Accept: text/event-stream
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{conversationId}},
  "message": "流式模式下输出团队讨论过程。",
  "enableRag": false,
  "generateSchemaDraft": false
}

### 创建 GroupChat 验证会话
# @name createGroupChatConversation
POST {{baseUrl}}/api/v1/team-agents/{{groupChatTeamAgentId}}/conversations
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "title": "GroupChat 运行时验证"
}

###
@groupChatConversationId = {{createGroupChatConversation.response.body.$.data.id}}

### GroupChat 模式 SSE 验证
# 期望顺序：
# orchestration.runtime.selected -> conversation.started -> round.started
# -> member.message -> execution.step -> schema.draft.updated(可选) -> conversation.completed|conversation.failed
POST {{baseUrl}}/api/v1/team-agents/{{groupChatTeamAgentId}}/chat/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Accept: text/event-stream
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{groupChatConversationId}},
  "message": "请用群聊模式讨论客户合同回款的数据结构。",
  "enableRag": false,
  "generateSchemaDraft": true
}

### 创建 Workflow 验证会话
# @name createWorkflowConversation
POST {{baseUrl}}/api/v1/team-agents/{{workflowTeamAgentId}}/conversations
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "title": "Workflow 运行时验证"
}

###
@workflowConversationId = {{createWorkflowConversation.response.body.$.data.id}}

### Workflow 模式 SSE 验证
# 期望顺序：
# orchestration.runtime.selected -> conversation.started
# -> execution.step(按工作流节点顺序) -> schema.draft.updated(可选) -> conversation.completed|conversation.failed
POST {{baseUrl}}/api/v1/team-agents/{{workflowTeamAgentId}}/chat/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Accept: text/event-stream
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{workflowConversationId}},
  "message": "请按工作流顺序拆解客户、合同、回款实体并输出字段建议。",
  "enableRag": false,
  "generateSchemaDraft": true
}

### 创建 Handoff 验证会话
# @name createHandoffConversation
POST {{baseUrl}}/api/v1/team-agents/{{handoffTeamAgentId}}/conversations
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "title": "Handoff 运行时验证"
}

###
@handoffConversationId = {{createHandoffConversation.response.body.$.data.id}}

### Handoff 模式 SSE 验证
# 期望顺序：
# orchestration.runtime.selected -> conversation.started
# -> execution.step(按 handoff 链路顺序) -> conversation.completed|conversation.failed
POST {{baseUrl}}/api/v1/team-agents/{{handoffTeamAgentId}}/chat/stream
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Accept: text/event-stream
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{handoffConversationId}},
  "message": "请按接力模式完成客户合同回款结构梳理。",
  "enableRag": false,
  "generateSchemaDraft": false
}

### 取消团队聊天
POST {{baseUrl}}/api/v1/team-agents/{{teamAgentId}}/chat/cancel
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "conversationId": {{conversationId}}
}

### 获取团队会话详情
GET {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取团队会话消息
GET {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}/messages?includeContextMarkers=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新团队会话标题
PUT {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "title": "客户合同管理建模会话"
}

### 清空团队会话上下文
POST {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}/clear-context
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 清空团队会话历史
POST {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}/clear-history
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 删除团队会话
DELETE {{baseUrl}}/api/v1/team-agent-conversations/{{conversationId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
