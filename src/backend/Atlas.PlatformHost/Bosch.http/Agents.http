@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@agentId = 1

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@csrfToken =

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### Agent 分页
GET {{baseUrl}}/api/v1/agents?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建 Agent
POST {{baseUrl}}/api/v1/agents
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "Demo Agent",
  "description": "用于阶段 3 验证",
  "avatarUrl": "https://example.com/avatar.png",
  "systemPrompt": "你是一个安全平台助手。",
  "personaMarkdown": "## 角色\n你是安全运营助手",
  "goals": "帮助用户排查与响应安全事件",
  "replyLogic": "先总结问题，再给出处理建议与下一步动作",
  "outputFormat": "优先使用清晰的分点结构",
  "constraints": "禁止编造不存在的数据源与执行结果",
  "openingMessage": "你好，我是你的安全运营助手。",
  "presetQuestions": [
    "帮我排查今天的高危告警",
    "给我一个安全事件处置清单"
  ],
  "temperature": 0.7,
  "maxTokens": 2048
}

### 查询 Agent 详情
GET {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新 Agent
PUT {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "Demo Agent Updated",
  "description": "更新后的描述",
  "avatarUrl": "https://example.com/avatar.png",
  "systemPrompt": "你是一个专业安全顾问。",
  "personaMarkdown": "## 角色\n你是专业安全顾问",
  "goals": "识别风险、解释影响并给出处置建议",
  "replyLogic": "先判断上下文，再输出结论与步骤",
  "outputFormat": "输出需要包含结论、依据、建议",
  "constraints": "不要输出未经确认的系统状态",
  "openingMessage": "你好，我可以协助你进行安全分析。",
  "presetQuestions": [
    "检查一下最新的攻击面",
    "给我这次事件的处置建议"
  ],
  "temperature": 0.3,
  "maxTokens": 4096,
  "knowledgeBindings": [
    {
      "knowledgeBaseId": 1001,
      "isEnabled": true,
      "invokeMode": "auto",
      "topK": 5,
      "scoreThreshold": 0.5,
      "enabledContentTypes": ["text", "table"],
      "rewriteQueryTemplate": "请结合 {{query}} 生成更适合检索的查询词"
    },
    {
      "knowledgeBaseId": 1002,
      "isEnabled": true,
      "invokeMode": "manual",
      "topK": 3,
      "scoreThreshold": 0.3,
      "enabledContentTypes": ["text", "image"]
    }
  ],
  "knowledgeBaseIds": [1001, 1002],
  "pluginBindings": [
    {
      "pluginId": 1,
      "sortOrder": 0,
      "isEnabled": true,
      "toolBindings": [
        {
          "apiId": 11,
          "isEnabled": true,
          "timeoutSeconds": 30,
          "failurePolicy": "fail",
          "parameterBindings": [
            {
              "parameterName": "assetId",
              "valueSource": "variable",
              "variableKey": "asset_id"
            },
            {
              "parameterName": "severity",
              "valueSource": "literal",
              "literalValue": "high"
            }
          ]
        }
      ]
    },
    {
      "pluginId": 2,
      "sortOrder": 1,
      "isEnabled": true,
      "toolBindings": [
        {
          "apiId": 21,
          "isEnabled": false,
          "timeoutSeconds": 60,
          "failurePolicy": "skip",
          "parameterBindings": []
        }
      ]
    }
  ],
  "databaseBindings": [
    {
      "databaseId": 3001,
      "alias": "incident_db",
      "accessMode": "readonly",
      "tableAllowlist": ["alerts", "incidents"],
      "isDefault": true
    }
  ],
  "variableBindings": [
    {
      "variableId": 4001,
      "alias": "asset_id",
      "isRequired": true,
      "defaultValueOverride": "srv-001"
    }
  ]
}

### 复制 Agent
POST {{baseUrl}}/api/v1/agents/{{agentId}}/duplicate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 发布 Agent
POST {{baseUrl}}/api/v1/agents/{{agentId}}/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 删除 Agent
DELETE {{baseUrl}}/api/v1/agents/{{agentId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}
