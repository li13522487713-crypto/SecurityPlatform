@host = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001

### 登录获取 token
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

###
@token = {{login.response.body.$.data.accessToken}}

### 分页查询规则链
GET {{host}}/api/v1/rule-chains?pageIndex=1&pageSize=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 创建规则链
# @name createRc
POST {{host}}/api/v1/rule-chains
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: rc-create-001
X-CSRF-TOKEN: test

{
  "name": "discount_rule",
  "displayName": "折扣规则链",
  "description": "根据会员等级和订单金额计算折扣",
  "stepsJson": "[{\"conditionExpression\":\"level == \\\"vip\\\" && amount > 1000\",\"outputExpression\":\"0.8\",\"priority\":1},{\"conditionExpression\":\"level == \\\"vip\\\"\",\"outputExpression\":\"0.9\",\"priority\":2},{\"conditionExpression\":\"amount > 500\",\"outputExpression\":\"0.95\",\"priority\":3}]",
  "defaultOutputExpression": "1.0",
  "sortOrder": 0
}

###
@rcId = {{createRc.response.body.$.data}}

### 查询单个规则链
GET {{host}}/api/v1/rule-chains/{{rcId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 执行规则链
POST {{host}}/api/v1/rule-chains/execute
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "chainId": {{rcId}},
  "input": { "level": "vip", "amount": 1500 }
}

### 更新规则链
PUT {{host}}/api/v1/rule-chains/{{rcId}}
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: rc-update-001
X-CSRF-TOKEN: test

{
  "id": {{rcId}},
  "name": "discount_rule",
  "displayName": "折扣规则链（已更新）",
  "description": "根据会员等级和订单金额计算折扣",
  "stepsJson": "[{\"conditionExpression\":\"level == \\\"vip\\\" && amount > 1000\",\"outputExpression\":\"0.8\",\"priority\":1},{\"conditionExpression\":\"level == \\\"vip\\\"\",\"outputExpression\":\"0.9\",\"priority\":2},{\"conditionExpression\":\"amount > 500\",\"outputExpression\":\"0.95\",\"priority\":3}]",
  "defaultOutputExpression": "1.0",
  "isEnabled": true,
  "sortOrder": 0
}

### 删除规则链
DELETE {{host}}/api/v1/rule-chains/{{rcId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: rc-delete-001
X-CSRF-TOKEN: test
