@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get Anti-Forgery Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### List Schema Drafts
GET {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Create Schema Draft (new field)
# @name createDraft
POST {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "objectType": "Field",
  "objectId": "orders__new_field",
  "objectKey": "new_field",
  "changeType": "Create",
  "afterSnapshot": "{\"name\":\"new_field\",\"fieldType\":\"String\",\"allowNull\":true}",
  "riskLevel": "Low"
}

###
@draftId = {{createDraft.response.body.$.data.id}}

### Get Schema Draft by ID
GET {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts/{{draftId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Validate Schema Draft
POST {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts/{{draftId}}/validate
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Publish Schema Drafts
POST {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts/publish
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Abandon Schema Draft
POST {{baseUrl}}/api/v1/apps/{{appId}}/schema-drafts/{{draftId}}/abandon
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
