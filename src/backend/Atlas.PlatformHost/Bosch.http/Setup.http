@platformHost = http://localhost:5001
@appHost = http://localhost:5002

### 平台 setup - 获取状态
GET {{platformHost}}/api/v1/setup/state
Accept: application/json

### 平台 setup - 获取驱动
GET {{platformHost}}/api/v1/setup/drivers
Accept: application/json

### 平台 setup - 测试 SQLite 连接（raw）
POST {{platformHost}}/api/v1/setup/test-connection
Content-Type: application/json

{
  "driverCode": "SQLite",
  "mode": "raw",
  "connectionString": "Data Source=atlas.db"
}

### 平台 setup - 测试 SQLite 连接（visual）
POST {{platformHost}}/api/v1/setup/test-connection
Content-Type: application/json

{
  "driverCode": "SQLite",
  "mode": "visual",
  "visualConfig": {
    "database": "atlas.db"
  }
}

### 平台 setup - 初始化（数据库 -> 管理员 -> 角色 -> 部门/岗位）
POST {{platformHost}}/api/v1/setup/initialize
Content-Type: application/json

{
  "database": {
    "driverCode": "SQLite",
    "mode": "raw",
    "connectionString": "Data Source=atlas.db"
  },
  "admin": {
    "tenantId": "00000000-0000-0000-0000-000000000001",
    "username": "admin",
    "password": "P@ssw0rd!"
  },
  "roles": {
    "selectedRoleCodes": [
      "SecurityAdmin",
      "AuditAdmin"
    ]
  },
  "organization": {
    "departments": [
      {
        "name": "总部",
        "code": "HQ",
        "parentCode": null,
        "sortOrder": 0
      },
      {
        "name": "研发部",
        "code": "RD",
        "parentCode": "HQ",
        "sortOrder": 10
      }
    ],
    "positions": [
      {
        "name": "系统管理员",
        "code": "SYS_ADMIN",
        "description": "系统配置与运维管理",
        "sortOrder": 10
      },
      {
        "name": "安全负责人",
        "code": "SEC_LEAD",
        "description": "安全策略与风险管理负责人",
        "sortOrder": 20
      }
    ]
  }
}

### 期望响应字段（超管强制与校验）
# data.effectiveAdminRoles 必须包含 "SuperAdmin"
# data.adminPermissionCheckPassed 应为 true
# data.adminPermissionCheckMessage 返回超管权限一致性校验结果说明

### 应用 setup - 获取状态（返回 appKey 字段）
GET {{appHost}}/api/v1/setup/state
Accept: application/json

### 应用 setup - 获取驱动
GET {{appHost}}/api/v1/setup/drivers
Accept: application/json

### 应用 setup - 测试 SQLite 连接（raw）
POST {{appHost}}/api/v1/setup/test-connection
Content-Type: application/json

{
  "database": {
    "driverCode": "SQLite",
    "mode": "raw",
    "connectionString": "Data Source=../Atlas.PlatformHost/atlas.db"
  }
}

### 应用 setup - 初始化
POST {{appHost}}/api/v1/setup/initialize
Content-Type: application/json

{
  "database": {
    "driverCode": "SQLite",
    "mode": "raw",
    "connectionString": "Data Source=../Atlas.PlatformHost/atlas.db"
  },
  "admin": {
    "appName": "Demo App",
    "adminUsername": "admin",
    "appKey": "demo-app"
  },
  "roles": {
    "selectedRoleCodes": [
      "SecurityAdmin",
      "AuditAdmin"
    ]
  },
  "organization": {
    "departments": [
      {
        "name": "总部",
        "code": "HQ",
        "parentCode": null,
        "sortOrder": 0
      },
      {
        "name": "研发部",
        "code": "RD",
        "parentCode": "HQ",
        "sortOrder": 10
      }
    ],
    "positions": [
      {
        "name": "系统管理员",
        "code": "SYS_ADMIN",
        "description": "系统配置与运维管理",
        "sortOrder": 10
      },
      {
        "name": "安全负责人",
        "code": "SEC_LEAD",
        "description": "安全策略与风险管理负责人",
        "sortOrder": 20
      }
    ]
  }
}
