@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appId = 1234567890

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{ "username": "{{username}}", "password": "{{password}}" }

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 列出页面
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建页面
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/pages
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "code": "home", "displayName": "首页", "path": "/home", "targetType": "web", "layout": "free" }

### 替换页面 schema
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/pages/1/schema
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "schemaJson": "{\"id\":\"home\",\"root\":{\"id\":\"root\",\"type\":\"Container\"}}" }

### 批量排序
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/pages/reorder
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "items": [{ "id": "1", "orderNo": 0 }, { "id": "2", "orderNo": 1 }] }

### 列出变量（按 scope 过滤）
GET {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/variables?scope=app
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建变量
POST {{baseUrl}}/api/v1/lowcode/apps/{{appId}}/variables
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "code": "currentUser",
  "displayName": "当前用户",
  "scope": "app",
  "valueType": "object",
  "isPersisted": true,
  "defaultValueJson": "{\"name\":\"\"}",
  "validationJson": null,
  "description": "全局当前用户对象"
}
