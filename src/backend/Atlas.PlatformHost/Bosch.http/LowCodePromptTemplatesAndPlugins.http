@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{ "username": "{{username}}", "password": "{{password}}" }

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 插件：搜索
GET {{baseUrl}}/api/v1/lowcode/plugins?keyword=&shareScope=public
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 插件：创建（OpenAPI 风格 toolsJson）
# @name createPlugin
POST {{baseUrl}}/api/v1/lowcode/plugins
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "name": "天气查询插件",
  "description": "查询全球城市天气",
  "toolsJson": "[{\"name\":\"getWeather\",\"args\":{\"city\":\"string\"}}]",
  "shareScope": "team"
}

###
@pluginDefId = {{createPlugin.response.body.$.data.id}}

### 插件：发布版本
POST {{baseUrl}}/api/v1/lowcode/plugins/{{pluginDefId}}/publish
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "version": "1.0.1" }

### 插件：授权
POST {{baseUrl}}/api/v1/lowcode/plugins/plg_demo/authorize
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{ "authKind": "api_key", "credential": "sk-demo-1234" }

### 插件：使用计量
GET {{baseUrl}}/api/v1/lowcode/plugins/plg_demo/usage?day=2026-04-17
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
