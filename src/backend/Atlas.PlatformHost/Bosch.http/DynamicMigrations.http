@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@tableKey = orders

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 列表查询：迁移记录列表
# @name listMigrations
GET {{baseUrl}}/api/v1/dynamic-migrations?pageIndex=1&pageSize=20&tableKey={{tableKey}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("迁移列表查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.items !== undefined, "应返回 items 字段");
  });
%}

### 详情查询：迁移记录详情
GET {{baseUrl}}/api/v1/dynamic-migrations/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("迁移详情查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.code === "Success", "code 应为 Success");
    client.assert(response.body.data === null || response.body.data.id !== undefined, "应返回 null 或包含 id 的详情");
  });
%}

### 关键写操作：创建迁移记录
POST {{baseUrl}}/api/v1/dynamic-migrations
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "tableKey": "{{tableKey}}",
  "version": {{$timestamp}},
  "upScript": "ALTER TABLE atlas_dt_orders ADD COLUMN ext_note TEXT NULL;",
  "downScript": "ALTER TABLE atlas_dt_orders DROP COLUMN ext_note;",
  "isDestructive": false
}

> {%
  client.test("创建迁移记录成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.id, "应返回 data.id");
  });
%}

### 错误码断言：非法版本号创建迁移记录
POST {{baseUrl}}/api/v1/dynamic-migrations
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "tableKey": "{{tableKey}}",
  "version": 0,
  "upScript": "",
  "downScript": null,
  "isDestructive": false
}

> {%
  client.test("非法迁移参数返回错误码", function () {
    client.assert(response.status >= 400, "状态码应为 4xx/5xx");
    client.assert(response.body.success === false, "success 应为 false");
    client.assert(response.body.code && response.body.code !== "Success", "应返回业务错误码");
  });
%}
