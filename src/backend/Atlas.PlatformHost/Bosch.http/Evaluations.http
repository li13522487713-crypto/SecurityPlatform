@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@agentId = 1
@datasetId = 0
@taskId = 0
@taskId2 = 0

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 创建评测数据集
# @name createDataset
POST {{baseUrl}}/api/v1/evaluations/datasets
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "弱口令整改评测集",
  "description": "验证 Agent 对弱口令整改建议输出质量",
  "scene": "Security-Audit"
}

###
@datasetId = {{createDataset.response.body.$.data.id}}

### 向数据集新增评测用例
POST {{baseUrl}}/api/v1/evaluations/datasets/{{datasetId}}/cases
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "input": "请给出弱口令排查与整改执行步骤",
  "expectedOutput": "整改",
  "referenceOutput": "先识别弱口令资产，再分批重置并复核策略",
  "tags": ["weak-password", "remediation"]
}

### 查询数据集列表
GET {{baseUrl}}/api/v1/evaluations/datasets?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询数据集用例
GET {{baseUrl}}/api/v1/evaluations/datasets/{{datasetId}}/cases
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建评测任务（异步 Hangfire）
# @name createTask
POST {{baseUrl}}/api/v1/evaluations/tasks
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "弱口令整改-模型A",
  "datasetId": {{datasetId}},
  "agentId": {{agentId}}
}

###
@taskId = {{createTask.response.body.$.data.id}}

### 再创建一个任务用于对比
# @name createTask2
POST {{baseUrl}}/api/v1/evaluations/tasks
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "弱口令整改-模型B",
  "datasetId": {{datasetId}},
  "agentId": {{agentId}}
}

###
@taskId2 = {{createTask2.response.body.$.data.id}}

### 查询评测任务列表
GET {{baseUrl}}/api/v1/evaluations/tasks?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询单个任务详情
GET {{baseUrl}}/api/v1/evaluations/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询任务结果
GET {{baseUrl}}/api/v1/evaluations/tasks/{{taskId}}/results
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 对比两个任务分数
GET {{baseUrl}}/api/v1/evaluations/comparisons?leftTaskId={{taskId}}&rightTaskId={{taskId2}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
