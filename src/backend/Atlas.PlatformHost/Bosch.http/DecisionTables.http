@host = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001

### 登录获取 token
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

###
@token = {{login.response.body.$.data.accessToken}}

### 分页查询决策表
GET {{host}}/api/v1/decision-tables?pageIndex=1&pageSize=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 创建决策表
# @name createDt
POST {{host}}/api/v1/decision-tables
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: dt-create-001
X-CSRF-TOKEN: test

{
  "name": "age_risk_level",
  "displayName": "年龄风险等级",
  "description": "根据年龄判断风险等级",
  "hitPolicy": 1,
  "inputColumnsJson": "[{\"name\":\"age\",\"type\":2}]",
  "outputColumnsJson": "[{\"name\":\"riskLevel\",\"type\":6}]",
  "rowsJson": "[{\"priority\":1,\"inputEntries\":[\"< 18\"],\"outputEntries\":[\"\\\"low\\\"\"]},{\"priority\":2,\"inputEntries\":[\"< 60\"],\"outputEntries\":[\"\\\"medium\\\"\"]},{\"priority\":3,\"inputEntries\":[\">= 60\"],\"outputEntries\":[\"\\\"high\\\"\"]}]",
  "sortOrder": 0
}

###
@dtId = {{createDt.response.body.$.data}}

### 查询单个决策表
GET {{host}}/api/v1/decision-tables/{{dtId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 执行决策表
POST {{host}}/api/v1/decision-tables/execute
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "tableId": {{dtId}},
  "input": { "age": 25 }
}

### 更新决策表
PUT {{host}}/api/v1/decision-tables/{{dtId}}
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: dt-update-001
X-CSRF-TOKEN: test

{
  "id": {{dtId}},
  "name": "age_risk_level",
  "displayName": "年龄风险等级（已更新）",
  "description": "根据年龄判断风险等级",
  "hitPolicy": 1,
  "inputColumnsJson": "[{\"name\":\"age\",\"type\":2}]",
  "outputColumnsJson": "[{\"name\":\"riskLevel\",\"type\":6}]",
  "rowsJson": "[{\"priority\":1,\"inputEntries\":[\"< 18\"],\"outputEntries\":[\"\\\"low\\\"\"]},{\"priority\":2,\"inputEntries\":[\"< 60\"],\"outputEntries\":[\"\\\"medium\\\"\"]},{\"priority\":3,\"inputEntries\":[\">= 60\"],\"outputEntries\":[\"\\\"high\\\"\"]}]",
  "isEnabled": true,
  "sortOrder": 0
}

### 删除决策表
DELETE {{host}}/api/v1/decision-tables/{{dtId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: dt-delete-001
X-CSRF-TOKEN: test
