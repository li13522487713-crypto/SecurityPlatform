@baseUrl = http://localhost:5001
@tenantId = 00000000-0000-0000-0000-000000000001
@workspaceId = atlas-space
@username = admin
@password = P@ssw0rd!

# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 任务列表
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/tasks?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 任务列表 - 状态筛选（pending/running/succeeded/failed）
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/tasks?status=running&pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 任务详情
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/tasks/task-1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
