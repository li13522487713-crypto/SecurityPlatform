@host = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001

### 登录获取 token
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

###
@token = {{login.response.body.$.data.accessToken}}

### 查询内置节点注册表（全部）
GET {{host}}/api/v1/node-types/registry
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 按分类查询注册表（触发类）
GET {{host}}/api/v1/node-types/registry?category=0
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 按分类查询注册表（数据读取类）
GET {{host}}/api/v1/node-types/registry?category=1
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 按分类查询注册表（控制流类）
GET {{host}}/api/v1/node-types/registry?category=3
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 查询节点类型分类列表
GET {{host}}/api/v1/node-types/categories
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 分页查询节点类型定义
GET {{host}}/api/v1/node-types?pageIndex=1&pageSize=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 按分类过滤查询
GET {{host}}/api/v1/node-types?pageIndex=1&pageSize=20&category=0
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 创建自定义节点类型
# @name createNodeType
POST {{host}}/api/v1/node-types
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: nt-create-001
X-CSRF-TOKEN: test

{
  "typeKey": "custom.my_processor",
  "category": 2,
  "displayName": "自定义处理器",
  "description": "自定义数据处理节点",
  "ports": [
    {
      "portKey": "in",
      "displayName": "输入",
      "direction": 0,
      "portType": 1,
      "dataType": 5,
      "isRequired": true,
      "maxConnections": 1
    },
    {
      "portKey": "out",
      "displayName": "输出",
      "direction": 1,
      "portType": 1,
      "dataType": 5,
      "isRequired": false,
      "maxConnections": 1
    }
  ],
  "capabilities": {
    "supportsRetry": true,
    "supportsTimeout": true,
    "supportsBreakpoint": true,
    "maxInputPorts": 1,
    "maxOutputPorts": 1
  },
  "uiMetadata": {
    "shape": "rectangle",
    "icon": "ToolOutlined",
    "color": "#722ed1"
  }
}

###
@nodeTypeId = {{createNodeType.response.body.$.data.id}}

### 查询单个节点类型
GET {{host}}/api/v1/node-types/{{nodeTypeId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 按 TypeKey 查询
GET {{host}}/api/v1/node-types/by-key/custom.my_processor
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 更新自定义节点类型
PUT {{host}}/api/v1/node-types/{{nodeTypeId}}
Content-Type: application/json
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: nt-update-001
X-CSRF-TOKEN: test

{
  "displayName": "自定义处理器（已更新）",
  "description": "更新后的自定义数据处理节点",
  "ports": [
    {
      "portKey": "in",
      "displayName": "输入",
      "direction": 0,
      "portType": 1,
      "dataType": 5,
      "isRequired": true,
      "maxConnections": 1
    },
    {
      "portKey": "out",
      "displayName": "输出",
      "direction": 1,
      "portType": 1,
      "dataType": 5,
      "isRequired": false,
      "maxConnections": 3
    }
  ]
}

### 删除自定义节点类型
DELETE {{host}}/api/v1/node-types/{{nodeTypeId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: nt-delete-001
X-CSRF-TOKEN: test
