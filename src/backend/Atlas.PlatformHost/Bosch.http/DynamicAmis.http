@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@tableKey = orders

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
  client.test("登录成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.data.accessToken, "应返回 accessToken");
    client.assert(response.body.code === "Success", "code 应为 Success");
  });
%}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 列表查询：AMIS 动态表列表 Schema
GET {{baseUrl}}/api/v1/amis/dynamic-tables/list
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("AMIS 列表 Schema 查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.type === "page", "data.type 应为 page");
  });
%}

### 详情查询：AMIS 详情表单 Schema
GET {{baseUrl}}/api/v1/amis/dynamic-tables/{{tableKey}}/forms/detail?id=1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("AMIS 详情 Schema 查询成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.code === "Success", "code 应为 Success");
    client.assert(response.body.data.type, "应返回 schema type 字段");
  });
%}

### 关键写操作：通过动态表接口创建记录（AMIS 表单目标写接口）
POST {{baseUrl}}/api/v1/dynamic-tables/{{tableKey}}/records
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$randomUUID}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "values": [
    { "field": "orderNo", "valueType": "String", "stringValue": "AMIS-{{$timestamp}}" },
    { "field": "amount", "valueType": "Decimal", "decimalValue": 88.8 }
  ]
}

> {%
  client.test("AMIS 目标写接口创建成功", function () {
    client.assert(response.status === 200, "状态码应为 200");
    client.assert(response.body.success === true, "success 应为 true");
    client.assert(response.body.data.id, "应返回 data.id");
  });
%}

### 错误码断言：查询不存在表的 CRUD Schema
GET {{baseUrl}}/api/v1/amis/dynamic-tables/not_exists_table/crud
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

> {%
  client.test("不存在动态表返回错误码", function () {
    client.assert(response.status >= 400, "状态码应为 4xx/5xx");
    client.assert(response.body.success === false, "success 应为 false");
    client.assert(response.body.code && response.body.code !== "Success", "应返回业务错误码");
  });
%}
