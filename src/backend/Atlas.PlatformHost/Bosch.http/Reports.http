@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 查询报表列表
GET {{baseUrl}}/api/v1/reports?pageIndex=1&pageSize=20&keyword=&sortBy=id&sortDesc=true
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建报表定义
# @name createReport
POST {{baseUrl}}/api/v1/reports
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "集成测试报表",
  "description": "Reports.http 自动化样例",
  "category": "security",
  "configJson": "{\"type\":\"table\",\"columns\":[]}",
  "dataSourceJson": "{\"source\":\"assets\"}"
}

###
@reportId = {{createReport.response.body.$.data.id}}

### 查询报表详情
GET {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新报表
PUT {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "集成测试报表-更新",
  "description": "更新描述",
  "category": "security",
  "configJson": "{\"type\":\"table\",\"columns\":[{\"key\":\"name\"}]}",
  "dataSourceJson": "{\"source\":\"assets\"}",
  "printTemplateJson": null
}

### 删除报表
DELETE {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

DELETE {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
