POST {{host}}/api/workflow_api/validate_tree
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "schema": "{\"nodes\":[],\"connections\":[]}"
}

