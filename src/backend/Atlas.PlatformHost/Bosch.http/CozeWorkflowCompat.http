@host = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@contentType = application/json

### 登录
# @name login
POST {{host}}/api/v1/auth/token
Content-Type: {{contentType}}
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

###
@token = {{login.response.body.data.accessToken}}
@workflowId = 1
@executionId = 1

### 原生 Coze 兼容：获取画布
POST {{host}}/api/workflow_api/canvas
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：保存草稿
POST {{host}}/api/workflow_api/save
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow",
  "schema": "{\"nodes\":[],\"connections\":[]}",
  "submit_commit_id": "coze-compat-draft"
}

### 原生 Coze 兼容：试运行
POST {{host}}/api/workflow_api/test_run
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow",
  "input": {
    "incident": "compat smoke"
  }
}

### 原生 Coze 兼容：查询运行结果
GET {{host}}/api/workflow_api/get_process?workflow_id={{workflowId}}&execute_id={{executionId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze 兼容：节点模板列表
POST {{host}}/api/workflow_api/node_template_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "node_types": ["Entry", "Exit", "Llm"]
}

### 原生 Coze Playground 兼容：空间列表
POST {{host}}/api/playground_api/space/list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{}

### 原生 Coze Bot 兼容：模型类型列表
POST {{host}}/api/bot/get_type_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "model_scene": 1
}

### 原生 Coze 兼容：创建工作流（P0）
POST {{host}}/api/workflow_api/create
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "name": "CozeCompat Smoke Workflow",
  "desc": "compat smoke",
  "space_id": "atlas-workflow",
  "flow_mode": 0
}

### 原生 Coze 兼容：提交草稿（P0）
POST {{host}}/api/workflow_api/submit
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：检查最新版本（P0）
POST {{host}}/api/workflow_api/latest
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：工作流列表（P0）
POST {{host}}/api/workflow_api/workflow_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "page": 1,
  "size": 10,
  "name": "",
  "flow_mode": 0,
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：工作流详情（P0）
POST {{host}}/api/workflow_api/workflow_detail
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_ids": ["{{workflowId}}"],
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：版本列表（P0）
POST {{host}}/api/workflow_api/version_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow",
  "page": 1,
  "size": 20
}

