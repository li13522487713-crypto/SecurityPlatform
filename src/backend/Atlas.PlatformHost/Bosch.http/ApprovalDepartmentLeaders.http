@baseUrl = http://localhost:5000
@token =
@tenantId =

### 设置部门负责人
POST {{baseUrl}}/api/v1/approval/department-leaders
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "departmentId": 1,
  "leaderUserId": 100
}

### 获取部门负责人
GET {{baseUrl}}/api/v1/approval/department-leaders/1
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 移除部门负责人
DELETE {{baseUrl}}/api/v1/approval/department-leaders/1
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

