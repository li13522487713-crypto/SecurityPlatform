@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### Login to get token (Execute this first)
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### Get CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### Get SystemConfigs (Paged)
GET {{baseUrl}}/api/v1/system-configs?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get SystemConfig by Key (platform)
GET {{baseUrl}}/api/v1/system-configs/by-key/FileStorage:BasePath
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Get SystemConfig by Key (app override with fallback)
GET {{baseUrl}}/api/v1/system-configs/by-key/FileStorage:BasePath?appId=1001
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Query SystemConfigs by Group/App/Keys
GET {{baseUrl}}/api/v1/system-configs/query?groupName=FileStorage&appId=1001&keys=FileStorage:BasePath,FileStorage:Minio:BucketName
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Create SystemConfig
POST {{baseUrl}}/api/v1/system-configs
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "configKey": "FileStorage:BasePath",
  "configValue": "/uploads",
  "configName": "本地存储根目录",
  "configType": "Text",
  "groupName": "FileStorage",
  "isEncrypted": false,
  "remark": "平台默认目录"
}

### Update SystemConfig
PUT {{baseUrl}}/api/v1/system-configs/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "configValue": "/uploads/v2",
  "configName": "本地存储根目录",
  "groupName": "FileStorage",
  "isEncrypted": false,
  "version": 1,
  "remark": "更新为 v2 路径"
}

### Batch Upsert SystemConfigs (single request per group/app)
POST {{baseUrl}}/api/v1/system-configs/batch-upsert
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

{
  "appId": "1001",
  "groupName": "FileStorage",
  "items": [
    {
      "configKey": "FileStorage:BasePath",
      "configValue": "uploads/app-1001",
      "configName": "应用级本地存储根目录",
      "configType": "Text",
      "groupName": "FileStorage",
      "isEncrypted": false
    },
    {
      "configKey": "FileStorage:Minio:BucketName",
      "configValue": "atlas-app-1001",
      "configName": "应用级 MinIO Bucket",
      "configType": "Text",
      "groupName": "FileStorage",
      "isEncrypted": false
    }
  ]
}

### Get Feature Flags
GET {{baseUrl}}/api/v1/system-configs/feature-flags
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Delete app-level override by id (example id from query result)
DELETE {{baseUrl}}/api/v1/system-configs/1000001
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Delete SystemConfig (built-in returns 403)
DELETE {{baseUrl}}/api/v1/system-configs/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### Delete SystemConfig by ID (custom key sample)
DELETE {{baseUrl}}/api/v1/system-configs/2
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
