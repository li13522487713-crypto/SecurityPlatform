### AppBridge V2 API

@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appInstanceId = 1
@idempotencyCreate = {{$guid}}
@idempotencyConflict = {{$guid}}

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 在线应用列表
GET {{baseUrl}}/api/v2/appbridge/online-apps?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 在线应用详情
GET {{baseUrl}}/api/v2/appbridge/online-apps/{{appInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 获取暴露策略
GET {{baseUrl}}/api/v2/appbridge/apps/{{appInstanceId}}/exposure-policy
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新暴露策略
PUT {{baseUrl}}/api/v2/appbridge/apps/{{appInstanceId}}/exposure-policy
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "exposedDataSets": ["users", "departments"],
  "allowedCommands": ["organization.sync-structure", "runtime.restart", "release.activate"],
  "maskPolicies": {
    "users": ["email", "phoneNumber"]
  }
}

### 创建命令（本地执行 + dry-run diff）
# @name createCommandDryRun
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "organization.sync-structure",
  "payloadJson": "{\"force\":true}",
  "dryRun": true
}

###
@commandId = {{createCommandDryRun.response.body.$.data.id}}

### 幂等重放（同 key + 同 payload，应返回同一个 commandId）
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "organization.sync-structure",
  "payloadJson": "{\"force\":true}",
  "dryRun": true
}

### 幂等冲突（同 key + 不同 payload，应返回冲突）
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "organization.sync-structure",
  "payloadJson": "{\"force\":true}",
  "dryRun": true
}

###
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "organization.sync-structure",
  "payloadJson": "{\"force\":false}",
  "dryRun": true
}

### 查询命令列表
GET {{baseUrl}}/api/v2/appbridge/commands?pageIndex=1&pageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询命令详情
GET {{baseUrl}}/api/v2/appbridge/commands/{{commandId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建高风险命令（需要 reason，进入审批等待）
# @name createHighRiskCommand
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "release.activate",
  "payloadJson": "{\"releaseVersion\":\"2026.04.09\"}",
  "dryRun": false,
  "reason": "生产发布窗口变更"
}

### 查询暴露数据
POST {{baseUrl}}/api/v2/appbridge/apps/{{appInstanceId}}/exposed-data/query
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "dataSet": "users",
  "paged": {
    "pageIndex": 1,
    "pageSize": 10,
    "keyword": "",
    "sortBy": "",
    "sortDesc": false
  }
}

### 联邦注册
POST {{baseUrl}}/api/v2/appbridge/federated/register
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "appKey": "demo",
  "runtimeStatus": "running",
  "healthStatus": "Healthy",
  "releaseVersion": "1.0.0",
  "bridgeEndpoint": "https://federated.demo/bridge",
  "supportedCommands": ["organization.sync-structure", "runtime.restart", "release.activate"]
}

### 联邦心跳
POST {{baseUrl}}/api/v2/appbridge/federated/heartbeat
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "appKey": "demo",
  "runtimeStatus": "running",
  "healthStatus": "Healthy",
  "releaseVersion": "1.0.1",
  "bridgeEndpoint": "https://federated.demo/bridge",
  "supportedCommands": ["organization.sync-structure", "runtime.restart", "release.activate"]
}

### 创建联邦命令（等待联邦 pull）
# @name createFederatedCommand
POST {{baseUrl}}/api/v2/appbridge/commands
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appInstanceId": "{{appInstanceId}}",
  "commandType": "runtime.restart",
  "payloadJson": "{\"restartWindow\":\"00:00:05\"}",
  "dryRun": false
}

###
@federatedCommandId = {{createFederatedCommand.response.body.$.data.id}}

### 联邦拉取待执行命令（应包含 federatedCommandId）
GET {{baseUrl}}/api/v2/appbridge/federated/commands/pending?appInstanceId={{appInstanceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 联邦命令 Ack
POST {{baseUrl}}/api/v2/appbridge/federated/commands/{{federatedCommandId}}/ack
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "message": "accepted"
}

### 联邦命令结果回写
POST {{baseUrl}}/api/v2/appbridge/federated/commands/{{federatedCommandId}}/result
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "status": "succeeded",
  "resultJson": "{\"synced\":42}",
  "message": "done"
}
