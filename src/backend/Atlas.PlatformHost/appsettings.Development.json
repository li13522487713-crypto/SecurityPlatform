{
  "Jwt": {
    "SigningKey": "DEV_ONLY_CHANGE_ME_TO_A_LONG_RANDOM_SECRET",
    "ExpiresMinutes": 15,
    "RefreshExpiresMinutes": 720,
    "SessionExpiresMinutes": 720
  },
  "IdGenerator": {
    "DefaultAppId": "SecurityPlatform",
    "FallbackGeneratorId": 1,
    "Mappings": [
      {
        "TenantId": "00000000-0000-0000-0000-000000000001",
        "AppId": "SecurityPlatform",
        "GeneratorId": 1
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5180",
      "http://localhost:5181",
      "http://localhost:5182",
      "http://127.0.0.1:5180",
      "http://127.0.0.1:5181",
      "http://127.0.0.1:5182"
    ]
  },
  "Atlas": {
    "Runtime": {
      "InstanceRoot": "runtime/instances",
      "ArtifactRoot": "runtime/artifacts",
      "AppHostProject": "src/backend/Atlas.AppHost/Atlas.AppHost.csproj",
      "SupervisorEnabled": true,
      "AppHostBaseUrl": "http://localhost:5002"
    }
  },
  "Security": {
    "EnforceHttps": false,
    "BootstrapAdmin": {
      "Password": "P@ssw0rd!",
      "IsPlatformAdmin": true
    }
  },
  "HybridCache": {
    "Redis": {
      "Enabled": false,
      "Configuration": "",
      "InstanceName": "atlas:dev:"
    },
    "FallbackToLocalWhenRedisUnavailable": true
  },
  "FileStorage": {
    "Provider": "local",
    "ChunkPartSizeBytes": 2097152,
    "ChunkSessionExpireMinutes": 120,
    "SignedUrlDefaultExpireSeconds": 600,
    "SignedUrlSecret": "DEV_FILE_SIGN_SECRET",
    "Minio": {
      "Endpoint": "http://127.0.0.1:9000",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "atlas-files-dev",
      "UseSsl": false,
      "ForcePathStyle": true
    },
    "Oss": {
      "Endpoint": "https://oss-cn-hangzhou.aliyuncs.com",
      "AccessKeyId": "",
      "AccessKeySecret": "",
      "BucketName": "atlas-files-dev",
      "Region": "cn-hangzhou",
      "ForcePathStyle": false
    }
  },
  "App": {
    "HeaderName": "X-App-Id",
    "DefaultAppId": "SecurityPlatform",
    "AllowHeaderOverrideWhenAuthenticated": true,
    "RequireWorkspaceHeaderForAuthenticatedOverride": true,
    "WorkspaceHeaderName": "X-App-Workspace",
    "WorkspaceHeaderValue": "1",
    "RequireHeaderAppIdNumeric": true,
    "ClientTypeMappings": [
      {
        "ClientType": "WebH5",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Mobile",
        "AppId": "SecurityPlatform"
      },
      {
        "ClientType": "Backend",
        "AppId": "SecurityPlatform"
      }
    ]
  },
  "TableViewDefaults": {
    "Fallback": {
      "density": "default",
      "pagination": {
        "pageSize": 10
      }
    },
    "Defaults": {
      "system.users": {
        "density": "default",
        "pagination": {
          "pageSize": 10
        }
      }
    }
  },
  "AiPlatform": {
    "DefaultProvider": "ollama",
    "Providers": {
      "openai": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com",
        "DefaultModel": "gpt-4o-mini",
        "SupportsEmbedding": true
      },
      "deepseek": {
        "ApiKey": "",
        "BaseUrl": "https://api.deepseek.com",
        "DefaultModel": "deepseek-chat",
        "SupportsEmbedding": true
      },
      "ollama": {
        "ApiKey": "",
        "BaseUrl": "http://localhost:11434",
        "DefaultModel": "llama3",
        "SupportsEmbedding": false
      }
    },
    "Embedding": {
      "Provider": "openai",
      "Model": "text-embedding-3-small",
      "Dimensions": 1536
    },
    "VectorDb": {
      "Provider": "sqlite",
      "SqliteConnectionString": "",
      "QdrantUrl": "http://localhost:6333",
      "QdrantApiKey": ""
    },
    "Retrieval": {
      "EnableHybrid": true,
      "EnableRerank": true,
      "VectorTopK": 12,
      "Bm25TopK": 12,
      "Bm25CandidateCount": 300,
      "RrfK": 60
    },
    "Memory": {
      "Enabled": true,
      "ShortTermTriggerMessageCount": 4,
      "ShortTermReserveRecentMessages": 2,
      "ShortTermMinIncrementalMessages": 2,
      "ShortTermMaxSummaryLength": 1200,
      "LongTermRecallTopK": 3,
      "LongTermCandidateCount": 30,
      "LongTermMaxRecordsPerUserAgent": 200
    },
    "Publication": {
      "EmbedTokenTtlHours": 720
    },
    "OpenApiProject": {
      "AccessTokenExpiresMinutes": 120
    },
    "OpenApiGovernance": {
      "ProjectRateLimitPerMinute": 60
    }
  },
  "AgentFramework": {
    "Enabled": true,
    "PreferredRuntime": "auto",
    "EmitRuntimeSelectionEvent": true,
    "PreferSemanticKernelForGroupChat": true,
    "PreferMicrosoftAgentFrameworkForWorkflow": true,
    "PreferMicrosoftAgentFrameworkForHandoff": true,
    "GroupChatMaximumRounds": 6,
    "Packages": {
      "SemanticKernelOrchestration": {
        "PackageId": "Microsoft.SemanticKernel.Agents.Orchestration",
        "Version": "1.74.0-preview"
      },
      "MicrosoftAgentFrameworkCore": {
        "PackageId": "Microsoft.Agents.AI",
        "Version": "1.0.0-rc4"
      },
      "MicrosoftAgentFrameworkOpenAi": {
        "PackageId": "Microsoft.Agents.AI.OpenAI",
        "Version": "1.0.0-rc4"
      },
      "MicrosoftAgentFrameworkWorkflows": {
        "PackageId": "Microsoft.Agents.AI.Workflows",
        "Version": "1.0.0-rc4"
      }
    }
  },
  "CodeExecution": {
    "Mode": "Sandbox",
    "TimeoutSeconds": 8,
    "MaxOutputLength": 8000,
    "BlockedModules": [
      "os",
      "subprocess",
      "sys"
    ]
  },
  "DatabaseInitializer": {
    "_comment": "开发环境：开启种子数据播种以确保首次启动有菜单/角色/管理员。Schema 迁移检查按需启用。",
    "SkipSchemaInit": false,
    "SkipSeedData": false,
    "SkipSchemaMigrations": true
  },
  "OpenTelemetry": {
    "_comment": "开发环境默认关闭 Console Exporter，避免大量 I/O 拖慢响应。如需调试遥测数据，可临时改为 true。",
    "EnableConsoleExporter": false
  },
  "AutoMapper": {
    "ValidateOnStartup": false
  },
  "Hangfire": {
    "RunServer": false,
    "WorkerCount": 1,
    "QueuePollIntervalSeconds": 30,
    "SchedulePollingIntervalSeconds": 60,
    "JobExpirationCheckIntervalMinutes": 360
  },
  "ExternalConnectors": {
    "_comment": "开发环境默认密钥；生产请通过环境变量 ExternalConnectors__DataProtectionKey 注入。",
    "DataProtectionKey": "DEV_ONLY_EXTERNAL_CONNECTORS_KEY_CHANGE_AT_LEAST_32_CHARS"
  },
  "License": {
    "DevMode": {
      "_comment": "调试模式：开启后跳过证书上传，直接视为已激活的 Enterprise 永久授权。仅限开发/测试环境使用，生产环境必须保持 Enabled=false。",
      "Enabled": true,
      "TenantId": "00000000-0000-0000-0000-000000000001",
      "Edition": "Enterprise",
      "CustomerName": "开发调试环境（DevMode）"
    }
  }
}
