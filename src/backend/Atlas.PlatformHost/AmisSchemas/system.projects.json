{
  "key": "system.projects",
  "title": "\u9879\u76ee\u7ba1\u7406",
  "description": "AMIS \u9875\u9762\u63d0\u4f9b\u9879\u76ee\u7684\u5206\u7ec4\u3001\u72b6\u6001\u4e0e\u591a\u79df\u6237\u53ef\u89c1\u6027",
  "tableKey": "system.projects",
  "schema": {
    "type": "page",
    "title": "\u9879\u76ee\u7ba1\u7406",
    "body": [
      {
        "type": "crud",
        "name": "projects-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/projects?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "\u5173\u952e\u5b57",
            "placeholder": "\u540d\u79f0/\u7f16\u7801",
            "clearable": true
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "\u65b0\u589e\u9879\u76ee",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "\u65b0\u589e\u9879\u76ee",
              "body": {
                "type": "form",
                "api": {
                  "url": "/projects",
                  "method": "post",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u4fdd\u5b58\u5b8c\u6210', data: payload?.data };"
                },
                "body": [
                  {
                    "type": "input-text",
                    "name": "code",
                    "label": "\u9879\u76ee\u7f16\u7801",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "name",
                    "label": "\u9879\u76ee\u540d\u79f0",
                    "required": true
                  },
                  {
                    "type": "textarea",
                    "name": "description",
                    "label": "\u63cf\u8ff0",
                    "rows": 3
                  },
                  {
                    "type": "switch",
                    "name": "isActive",
                    "label": "\u542f\u7528",
                    "trueValue": true,
                    "falseValue": false
                  },
                  {
                    "type": "input-number",
                    "name": "sortOrder",
                    "label": "\u6392\u5e8f",
                    "value": 0
                  }
                ],
                "name": "system-projects-dialog-form-1"
              },
              "actions": [
                {
                  "type": "button",
                  "label": "\u53d6\u6d88",
                  "actionType": "cancel"
                },
                {
                  "type": "button",
                  "label": "\u4fdd\u5b58",
                  "level": "primary",
                  "actionType": "submit",
                  "target": "system-projects-dialog-form-1"
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          {
            "name": "code",
            "label": "\u7f16\u7801"
          },
          {
            "name": "name",
            "label": "\u540d\u79f0"
          },
          {
            "name": "description",
            "label": "\u63cf\u8ff0",
            "tpl": "<span>${description || '-'}</span>"
          },
          {
            "name": "isActive",
            "label": "\u72b6\u6001",
            "type": "tpl",
            "tpl": "<span>${isActive ? '\u542f\u7528' : '\u505c\u7528'}</span>"
          },
          {
            "name": "sortOrder",
            "label": "\u6392\u5e8f"
          },
          {
            "type": "operation",
            "label": "\u64cd\u4f5c",
            "buttons": [
              {
                "label": "\u7f16\u8f91",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "\u7f16\u8f91\u9879\u76ee",
                  "body": {
                    "type": "form",
                    "api": {
                      "url": "/projects/${id}",
                      "method": "put",
                      "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u66f4\u65b0\u5b8c\u6210' };"
                    },
                    "body": [
                      {
                        "type": "input-text",
                        "name": "name",
                        "label": "\u540d\u79f0",
                        "required": true
                      },
                      {
                        "type": "textarea",
                        "name": "description",
                        "label": "\u63cf\u8ff0",
                        "rows": 3
                      },
                      {
                        "type": "switch",
                        "name": "isActive",
                        "label": "\u542f\u7528",
                        "trueValue": true,
                        "falseValue": false
                      },
                      {
                        "type": "input-number",
                        "name": "sortOrder",
                        "label": "\u6392\u5e8f",
                        "value": 0
                      }
                    ],
                    "initApi": "/projects/${id}",
                    "name": "system-projects-dialog-form-2"
                  },
                  "actions": [
                    {
                      "type": "button",
                      "label": "\u53d6\u6d88",
                      "actionType": "cancel"
                    },
                    {
                      "type": "button",
                      "label": "\u4fdd\u5b58",
                      "level": "primary",
                      "actionType": "submit",
                      "target": "system-projects-dialog-form-2"
                    }
                  ]
                }
              },
              {
                "label": "\u5220\u9664",
                "level": "link",
                "actionType": "ajax",
                "confirmText": "\u786e\u8ba4\u505c\u7528\u8be5\u9879\u76ee\uff1f",
                "api": {
                  "url": "/projects/${id}",
                  "method": "delete",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '\u505c\u7528\u5b8c\u6210' };"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
