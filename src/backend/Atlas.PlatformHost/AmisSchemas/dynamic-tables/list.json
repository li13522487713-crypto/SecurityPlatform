{
  "type": "page",
  "title": "动态表管理",
  "body": [
    {
      "type": "crud",
      "name": "tableCrud",
      "api": {
        "method": "get",
        "url": "/api/v1/dynamic-tables?pageIndex=${pageIndex}&pageSize=${pageSize}&keyword=${keyword}",
        "adaptor": "if (!payload.success) { return { status: 1, msg: payload.message }; } var d = payload.data || {}; var routeAppId = ''; try { var matched = (window.location.pathname || '').match(/^\\/apps\\/([^/]+)/); routeAppId = matched && matched[1] ? decodeURIComponent(matched[1]) : ''; } catch (e) { routeAppId = ''; } var withApp = (d.items || []).map(function(it) { return Object.assign({}, it, { appId: routeAppId || it.appId || '' }); }); return { status: 0, data: { items: withApp, total: d.total || 0, pageIndex: d.pageIndex || 1, pageSize: d.pageSize || 20 } };"
      },
      "pageField": "pageIndex",
      "perPageField": "pageSize",
      "pageSize": 20,
      "filter": {
        "title": "搜索",
        "body": [
          {
            "type": "input-text",
            "name": "keyword",
            "label": "关键字"
          }
        ]
      },
      "columns": [
        { "name": "tableKey", "label": "表标识" },
        { "name": "displayName", "label": "表名称" },
        { "name": "dbType", "label": "数据库类型" },
        { "name": "status", "label": "状态" },
        {
          "name": "approvalFlowDefinitionId",
          "label": "审批流",
          "type": "tpl",
          "tpl": "${approvalFlowDefinitionId ? '已绑定' : '未绑定'}"
        },
        { "name": "createdAt", "label": "创建时间" },
        {
          "type": "operation",
          "label": "操作",
          "buttons": [
            {
              "type": "button",
              "label": "进入数据",
              "actionType": "link",
              "link": "/apps/${appId || currentAppId}/data/${tableKey}"
            },
            {
              "type": "button",
              "label": "设计字段",
              "actionType": "link",
              "link": "/apps/${appId || currentAppId}/data/${tableKey}/design"
            },
            {
              "type": "button",
              "label": "绑定审批流",
              "actionType": "dialog",
              "dialog": {
                "title": "绑定审批流",
                "body": {
                  "type": "form",
                  "api": {
                    "method": "put",
                    "url": "/api/v1/dynamic-tables/${tableKey}/approval-binding",
                    "adaptor": "return { status: payload.success ? 0 : 1, msg: payload.success ? '绑定成功' : payload.message };"
                  },
                  "body": [
                    {
                      "type": "select",
                      "name": "approvalFlowDefinitionId",
                      "label": "审批流程",
                      "source": {
                        "method": "get",
                        "url": "/api/v1/approval/flows?pageIndex=1&pageSize=100&status=Published",
                        "adaptor": "if (!payload.success) return { status: 1 }; return { status: 0, data: { options: (payload.data.items || []).map(function(f) { return { label: f.name, value: f.id }; }) } };"
                      },
                      "clearable": true,
                      "description": "清空则解除绑定"
                    },
                    {
                      "type": "select",
                      "name": "approvalStatusField",
                      "label": "审批状态字段",
                      "visibleOn": "data.approvalFlowDefinitionId",
                      "required": true,
                      "source": {
                        "method": "get",
                        "url": "/api/v1/dynamic-tables/${tableKey}/fields",
                        "adaptor": "if (!payload.success) return { status: 1 }; return { status: 0, data: { options: (payload.data || []).filter(function(f) { return f.fieldType === 'String' || f.fieldType === 'Text'; }).map(function(f) { return { label: f.displayName || f.name, value: f.name }; }) } };"
                      },
                      "description": "选择用于存储审批状态的字符串字段"
                    }
                  ]
                }
              }
            },
            {
              "type": "button",
              "label": "删除",
              "level": "danger",
              "actionType": "ajax",
              "confirmText": "确认删除该表？此操作不可恢复。",
              "api": {
                "method": "delete",
                "url": "/api/v1/dynamic-tables/${tableKey}",
                "adaptor": "return { status: payload.success ? 0 : 1, msg: payload.message };"
              }
            }
          ]
        }
      ],
      "headerToolbar": [
        {
          "type": "button",
          "label": "新建表",
          "level": "primary",
          "actionType": "drawer",
          "drawer": {
            "title": "新建动态表",
            "size": "lg",
            "closeOnEsc": true,
            "body": {
              "type": "service",
              "schemaApi": "get:/api/v1/amis/dynamic-tables/designer"
            }
          }
        },
        "bulkActions",
        "pagination"
      ]
    }
  ]
}
