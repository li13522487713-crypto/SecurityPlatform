{
  "type": "form",
  "name": "tableForm",
  "id": "tableFormId",
  "className": "dynamic-table-form",
  "title": "",
  "api": {
    "method": "post",
    "url": "/api/v1/dynamic-tables",
    "headers": {
      "X-App-Id": "${appId || currentAppId || ''}",
      "X-App-Workspace": "1"
    },
    "requestAdaptor": "var body = api.data || {}; var appId = body.appId || body.currentAppId || ''; body.appId = appId ? String(appId) : null; body.indexes = []; body.fields = Array.isArray(body.fields) ? body.fields.map(function(field, idx) { return Object.assign({ sortOrder: idx + 1, allowNull: true, isPrimaryKey: false, isAutoIncrement: false, isUnique: false }, field || {}); }) : []; api.data = body; return api;",
    "data": {
      "tableKey": "${tableKey}",
      "displayName": "${displayName}",
      "description": "${description}",
      "appId": "${appId || currentAppId || null}",
      "dbType": "${dbType}",
      "fields": "${fields}"
    },
    "adaptor": "return { status: payload.success ? 0 : 1, msg: payload.message || '操作失败', data: payload.data };",
    "messages": {
      "success": "动态表保存成功！",
      "failed": "保存失败：${msg}"
    }
  },
  "onEvent": {
    "submitSucc": {
      "actions": [
        {
          "actionType": "link",
          "args": {
            "link": "/apps/${appId || currentAppId}/data/${tableKey}"
          }
        }
      ]
    }
  },
  "body": [
    {
      "type": "fieldset",
      "title": "基础信息",
      "collapsable": true,
      "body": [
        {
          "type": "input-text",
          "name": "tableKey",
          "id": "tableKeyInputId",
          "label": "表标识",
          "required": true,
          "clearable": true,
          "placeholder": "例如：customer_order",
          "description": "仅字母/数字/下划线，且以字母开头。",
          "onEvent": {
            "change": {
              "actions": [
                {
                  "actionType": "setValue",
                  "componentId": "tableFormId",
                  "args": {
                    "value": {
                      "__tableKeyManual": "${!!tableKey}"
                    }
                  }
                }
              ]
            }
          },
          "validation": {
            "pattern": "^(?!(?i)(select|from|where|table|index|create|drop|delete|update|insert|alter|TenantIdValue)$)[A-Za-z][A-Za-z0-9_]{1,63}$",
            "message": "表标识格式不正确或使用了保留字"
          }
        },
        {
          "type": "input-text",
          "name": "displayName",
          "label": "表名称",
          "required": true,
          "clearable": true,
          "placeholder": "例如：客户订单",
          "onEvent": {
            "blur": {
              "actions": [
                {
                  "actionType": "custom",
                  "expression": "${!__tableKeyManual}",
                  "script": "const raw = (event.data.displayName || '').trim(); if (!raw) { return; } const normalized = raw.normalize('NFKD').replace(/[\\u0300-\\u036f]/g, ''); const slug = normalized.replace(/[^A-Za-z0-9_\\s-]/g, '').replace(/[\\s-]+/g, '_').replace(/_+/g, '_').replace(/^_+|_+$/g, '').toLowerCase(); const fallback = `table_${Date.now().toString(36)}`; const tableKey = slug || fallback; doAction({ actionType: 'setValue', componentId: 'tableFormId', args: { value: { tableKey } } });"
                }
              ]
            }
          }
        },
        {
          "type": "hidden",
          "name": "__tableKeyManual",
          "value": false
        },
        {
          "type": "select",
          "name": "dbType",
          "label": "数据库类型",
          "value": "Sqlite",
          "clearable": false,
          "options": [
            { "label": "SQLite", "value": "Sqlite" },
            { "label": "SQL Server", "value": "SqlServer" },
            { "label": "MySQL", "value": "MySql" },
            { "label": "PostgreSQL", "value": "PostgreSql" }
          ]
        },
        {
          "type": "textarea",
          "name": "description",
          "label": "描述",
          "placeholder": "可选：补充该数据表用途与约束",
          "minRows": 2,
          "maxRows": 4
        }
      ]
    },
    {
      "type": "fieldset",
      "title": "字段定义",
      "collapsable": true,
      "body": [
        {
          "type": "alert",
          "level": "info",
          "showIcon": true,
          "body": "已预置主键和常用模板字段（createdAt/createdBy/updatedAt/updatedBy），可按需删除；字符串默认长度 50，金额请使用 Decimal。注意：只能有一个主键字段。"
        },
        {
          "type": "input-table",
          "name": "fields",
          "label": "字段定义",
          "addable": true,
          "addButtonText": "新增字段",
          "editable": true,
          "removable": true,
          "needConfirm": false,
          "showIndex": true,
          "minLength": 1,
          "validation": {
            "custom": "const pks = (value || []).filter(f => f.isPrimaryKey); if (pks.length > 1) return '只能有一个主键字段'; if (pks.length === 0) return '必须指定一个主键字段'; return '';"
          },
          "value": [
            {
              "name": "id",
              "displayName": "主键ID",
              "fieldType": "Long",
              "allowNull": false,
              "isPrimaryKey": true,
              "isAutoIncrement": true,
              "isUnique": true
            },
            {
              "name": "createdAt",
              "displayName": "创建时间(模板)",
              "fieldType": "DateTime",
              "allowNull": true,
              "isPrimaryKey": false,
              "isAutoIncrement": false,
              "isUnique": false
            },
            {
              "name": "createdBy",
              "displayName": "创建人(模板)",
              "fieldType": "Long",
              "allowNull": true,
              "isPrimaryKey": false,
              "isAutoIncrement": false,
              "isUnique": false
            },
            {
              "name": "updatedAt",
              "displayName": "更新时间(模板)",
              "fieldType": "DateTime",
              "allowNull": true,
              "isPrimaryKey": false,
              "isAutoIncrement": false,
              "isUnique": false
            },
            {
              "name": "updatedBy",
              "displayName": "更新人(模板)",
              "fieldType": "Long",
              "allowNull": true,
              "isPrimaryKey": false,
              "isAutoIncrement": false,
              "isUnique": false
            }
          ],
          "columns": [
            {
              "name": "name",
              "label": "字段名",
              "type": "input-text",
              "required": true,
              "unique": true,
              "placeholder": "例如：orderNo",
              "validation": {
                "pattern": "^(?!(?i)(select|from|where|table|index|create|drop|delete|update|insert|alter|TenantIdValue)$)[A-Za-z][A-Za-z0-9_]{0,63}$",
                "message": "字段名格式不正确或使用了保留字"
              }
            },
            {
              "name": "displayName",
              "label": "显示名",
              "type": "input-text",
              "placeholder": "例如：订单号"
            },
            {
              "name": "fieldType",
              "label": "类型",
              "type": "select",
              "required": true,
              "value": "String",
              "options": [
                { "label": "Int", "value": "Int" },
                { "label": "Long", "value": "Long" },
                { "label": "Decimal", "value": "Decimal" },
                { "label": "String", "value": "String" },
                { "label": "Text", "value": "Text" },
                { "label": "Bool", "value": "Bool" },
                { "label": "DateTime", "value": "DateTime" },
                { "label": "Date", "value": "Date" }
              ]
            },
            {
              "name": "length",
              "label": "长度",
              "type": "input-number",
              "visibleOn": "data.fieldType === 'String'",
              "clearValueOnHidden": true,
              "min": 1,
              "max": 1024,
              "value": 50
            },
            {
              "name": "precision",
              "label": "精度",
              "type": "input-number",
              "visibleOn": "data.fieldType === 'Decimal'",
              "clearValueOnHidden": true,
              "min": 1,
              "max": 38,
              "value": 18
            },
            {
              "name": "scale",
              "label": "小数位",
              "type": "input-number",
              "visibleOn": "data.fieldType === 'Decimal'",
              "clearValueOnHidden": true,
              "min": 0,
              "max": 18,
              "value": 2
            },
            {
              "name": "allowNull",
              "label": "可为空",
              "type": "switch",
              "value": true
            },
            {
              "name": "isPrimaryKey",
              "label": "主键",
              "type": "checkbox"
            },
            {
              "name": "isAutoIncrement",
              "label": "自增",
              "type": "checkbox",
              "visibleOn": "data.isPrimaryKey && (data.fieldType === 'Int' || data.fieldType === 'Long')",
              "clearValueOnHidden": true
            },
            {
              "name": "isUnique",
              "label": "唯一",
              "type": "checkbox"
            }
          ]
        }
      ]
    }
  ]
}
