{
  "Jwt": {
    "Issuer": "Atlas.SecurityPlatform",
    "Audience": "Atlas.SecurityPlatform.AppWeb",
    "SigningKey": "PLACEHOLDER__SET_VIA_ENV_JWT_SIGNING_KEY",
    "ExpiresMinutes": 60,
    "RefreshExpiresMinutes": 720,
    "SessionExpiresMinutes": 720
  },
  "Security": {
    "EnforceHttps": true,
    "BootstrapAdmin": {
      "Enabled": false
    }
  },
  "Microflow": {
    "Adapter": {
      "Mode": "http",
      "ApiBaseUrl": "/api"
    },
    "Runtime": {
      "MaxSteps": 5000,
      "MaxLoopIterations": 1000,
      "MaxCallDepth": 20,
      "MaxErrorHandlingDepth": 10,
      "RunTimeoutSeconds": 300,
      "ActionTimeoutSeconds": 60,
      "MaxTraceFrames": 20000,
      "MaxRuntimeLogs": 20000,
      "MaxOutputJsonBytes": 1048576,
      "MaxVariableSnapshotBytes": 1048576,
      "MaxConcurrentRuns": 20,
      "MaxConcurrentRunsPerResource": 3,
      "EnableRawValueInTrace": false,
      "Rest": {
        "AllowRealHttp": false,
        "AllowPrivateNetwork": false,
        "AllowedHosts": [],
        "DeniedHosts": [],
        "MaxResponseBytes": 1048576,
        "TimeoutSeconds": 30,
        "FollowRedirects": false
      }
    },
    "Metadata": {
      "SeedEnabled": false,
      "ForceSeed": false,
      "CacheTtlSeconds": 300
    },
    "Retention": {
      "RunSessionRetentionDays": 30,
      "TraceRetentionDays": 30,
      "LogRetentionDays": 30,
      "MaxRunSessionsPerResource": 1000,
      "FailedRunRetentionDays": 90
    },
    "Security": {
      "EnableProductionGuard": true,
      "RequireWorkspaceId": true,
      "RequireTenantId": false,
      "ApplyEntityAccessDefault": true,
      "EntityAccessMode": "DenyUnknownEntity"
    },
    "Diagnostics": {
      "EnableRuntimePlanApi": false,
      "EnableInternalDebugApi": false,
      "EnableVerboseTrace": false
    },
    "Observability": {
      "StructuredLoggingEnabled": true,
      "ActivitySourceName": "Atlas.Microflows",
      "AuditLogEnabled": true
    }
  },
  "Microflows": {
    "Metadata": {
      "SeedEnabled": false,
      "ForceSeed": false
    },
    "SeedData": {
      "Enabled": false
    }
  },
  "DatabaseInitializer": {
    "RunOnStartup": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "OpenTelemetry": {
    "EnableConsoleExporter": false
  }
}
