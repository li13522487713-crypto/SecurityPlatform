### Runtime Round 50 - FlowNavigator variable snapshots
# Expected JSON paths:
# - data.traceFrames[*].variablesSnapshot.$currentUser
# - data.traceFrames[retrieve frame].variablesSnapshot.orders
# - data.traceFrames[loop internal frame].variablesSnapshot.$currentIndex
POST {{host}}/api/microflows/runtime/navigate
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "options": { "includeVariableSnapshots": true, "loopIterations": 2 },
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "runtime-round-50-variable-store",
    "stableId": "runtime-round-50-variable-store",
    "name": "RuntimeRound50VariableStore",
    "displayName": "Runtime Round 50 VariableStore",
    "moduleId": "demo-module",
    "parameters": [{ "id": "p-customer", "name": "customerId", "required": true, "type": { "kind": "string" } }],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root-collection",
      "objects": [
        { "id": "start", "kind": "startEvent", "officialType": "Microflows$StartEvent" },
        {
          "id": "retrieve",
          "kind": "actionActivity",
          "officialType": "Microflows$ActionActivity",
          "action": {
            "id": "retrieve-action",
            "kind": "retrieve",
            "officialType": "Microflows$RetrieveAction",
            "outputVariableName": "orders",
            "retrieveSource": { "entityQualifiedName": "Sales.Order", "mode": "databaseAll" }
          }
        },
        { "id": "end", "kind": "endEvent", "officialType": "Microflows$EndEvent" }
      ],
      "flows": [
        { "id": "f-start-retrieve", "kind": "sequence", "originObjectId": "start", "destinationObjectId": "retrieve" },
        { "id": "f-retrieve-end", "kind": "sequence", "originObjectId": "retrieve", "destinationObjectId": "end" }
      ]
    },
    "flows": []
  }
}

### Runtime Round 50 - REST error handler variables
# Expected JSON paths:
# - data.traceFrames[handledEnd frame].variablesSnapshot.$latestError
# - data.traceFrames[handledEnd frame].variablesSnapshot.$latestHttpResponse
POST {{host}}/api/microflows/runtime/navigate
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "options": { "includeVariableSnapshots": true, "simulateRestError": true },
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "runtime-round-50-rest-error",
    "stableId": "runtime-round-50-rest-error",
    "name": "RuntimeRound50RestError",
    "moduleId": "demo-module",
    "parameters": [],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root-collection",
      "objects": [
        { "id": "start", "kind": "startEvent" },
        { "id": "rest", "kind": "actionActivity", "action": { "id": "rest-action", "kind": "restCall" } },
        { "id": "handledEnd", "kind": "endEvent" },
        { "id": "normalEnd", "kind": "endEvent" }
      ],
      "flows": [
        { "id": "f-start-rest", "originObjectId": "start", "destinationObjectId": "rest" },
        { "id": "f-rest-normal", "originObjectId": "rest", "destinationObjectId": "normalEnd" },
        { "id": "f-rest-error", "originObjectId": "rest", "destinationObjectId": "handledEnd", "isErrorHandler": true, "editor": { "edgeKind": "errorHandler" } }
      ]
    },
    "flows": []
  }
}

