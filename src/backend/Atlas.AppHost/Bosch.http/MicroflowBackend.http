### Runtime Round 56 - CallMicroflow / CallStack verify script
# Runs an end-to-end local child microflow call:
# 1. create child + parent resources
# 2. save child current schema with required string parameter and string return
# 3. parent testRun calls child by id / qualifiedName
# 4. assert output.callMicroflow.parameterBindings, returnBinding, childRunId, child trace parentRunId/callDepth
# 5. assert missing parameter and recursion failure paths
# Command:
#   npx tsx scripts/verify-microflow-callstack-runtime.ts
# Expected:
# - parent trace frame output.callMicroflow.childRunId exists
# - parent variablesSnapshot.childGreeting.valuePreview == "hello child"
# - GET /api/microflows/runs/{childRunId}/trace returns frames with parentRunId and callDepth
# - recursion failure includes RUNTIME_CALL_RECURSION_DETECTED

### Runtime Round 56 - GET child trace by childRunId
# Replace {{childRunId}} with output.callMicroflow.childRunId from the verify script or parent test-run response.
GET {{host}}/api/microflows/runs/{{childRunId}}/trace
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

@host = http://localhost:5002
@workspaceId = demo-workspace
@tenantId = demo-tenant
@userId = demo-user
@traceId = demo-trace
@microflowId = mf-seed-blank
@runtimeMicroflowId = mf-seed-blank
@versionId = replace-with-version-id-from-publish-response
@childRunId = replace-with-child-run-id-from-callmicroflow-output

