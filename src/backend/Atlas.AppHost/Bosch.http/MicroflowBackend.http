### Runtime Round 57 - RestCall / LogMessage verify script
# Covers mock REST execution, URL/header/query/body expression evaluation, sensitive header redaction,
# response variables, simulateRestError + $latestHttpResponse, structured LogMessage logs, and connector-required guardrails.
# Command:
#   npx tsx scripts/verify-microflow-restcall-logmessage-runtime.ts
# Expected:
# - TraceFrame.output.restCall contains requestPreview/securityDecision/statusCode/responsePreview/producedVariables
# - Authorization/Cookie/API key style headers are redacted in trace/log output
# - allowRealHttp=false does not send external requests and returns mock response
# - simulateRestError writes $latestHttpResponse in error handler scope
# - LogMessage logs include logNodeName/traceId/structuredFieldsJson

### Runtime Round 57 - TestRun RestCall mock GET/string response/status/header variables
POST {{host}}/api/microflows/{{microflowId}}/test-run
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "round57-rest-mock",
    "name": "Round57RestMock",
    "displayName": "Round57RestMock",
    "moduleId": "verify-module",
    "parameters": [
      { "id": "p-url", "name": "url", "dataType": "string", "type": { "kind": "string" } },
      { "id": "p-token", "name": "token", "dataType": "string", "type": { "kind": "string" } }
    ],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root",
      "objects": [
        { "id": "start", "kind": "startEvent", "officialType": "Microflows$StartEvent" },
        {
          "id": "rest",
          "kind": "actionActivity",
          "officialType": "Microflows$ActionActivity",
          "action": {
            "id": "rest-1",
            "kind": "restCall",
            "request": {
              "method": "GET",
              "urlExpression": "$url",
              "headers": [{ "key": "Authorization", "valueExpression": "$token" }],
              "queryParameters": [{ "key": "q", "valueExpression": "'demo'" }],
              "body": { "kind": "none" }
            },
            "response": {
              "handling": { "kind": "string", "outputVariableName": "responseText" },
              "statusCodeVariableName": "statusCode",
              "headersVariableName": "responseHeaders"
            },
            "timeoutSeconds": 5
          }
        },
        { "id": "end", "kind": "endEvent", "officialType": "Microflows$EndEvent" }
      ],
      "flows": [
        { "id": "f-start-rest", "kind": "sequence", "originObjectId": "start", "destinationObjectId": "rest" },
        { "id": "f-rest-end", "kind": "sequence", "originObjectId": "rest", "destinationObjectId": "end" }
      ]
    },
    "flows": []
  },
  "input": { "url": "https://example.com/api", "token": "Bearer demo-secret" },
  "options": { "allowRealHttp": false }
}

