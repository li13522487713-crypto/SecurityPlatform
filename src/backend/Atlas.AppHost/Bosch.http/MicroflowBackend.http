        { "id": "change-order", "kind": "actionActivity", "action": { "id": "change-order-action", "kind": "changeMembers", "changeVariableName": "order", "memberChanges": [{ "memberQualifiedName": "Sales.Order.Status", "valueExpression": "'Paid'" }], "commit": { "enabled": true }, "validateObject": true } },
