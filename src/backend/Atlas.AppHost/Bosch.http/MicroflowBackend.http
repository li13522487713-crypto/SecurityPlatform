  "input": { "name": "demo" },
  "options": { "maxSteps": 50 },
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "{{runtimeMicroflowId}}",
    "stableId": "{{runtimeMicroflowId}}",
    "name": "RuntimeRound42Demo",
    "displayName": "Runtime Round 42 Demo",
    "moduleId": "demo-module",
    "parameters": [{ "id": "p-name", "name": "name", "dataType": "String" }],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root-collection",
      "objects": [
        { "id": "start-1", "kind": "startEvent", "officialType": "Microflows$StartEvent" },
        {
          "id": "log-1",
          "kind": "actionActivity",
          "officialType": "Microflows$ActionActivity",
          "action": {
            "id": "action-log-1",
            "kind": "logMessage",
            "officialType": "Microflows$LogMessageAction",
            "template": { "text": "Round 42 backend mock run" },
            "level": "info"
          }
        },
        { "id": "end-1", "kind": "endEvent", "officialType": "Microflows$EndEvent" }
      ]
    },
    "flows": [
      { "id": "flow-start-log", "kind": "sequence", "originObjectId": "start-1", "destinationObjectId": "log-1" },
      { "id": "flow-log-end", "kind": "sequence", "originObjectId": "log-1", "destinationObjectId": "end-1" }
    ],
    "variables": {}
  }
}

### TestRun Round 42 - decision true
POST {{host}}/api/microflows/{{runtimeMicroflowId}}/test-run
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "input": {},
  "options": { "decisionBooleanResult": true },
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "{{runtimeMicroflowId}}",
    "name": "RuntimeRound42Decision",
    "moduleId": "demo-module",
    "parameters": [],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root-collection",
      "objects": [
        { "id": "start-1", "kind": "startEvent" },
        { "id": "decision-1", "kind": "exclusiveSplit", "splitCondition": { "resultType": "boolean", "expression": { "raw": "true" } } },
        { "id": "true-log", "kind": "actionActivity", "action": { "id": "true-log-action", "kind": "logMessage", "template": { "text": "true branch" } } },
        { "id": "false-log", "kind": "actionActivity", "action": { "id": "false-log-action", "kind": "logMessage", "template": { "text": "false branch" } } },
        { "id": "end-1", "kind": "endEvent" }
      ]
    },
    "flows": [
      { "id": "flow-start-decision", "originObjectId": "start-1", "destinationObjectId": "decision-1" },
      { "id": "flow-decision-true", "originObjectId": "decision-1", "destinationObjectId": "true-log", "caseValues": [{ "kind": "boolean", "value": "true" }] },
      { "id": "flow-decision-false", "originObjectId": "decision-1", "destinationObjectId": "false-log", "caseValues": [{ "kind": "boolean", "value": "false" }] },
      { "id": "flow-true-end", "originObjectId": "true-log", "destinationObjectId": "end-1" },
      { "id": "flow-false-end", "originObjectId": "false-log", "destinationObjectId": "end-1" }
    ],
    "variables": {}
  }
}

