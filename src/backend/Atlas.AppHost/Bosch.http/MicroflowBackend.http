@host = http://localhost:5002
@workspaceId = demo-workspace
@tenantId = demo-tenant
@userId = demo-user
@traceId = demo-trace
@microflowId = mf-seed-blank
@versionId = replace-with-version-id-from-publish-response

### Microflow health
GET {{host}}/api/microflows/health
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

### Microflow list
GET {{host}}/api/microflows?pageIndex=1&pageSize=20
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

### Microflow list favorite only sorted
GET {{host}}/api/microflows?pageIndex=1&pageSize=20&favoriteOnly=true&sortBy=updatedAt&sortOrder=desc
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

### Microflow create
POST {{host}}/api/microflows
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "workspaceId": "{{workspaceId}}",
  "input": {
    "name": "OrderApprovalDemo",
    "displayName": "Order Approval Demo",
    "description": "Created by real backend CRUD API.",
    "moduleId": "demo-module",
    "moduleName": "Demo",
    "tags": ["demo", "crud"],
    "parameters": [],
    "returnType": { "kind": "void" }
  }
}

