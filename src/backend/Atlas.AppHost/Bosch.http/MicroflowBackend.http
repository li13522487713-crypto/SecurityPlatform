### References Round 41 - save A schema that calls B
# Replace {{sourceMicroflowId}} and {{targetMicroflowId}} with ids from the two create responses.
PUT {{host}}/api/microflows/{{sourceMicroflowId}}/schema
Content-Type: application/json
X-Workspace-Id: {{workspaceId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
X-Trace-Id: {{traceId}}

{
  "saveReason": "round 41 callMicroflow reference",
  "schema": {
    "schemaVersion": "1.0.0",
    "id": "{{sourceMicroflowId}}",
    "stableId": "{{sourceMicroflowId}}",
    "name": "OrderProcessRound41",
    "displayName": "Order Process Round 41",
    "moduleId": "demo-module",
    "moduleName": "Demo",
    "parameters": [],
    "returnType": { "kind": "void" },
    "objectCollection": {
      "id": "root-collection",
      "objects": [
        { "id": "start-1", "kind": "startEvent" },
        {
          "id": "call-1",
          "kind": "actionActivity",
          "action": {
            "kind": "callMicroflow",
            "targetMicroflowId": "{{targetMicroflowId}}",
            "targetMicroflowQualifiedName": "Demo.NotifyUserRound41",
            "parameterMappings": [{ "parameterName": "userId", "expression": "'demo-user'" }]
          }
        },
        { "id": "end-1", "kind": "endEvent" }
      ]
    },
    "flows": [
      { "id": "flow-1", "originObjectId": "start-1", "destinationObjectId": "call-1" },
      { "id": "flow-2", "originObjectId": "call-1", "destinationObjectId": "end-1" }
    ],
    "variables": {}
  }
}

