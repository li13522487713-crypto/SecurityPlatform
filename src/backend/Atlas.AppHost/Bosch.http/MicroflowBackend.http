      "id": "root",
      "objects": [
        { "id": "start", "kind": "startEvent", "officialType": "Microflows$StartEvent" },
        { "id": "rest", "kind": "actionActivity", "officialType": "Microflows$ActionActivity", "action": { "id": "rest-1", "kind": "restCall", "request": { "method": "GET", "urlExpression": "$url" }, "response": { "handling": { "kind": "ignore" } } } },
        { "id": "log-error", "kind": "actionActivity", "officialType": "Microflows$ActionActivity", "action": { "id": "log-1", "kind": "logMessage", "level": "warning", "logNodeName": "RestErrorHandler", "template": { "text": "latest={0}", "arguments": ["$latestHttpResponse/statusCode"] }, "includeTraceId": true, "includeContextVariables": true } },
        { "id": "end", "kind": "endEvent", "officialType": "Microflows$EndEvent" }
      ],
      "flows": [
        { "id": "f-start-rest", "kind": "sequence", "originObjectId": "start", "destinationObjectId": "rest" },
        { "id": "f-rest-end", "kind": "sequence", "originObjectId": "rest", "destinationObjectId": "end" },
        { "id": "f-rest-error", "kind": "sequence", "originObjectId": "rest", "destinationObjectId": "log-error", "isErrorHandler": true, "editor": { "edgeKind": "errorHandler" } },
        { "id": "f-log-end", "kind": "sequence", "originObjectId": "log-error", "destinationObjectId": "end" }
      ]
    },
