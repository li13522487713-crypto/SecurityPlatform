@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@appKey = app-default
@appId = 1

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 按 key 查询应用
GET {{baseUrl}}/api/v1/lowcode-apps/by-key/{{appKey}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用详情
GET {{baseUrl}}/api/v1/lowcode-apps/{{appId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询应用页面列表
GET {{baseUrl}}/api/v1/lowcode-apps/{{appId}}/pages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
