@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@agentId = 1
@appId = 1
@workflowId = 1
@sessionId = 1

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 创建 Agent 会话
# @name createAgentSession
POST {{baseUrl}}/api/v1/agent-sessions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "agentId": {{agentId}},
  "title": "Workbench Session"
}

###
@createdSessionId = {{createAgentSession.response.body.$.data.Id}}

### 查询会话消息
GET {{baseUrl}}/api/v1/agent-sessions/{{createdSessionId}}/messages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 清空会话上下文
POST {{baseUrl}}/api/v1/conversations/{{createdSessionId}}/clear-context
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

### 清空会话历史
POST {{baseUrl}}/api/v1/conversations/{{createdSessionId}}/clear-history
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

### 删除会话
DELETE {{baseUrl}}/api/v1/conversations/{{createdSessionId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 追加工具消息
POST {{baseUrl}}/api/v1/agent-sessions/{{createdSessionId}}/messages
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "role": "tool",
  "content": "任务标题：安全事件处置任务\\n事件摘要：示例告警\\n严重级别：高",
  "metadata": "{\"kind\":\"workflow-task\",\"workflowId\":{{workflowId}},\"resourceUsage\":{\"usedPlugins\":[\"asset_lookup\"],\"usedKnowledgeBases\":[\"SOC 知识库\"],\"usedDatabases\":[\"incident_db\"],\"usedVariables\":[\"asset_id\"]}}"
}

### 绑定 Agent 默认工作流
POST {{baseUrl}}/api/v1/draft-agents/{{agentId}}/workflow-bindings
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "workflowId": {{workflowId}}
}

### 执行工作台工作流任务（AppHost 聚合）
POST {{baseUrl}}/api/v1/workflow-playground/{{workflowId}}/execute
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "incident": "主机检测到可疑 PowerShell 横向移动行为，需要立即安排隔离、排查和取证。",
  "source": "draft"
}

### App Builder 预览运行（绑定工作流）
POST {{baseUrl}}/api/v1/ai-apps/{{appId}}/preview-run
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "inputs": {
    "question": "请总结最近一次告警处置流程"
  }
}
