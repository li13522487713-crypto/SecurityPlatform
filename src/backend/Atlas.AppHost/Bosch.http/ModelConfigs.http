@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@modelConfigId = 1

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 模型配置分页
GET {{baseUrl}}/api/v1/model-configs?PageIndex=1&PageSize=20
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 模型配置统计
GET {{baseUrl}}/api/v1/model-configs/stats
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 查询单个模型配置
GET {{baseUrl}}/api/v1/model-configs/{{modelConfigId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 测试模型连接
POST {{baseUrl}}/api/v1/model-configs/test
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "providerType": "openai",
  "apiKey": "sk-demo-key",
  "baseUrl": "https://api.openai.com",
  "model": "gpt-4o-mini"
}
