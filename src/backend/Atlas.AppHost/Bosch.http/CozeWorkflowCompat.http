@host = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@contentType = application/json

### 登录
# @name login
POST {{host}}/api/v1/auth/token
Content-Type: {{contentType}}
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

### 获取验证码（AppHost）
# @name getCaptcha
GET {{host}}/api/v1/auth/captcha
X-Tenant-Id: {{tenantId}}

###
@captchaKey = {{getCaptcha.response.body.data.captchaKey}}

### 使用验证码登录（风控触发后）
POST {{host}}/api/v1/auth/token
Content-Type: {{contentType}}
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!",
  "captchaKey": "{{captchaKey}}",
  "captchaCode": "0000"
}

###
@token = {{login.response.body.data.accessToken}}
@workflowId = 1

### 原生 Coze 兼容：画布详情
POST {{host}}/api/workflow_api/canvas
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow"
}

### 原生 Coze 兼容：引用关系
POST {{host}}/api/workflow_api/workflow_references
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "space_id": "atlas-workflow"
}

### 原生 Coze Playground 兼容：空间列表
POST {{host}}/api/playground_api/space/list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{}

### 原生 Coze Bot 兼容：模型类型列表
POST {{host}}/api/bot/get_type_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "model_scene": 1
}

### 原生 Coze 兼容：创建工作流（P0）
POST {{host}}/api/workflow_api/create
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "name": "AppHost Coze Compat Workflow",
  "desc": "compat smoke",
  "space_id": "atlas-workflow",
  "flow_mode": 0
}

### 原生 Coze 兼容：工作流列表（P0）
POST {{host}}/api/workflow_api/workflow_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "page": 1,
  "size": 10,
  "space_id": "atlas-workflow"
}

### 原生 Coze OP 兼容：differences（fallback）
POST {{host}}/api/op_workflow/differences
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}"
}

### 原生 Coze Playground 兼容：get_type_list（fallback）
POST {{host}}/api/playground_api/get_type_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "model_scene": 1
}

### 原生 Coze Developer 兼容：draftbot/list（fallback）
POST {{host}}/api/draftbot/get_draft_bot_list
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "page": 1,
  "size": 10
}

### 原生 Coze OpenAPI 兼容：chat（fallback）
POST {{host}}/v1/workflows/chat
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "workflow_id": "{{workflowId}}",
  "inputs": {
    "incident": "openapi chat smoke"
  }
}

### 原生 Coze OpenAPI 兼容：工作空间列表（v1）
# @name openSpaceList
GET {{host}}/v1/workspaces?page_num=1&page_size=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

###
@workspaceId = {{openSpaceList.response.body.data.workspaces[0].id}}
@memberUserId = 1

### 原生 Coze OpenAPI 兼容：工作空间列表（api/v1 别名）
GET {{host}}/api/v1/workspaces?page_num=1&page_size=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze OpenAPI 兼容：创建工作空间
POST {{host}}/v1/workspaces
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "name": "Compat Workspace",
  "description": "created from coze compat http"
}

### 原生 Coze OpenAPI 兼容：空间成员列表
GET {{host}}/v1/workspaces/{{workspaceId}}/members?page_num=1&page_size=20
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze OpenAPI 兼容：新增空间成员
POST {{host}}/v1/workspaces/{{workspaceId}}/members
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "users": [
    {
      "user_id": "{{memberUserId}}",
      "role_type": "member"
    }
  ]
}

### 原生 Coze OpenAPI 兼容：更新空间成员角色
PUT {{host}}/v1/workspaces/{{workspaceId}}/members/{{memberUserId}}
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "role_type": "member"
}

### 原生 Coze OpenAPI 兼容：移除空间成员
DELETE {{host}}/v1/workspaces/{{workspaceId}}/members
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "user_ids": ["{{memberUserId}}"]
}

### 原生 Coze OpenAPI 兼容：申请加入空间
POST {{host}}/v1/workspaces/{{workspaceId}}/members/apply
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "user_ids": ["{{memberUserId}}"]
}

### 原生 Coze OpenAPI 兼容：删除空间
DELETE {{host}}/v1/workspaces/{{workspaceId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze OpenAPI 兼容：Bot 详情（api/v1 别名）
GET {{host}}/api/v1/bots/{{memberUserId}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze OpenAPI 兼容：Bot 版本列表
GET {{host}}/v1/bots/{{memberUserId}}/versions?page_num=1&page_size=10
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 原生 Coze OpenAPI 兼容：切换 Bot 协作模式
POST {{host}}/v1/bots/{{memberUserId}}/collaboration_mode
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "collaboration_mode": "single"
}
