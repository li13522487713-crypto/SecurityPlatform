@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!
@taskId = 1

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###

### 我的待办
GET {{baseUrl}}/api/v1/approval/tasks/my?PageIndex=1&PageSize=10
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 任务详情
GET {{baseUrl}}/api/v1/approval/tasks/{{taskId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 标记已阅
POST {{baseUrl}}/api/v1/approval/tasks/{{taskId}}/viewed
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
