@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@workspaceId = atlas-space
@username = admin
@password = P@ssw0rd!

### 登录获取令牌
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 渠道列表
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels?pageIndex=1&pageSize=50
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 渠道目录
GET {{baseUrl}}/api/v1/publish-channels/catalog
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 新增渠道
# @name createChannel
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "Web SDK",
  "type": "web-sdk",
  "description": "在外部站点嵌入聊天窗口",
  "supportedTargets": ["agent", "app"]
}

###
@channelId = {{createChannel.response.body.$.data.channelId}}

### 重新授权
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}/reauth
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 删除渠道
DELETE {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 飞书凭据 upsert
PUT {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}/feishu-credential
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appId": "cli_xxxx",
  "appSecret": "xxxxxxxx",
  "verificationToken": "vtoken-from-feishu",
  "encryptKey": null
}

### 微信公众号凭据 upsert
PUT {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}/wechat-mp-credential
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appId": "wx_xxxx",
  "appSecret": "xxxxxxxx",
  "token": "wechat-token-from-platform",
  "encodingAesKey": null
}

### 微信小程序凭据 upsert
PUT {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}/wechat-miniapp-credential
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "appId": "wxmini_xxxx",
  "appSecret": "xxxxxxxx",
  "originalId": "gh_xxxx",
  "messageToken": "mini-token",
  "encodingAesKey": null
}

### 微信客服凭据 upsert
PUT {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/publish-channels/{{channelId}}/wechat-cs-credential
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "corpId": "ww_xxxx",
  "secret": "xxxxxxxx",
  "openKfId": "wkf_xxxx",
  "token": "kf-token",
  "encodingAesKey": null
}
