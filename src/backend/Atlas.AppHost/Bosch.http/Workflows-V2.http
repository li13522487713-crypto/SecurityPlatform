@host = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@contentType = application/json

### 登录获取令牌
# @name login
POST {{host}}/api/v1/auth/token
Content-Type: {{contentType}}
X-Tenant-Id: {{tenantId}}

{
  "username": "admin",
  "password": "P@ssw0rd!"
}

###
@token = {{login.response.body.data.accessToken}}
@workflowId = 1

### 获取 CSRF Token
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

###

### 获取工作流依赖
GET {{host}}/api/v2/workflows/{{workflowId}}/dependencies
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

### 保存工作流草稿
PUT {{host}}/api/v2/workflows/{{workflowId}}/draft
Content-Type: {{contentType}}
Authorization: Bearer {{token}}
X-Tenant-Id: {{tenantId}}

{
  "canvasJson": "{\"nodes\":[],\"connections\":[]}",
  "commitId": "apphost-draft-smoke"
}
