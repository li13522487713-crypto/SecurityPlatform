@baseUrl = http://localhost:5002
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}
@orgId = {{tenantId}}

### 工作空间列表
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 按 AppKey 查询工作空间
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/by-app-key/dev-app
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建工作空间（1→N 模型：不再需要 appInstanceId；应用实例由后续 POST app-instances 单独创建）
# @name createWorkspace
POST {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "新工作空间 {{$timestamp}}",
  "description": "用于验证组织-工作空间入口",
  "icon": "workspace"
}

###
@createdWorkspaceId = {{createWorkspace.response.body.$.data.id}}

### 1→N 模型：在工作空间内创建应用实例（AppManifest）
# AppKey 留空时由后端按 ws-{workspaceId}-app-{seq} 自动生成。
# @name createWorkspaceAppInstance
POST {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/{{createdWorkspaceId}}/app-instances
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "默认应用 {{$timestamp}}",
  "description": "用于验证 1→N 工作空间-应用实例创建链路",
  "icon": "app",
  "category": "general",
  "appKey": null
}

### 工作空间详情
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新工作空间
PUT {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/{{createdWorkspaceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "已更新工作空间 {{$timestamp}}",
  "description": "用于验证工作空间更新接口",
  "icon": "workspace-updated"
}

### 工作空间开发页应用
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/develop/apps?pageIndex=1&pageSize=12
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 在工作空间内创建应用
# AgentId 当前允许为空；本接口只需提供应用基础信息，后端会先创建 Workflow，再创建未绑定 Agent 的 AiApp。
POST {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/develop/apps
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "name": "Workspace App {{$timestamp}}",
  "description": "用于验证工作空间应用优先入口"
}

### 工作空间资源列表
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/resources?resourceType=agent&pageIndex=1&pageSize=8
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 工作空间成员列表
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/members
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 添加工作空间成员
POST {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/members
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "userId": "1",
  "roleCode": "Member"
}

### 查看资源权限
GET {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/resources/app/1/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新资源权限
PUT {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/1/resources/app/1/permissions
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "items": [
    {
      "roleCode": "Owner",
      "actions": ["view", "edit", "publish", "delete", "manage-permission"]
    },
    {
      "roleCode": "Member",
      "actions": ["view"]
    }
  ]
}

### 归档工作空间
DELETE {{baseUrl}}/api/v1/organizations/{{orgId}}/workspaces/{{createdWorkspaceId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
